<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/core_ui_dp_24"
    android:paddingTop="@dimen/core_ui_dp_20"
    android:paddingEnd="@dimen/core_ui_dp_24"
    android:paddingBottom="@dimen/core_ui_dp_20">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="@dimen/core_ui_dp_16"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/core_ui_dp_20"
            android:paddingTop="@dimen/core_ui_dp_20"
            android:paddingEnd="@dimen/core_ui_dp_20"
            android:paddingBottom="@dimen/core_ui_dp_20">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#x4ECA;&#x65E5;&#x65B0;&#x5B66;&#x5DF2;&#x5B8C;&#x6210;"
                android:textColor="#0f172a"
                android:textSize="@dimen/core_ui_text_18"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/core_ui_dp_14"
                android:text="&#x52A0;&#x91CF;&#x65B0;&#x5B66;&#x6570;&#x91CF;"
                android:textColor="#475569"
                android:textSize="@dimen/core_ui_text_14" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/core_ui_dp_12"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvOptionFive"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/core_ui_dp_40"
                    android:layout_weight="1"
                    android:background="@drawable/feature_home_select_border_gray"
                    android:gravity="center"
                    android:text="+5"
                    android:textColor="#0f172a"
                    android:textSize="@dimen/core_ui_text_14"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvOptionTen"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/core_ui_dp_40"
                    android:layout_marginStart="@dimen/core_ui_dp_10"
                    android:layout_weight="1"
                    android:background="@drawable/feature_home_select_border_gray"
                    android:gravity="center"
                    android:text="+10"
                    android:textColor="#0f172a"
                    android:textSize="@dimen/core_ui_text_14"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvOptionTwenty"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/core_ui_dp_40"
                    android:layout_marginStart="@dimen/core_ui_dp_10"
                    android:layout_weight="1"
                    android:background="@drawable/feature_home_select_border_gray"
                    android:gravity="center"
                    android:text="+20"
                    android:textColor="#0f172a"
                    android:textSize="@dimen/core_ui_text_14"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvConfirmBoost"
                android:layout_width="match_parent"
                android:layout_height="@dimen/core_ui_dp_48"
                android:layout_marginTop="@dimen/core_ui_dp_18"
                android:background="@drawable/feature_home_select_radius_black"
                android:gravity="center"
                android:text="&#x52A0;&#x91CF;&#x65B0;&#x5B66; (+5)"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/core_ui_text_15"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCancel"
                android:layout_width="match_parent"
                android:layout_height="@dimen/core_ui_dp_48"
                android:layout_marginTop="@dimen/core_ui_dp_10"
                android:background="@drawable/feature_home_select_border_gray"
                android:gravity="center"
                android:text="&#x53D6;&#x6D88;"
                android:textColor="#334155"
                android:textSize="@dimen/core_ui_text_15"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/module_home_bg_practice_entry_sheet"
    android:paddingStart="@dimen/core_ui_dp_20"
    android:paddingEnd="@dimen/core_ui_dp_20"
    android:paddingTop="@dimen/core_ui_dp_16"
    android:paddingBottom="@dimen/core_ui_dp_24">

    <View
        android:layout_width="@dimen/core_ui_dp_36"
        android:layout_height="@dimen/core_ui_dp_4"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/core_ui_dp_4"
        android:layout_marginBottom="@dimen/core_ui_dp_12"
        android:background="@drawable/module_home_bg_practice_entry_handle" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/practice_entry_title"
        android:textColor="#0F172A"
        android:textSize="@dimen/core_ui_text_20"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/core_ui_dp_8"
        android:text="@string/practice_entry_subtitle"
        android:textColor="#64748B"
        android:textSize="@dimen/core_ui_text_13" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/core_ui_dp_16"
        android:background="@drawable/module_home_bg_practice_entry_card"
        android:orientation="vertical"
        android:padding="@dimen/core_ui_dp_16">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/practice_entry_count_label"
            android:textColor="#94A3B8"
            android:textSize="@dimen/core_ui_text_12" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_10"
            android:background="@drawable/module_home_bg_practice_entry_input"
            android:gravity="center_vertical"
            android:minHeight="@dimen/core_ui_dp_48"
            android:orientation="horizontal"
            android:paddingStart="@dimen/core_ui_dp_16"
            android:paddingEnd="@dimen/core_ui_dp_16">

            <EditText
                android:id="@+id/et_random_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="@string/practice_entry_count_hint"
                android:inputType="number"
                android:padding="0dp"
                android:textColor="#0F172A"
                android:textSize="@dimen/core_ui_text_14"
                android:textColorHint="#94A3B8" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/practice_entry_count_unit"
                android:textColor="#94A3B8"
                android:textSize="@dimen/core_ui_text_14" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_8"
            android:text="@string/practice_entry_tip"
            android:textColor="#94A3B8"
            android:textSize="@dimen/core_ui_text_12" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_random"
        android:layout_width="match_parent"
        android:layout_height="@dimen/core_ui_dp_52"
        android:layout_marginTop="@dimen/core_ui_dp_20"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="@string/practice_entry_random_btn"
        android:textColor="@android:color/white"
        android:textSize="@dimen/core_ui_text_16"
        app:backgroundTint="@color/practice_entry_primary"
        app:cornerRadius="@dimen/core_ui_dp_26" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_self_select"
        android:layout_width="match_parent"
        android:layout_height="@dimen/core_ui_dp_52"
        android:layout_marginTop="@dimen/core_ui_dp_12"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="@string/practice_entry_self_btn"
        android:textColor="#0F172A"
        android:textSize="@dimen/core_ui_text_16"
        app:backgroundTint="@android:color/white"
        app:cornerRadius="@dimen/core_ui_dp_26"
        app:strokeColor="@color/practice_entry_outline"
        app:strokeWidth="@dimen/core_ui_dp_1" />
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.chen.memorizewords.feature.home.ui.practice.PracticeViewModel" />
    </data>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/module_home_bg_home"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/page_margin">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/title_margin"
                android:gravity="center"
                android:text="自由练习"
                android:textColor="#000"
                android:textSize="@dimen/title_text_size"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/home_practice_today_duration"
                    android:textColor="@color/practice_record_icon_shadowing"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPracticeTodayDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:textColor="#0F172A"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    tools:text="01:00:00" />

                <LinearLayout
                    android:padding="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_practice_total_duration"
                            android:textColor="#94A3B8"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvPracticeTotalMinutesValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#0F172A"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                tools:text="15" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/home_minutes_unit"
                                android:textColor="#64748B"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="32dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="#E2E8F0" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_practice_streak_days"
                            android:textColor="#94A3B8"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvPracticeStreakValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#0F172A"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                tools:text="15" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/home_days_unit"
                                android:textColor="#64748B"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="2dp"
                        android:layout_height="10dp"
                        android:background="#34D399" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/feature_home_practice_mode_section_title"
                        android:textColor="#0F172A"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="124dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/feature_home_bg_practice_mode_listening_card"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:onClick="@{() -> viewModel.openListening()}"
                        android:stateListAnimator="@animator/btn_scale_animator">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:paddingStart="6dp"
                            android:paddingTop="11dp"
                            android:paddingEnd="6dp"
                            android:paddingBottom="18dp">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/module_home_practice_circle_listening"
                                android:padding="8dp"
                                android:src="@drawable/feature_home_ic_practice_headset"
                                app:tint="@color/practice_record_icon_listening" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/home_practice_mode_listening"
                                android:textColor="#0F172A"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:gravity="center"
                                android:lineSpacingExtra="1dp"
                                android:maxLines="2"
                                android:text="@string/feature_home_practice_mode_listening_desc"
                                android:textColor="#64748B"
                                android:textSize="9sp" />
                        </LinearLayout>
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="124dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/feature_home_bg_practice_mode_shadowing_card"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:onClick="@{() -> viewModel.openShadowing()}"
                        android:stateListAnimator="@animator/btn_scale_animator">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:paddingStart="6dp"
                            android:paddingTop="11dp"
                            android:paddingEnd="6dp"
                            android:paddingBottom="18dp">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/module_home_practice_circle_shadowing"
                                android:padding="8dp"
                                android:src="@drawable/feature_home_ic_practice_mic"
                                app:tint="@color/practice_record_icon_shadowing" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/home_practice_mode_shadowing"
                                android:textColor="#0F172A"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:gravity="center"
                                android:lineSpacingExtra="1dp"
                                android:maxLines="2"
                                android:text="@string/feature_home_practice_mode_shadowing_desc"
                                android:textColor="#64748B"
                                android:textSize="9sp" />
                        </LinearLayout>
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="124dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/feature_home_bg_practice_mode_spelling_card"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:onClick="@{() -> viewModel.openSpelling()}"
                        android:stateListAnimator="@animator/btn_scale_animator">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:paddingStart="6dp"
                            android:paddingTop="11dp"
                            android:paddingEnd="6dp"
                            android:paddingBottom="18dp">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/module_home_practice_circle_spelling"
                                android:padding="8dp"
                                android:src="@drawable/feature_home_ic_practice_edit"
                                app:tint="@color/practice_record_icon_spelling" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/home_practice_mode_spelling"
                                android:textColor="#0F172A"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:gravity="center"
                                android:lineSpacingExtra="1dp"
                                android:maxLines="2"
                                android:text="@string/feature_home_practice_mode_spelling_desc"
                                android:textColor="#64748B"
                                android:textSize="9sp" />
                        </LinearLayout>
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="124dp"
                        android:layout_weight="1"
                        android:background="@drawable/feature_home_bg_practice_mode_audio_loop_card"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:onClick="@{() -> viewModel.openAudioLoop()}"
                        android:stateListAnimator="@animator/btn_scale_animator">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:paddingStart="6dp"
                            android:paddingTop="11dp"
                            android:paddingEnd="6dp"
                            android:paddingBottom="18dp">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/feature_home_practice_circle_player"
                                android:padding="8dp"
                                android:src="@drawable/feature_home_ic_practice_play"
                                app:tint="@color/practice_record_icon_audio_loop" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/home_practice_mode_audio_loop"
                                android:textColor="#0F172A"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:gravity="center"
                                android:lineSpacingExtra="1dp"
                                android:maxLines="2"
                                android:text="@string/feature_home_practice_mode_audio_loop_desc"
                                android:textColor="#64748B"
                                android:textSize="9sp" />
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutFloatingCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/feature_home_bg_layout_floating_card"
                android:gravity="center_vertical"
                android:minHeight="76dp"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingTop="14dp"
                android:paddingEnd="16dp"
                android:paddingBottom="14dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/feature_home_bg_floating_ball">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/feature_home_ic_floating_ball" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/feature_home_floating_section_title"
                            android:textColor="#0F172A"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/feature_home_bg_floating_vip_badge">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="VIP"
                                android:textColor="#EA580C"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/feature_home_floating_subtitle"
                        android:textColor="#64748B"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/btnFloatingSettings"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="@string/feature_home_floating_settings"
                    android:focusable="true"
                    android:padding="4dp"
                    android:src="@drawable/feature_home_settings_172337" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchFloatingCard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@drawable/feature_home_floating_switch_thumb_tint"
                    app:trackTint="@drawable/feature_home_floating_switch_track_tint" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPracticeRecords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/tvPracticeRecordsEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="6dp"
                android:text="@string/home_practice_records_empty"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</layout>

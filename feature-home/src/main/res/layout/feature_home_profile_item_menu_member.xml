<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>
        <variable
            name="viewModel"
            type="com.chen.memorizewords.feature.home.ui.profile.ProfileViewModel" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:gravity="center_vertical"
        android:onClick="@{()->viewModel.toMembership()}"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/feature_home_bg_profile_icon_orange"
            android:contentDescription="@null"
            android:padding="6dp"
            android:src="@drawable/feature_home_ic_profile_menu_crown" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/feature_home_profile_member_center"
            android:textColor="#101C32"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:contentDescription="@null"
            android:src="@drawable/module_home_ic_right" />
    </LinearLayout>
</layout>

<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/module_home_bg_home"
        android:orientation="vertical"
        android:padding="@dimen/page_margin"
        tools:context=".ui.profile.PersonalQrActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/title_margin">

        <ImageView
            android:id="@+id/feature_home_btn_qr_back"
            android:layout_width="@dimen/title_icon_size"
            android:layout_height="@dimen/title_icon_size"
            android:contentDescription="@string/feature_home_common_back"
            android:padding="@dimen/core_ui_dp_2"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/feature_home_profile_personal_qr"
            android:textColor="#0F172A"
            android:textSize="@dimen/title_text_size"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/feature_home_btn_qr_back"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/feature_home_btn_qr_back" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/core_ui_dp_18"
        android:gravity="center"
        android:text="@string/feature_home_profile_qr_subtitle"
        android:textColor="#64748B"
        android:textSize="@dimen/core_ui_text_13" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/core_ui_dp_18"
        android:background="@drawable/feature_home_bg_profile_panel"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="@dimen/core_ui_dp_20">

        <ImageView
            android:id="@+id/feature_home_iv_qr_avatar"
            android:layout_width="@dimen/core_ui_dp_64"
            android:layout_height="@dimen/core_ui_dp_64"
            android:background="@drawable/bg_avatar_ring"
            android:padding="@dimen/core_ui_dp_4"
            android:scaleType="centerCrop"
            tools:src="@drawable/feature_home_ic_avatar_placeholder" />

        <TextView
            android:id="@+id/feature_home_tv_qr_nickname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_12"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="#0F172A"
            android:textSize="@dimen/core_ui_text_18"
            android:textStyle="bold"
            tools:text="小白" />

        <TextView
            android:id="@+id/feature_home_tv_qr_user_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_6"
            android:gravity="center"
            android:textColor="#64748B"
            android:textSize="@dimen/core_ui_text_13"
            tools:text="用户 ID：10001" />

        <FrameLayout
            android:layout_width="@dimen/core_ui_dp_240"
            android:layout_height="@dimen/core_ui_dp_240"
            android:layout_marginTop="@dimen/core_ui_dp_18"
            android:background="@drawable/feature_home_bg_qr_surface"
            android:padding="@dimen/core_ui_dp_14">

            <ImageView
                android:id="@+id/feature_home_iv_qr_code"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/feature_home_profile_personal_qr"
                android:scaleType="fitCenter" />
        </FrameLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/feature_home_tv_qr_scan_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/core_ui_dp_16"
        android:background="@drawable/feature_home_bg_profile_panel"
        android:lineSpacingExtra="@dimen/core_ui_dp_3"
        android:padding="@dimen/core_ui_dp_14"
        android:textColor="#334155"
        android:textSize="@dimen/core_ui_text_13"
        android:visibility="gone"
        tools:text="扫码结果"
        tools:visibility="visible" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/feature_home_btn_copy_qr_payload"
        android:layout_width="match_parent"
        android:layout_height="@dimen/core_ui_dp_46"
        android:background="@drawable/feature_home_bg_profile_secondary_button"
        android:gravity="center"
        android:text="@string/feature_home_profile_qr_copy"
        android:textColor="#0F172A"
        android:textSize="@dimen/core_ui_text_14"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/feature_home_btn_start_qr_scan"
        android:layout_width="match_parent"
        android:layout_height="@dimen/core_ui_dp_48"
        android:layout_marginTop="@dimen/core_ui_dp_10"
        android:background="@drawable/feature_home_bg_profile_primary_button"
        android:gravity="center"
        android:text="@string/feature_home_profile_scan"
        android:textColor="#0F172A"
        android:textSize="@dimen/core_ui_text_15"
        android:textStyle="bold" />
    </LinearLayout>
</layout>
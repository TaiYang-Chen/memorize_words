<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="@dimen/core_ui_dp_8"
        android:paddingBottom="@dimen/core_ui_dp_8">

        <TextView
            android:id="@+id/tvWord"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#0F172A"
            android:textSize="@dimen/core_ui_text_14"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPhonetic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_2"
            android:textColor="#94A3B8"
            android:textSize="@dimen/core_ui_text_12" />

        <TextView
            android:id="@+id/tvDefinition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_2"
            android:textColor="#64748B"
            android:textSize="@dimen/core_ui_text_12" />
    </LinearLayout>
</layout>

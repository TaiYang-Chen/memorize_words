<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="1dp">

    <View
        android:id="@+id/view_day_selected"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/module_home_stats_day_bg_selected"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_calendar_day"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:textColor="#334155"
        android:textSize="12sp"
        android:textStyle="bold" />

    <View
        android:id="@+id/view_day_today_dot"
        android:layout_width="4dp"
        android:layout_height="4dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="4dp"
        android:background="@drawable/module_home_stats_day_today_dot"
        android:visibility="gone" />

</FrameLayout>

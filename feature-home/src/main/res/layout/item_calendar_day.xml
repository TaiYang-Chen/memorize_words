<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/core_ui_dp_1">

    <View
        android:id="@+id/view_day_selected"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/module_home_stats_day_bg_selected"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_calendar_day"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:textColor="#0F172A"
        android:textSize="@dimen/core_ui_text_13" />

    <View
        android:id="@+id/view_day_today_dot"
        android:layout_width="@dimen/core_ui_dp_4"
        android:layout_height="@dimen/core_ui_dp_4"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="@dimen/core_ui_dp_2"
        android:background="@drawable/module_home_stats_day_today_dot"
        android:visibility="gone" />

</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.chen.memorizewords.feature.home.ui.home.HomeViewModel" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/core_ui_dp_16"
        android:paddingEnd="@dimen/core_ui_dp_16">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/module_home_select_radius_black"
            android:clickable="true"
            android:enabled="@{viewModel.learningButtonEnabled}"
            android:gravity="center"
            android:onClick="@{() -> viewModel.onStartLearningClick()}"
            android:padding="@dimen/core_ui_dp_16"
            android:stateListAnimator="@animator/btn_scale_animator"
            android:text="@{viewModel.learnButtonText}"
            android:textColor="#fff"
            tools:text="&#x5F00;&#x59CB;&#x5B66;&#x4E60;" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_24"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/core_ui_dp_8"
                android:layout_weight="1"
                android:background="@drawable/module_home_select_border_gray"
                android:gravity="center"
                android:onClick="@{() -> viewModel.toLearningReviewActivity()}"
                android:orientation="horizontal"
                android:padding="@dimen/core_ui_dp_12"
                android:stateListAnimator="@animator/module_learning_btn_scale_animator">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/module_home_refresh_fff" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/core_ui_dp_8"
                    android:text="&#x590D;&#x4E60;&#x5355;&#x8BCD;"
                    android:textColor="#0f172a"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/core_ui_dp_8"
                android:layout_weight="1"
                android:background="@drawable/module_home_select_border_gray"
                android:gravity="center"
                android:onClick="@{() -> viewModel.toWordBookActivity()}"
                android:orientation="horizontal"
                android:padding="@dimen/core_ui_dp_12"
                android:stateListAnimator="@animator/module_learning_btn_scale_animator">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/module_home_edit_calendar_6b46c1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/core_ui_dp_8"
                    android:text="&#x4FEE;&#x6539;&#x8BA1;&#x5212;"
                    android:textColor="#0f172a"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</layout>

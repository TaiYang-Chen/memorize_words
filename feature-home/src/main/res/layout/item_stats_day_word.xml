<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="@dimen/core_ui_dp_54"
    android:orientation="horizontal"
    android:paddingStart="@dimen/core_ui_dp_14"
    android:paddingTop="@dimen/core_ui_dp_9"
    android:paddingEnd="@dimen/core_ui_dp_14"
    android:paddingBottom="@dimen/core_ui_dp_9">

    <TextView
        android:id="@+id/tvBadge"
        android:layout_width="@dimen/core_ui_dp_32"
        android:layout_height="@dimen/core_ui_dp_32"
        android:gravity="center"
        android:includeFontPadding="false"
        android:textColor="#0B5FE8"
        android:textSize="@dimen/core_ui_text_14"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvWord"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/core_ui_dp_14"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#071426"
        android:textSize="@dimen/core_ui_text_17" />

    <TextView
        android:id="@+id/tvDefinition"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/core_ui_dp_10"
        android:layout_weight="1"
        android:ellipsize="end"
        android:gravity="end"
        android:maxLines="1"
        android:textColor="#333B4D"
        android:textSize="@dimen/core_ui_text_15"
        android:textStyle="bold" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/module_home_bg_practice_entry_sheet"
        android:orientation="vertical"
        android:paddingStart="@dimen/core_ui_dp_20"
        android:paddingEnd="@dimen/core_ui_dp_20"
        android:paddingTop="@dimen/core_ui_dp_16"
        android:paddingBottom="@dimen/core_ui_dp_24">

        <View
            android:layout_width="@dimen/core_ui_dp_36"
            android:layout_height="@dimen/core_ui_dp_4"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/core_ui_dp_4"
            android:layout_marginBottom="@dimen/core_ui_dp_12"
            android:background="@drawable/module_home_bg_practice_entry_handle" />

        <TextView
            android:id="@+id/tvDetailTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/practice_record_detail_title"
            android:textColor="#0F172A"
            android:textSize="@dimen/core_ui_text_18"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDetailRecordTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_10"
            android:textColor="#0F172A"
            android:textSize="@dimen/core_ui_text_14"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDetailRecordSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_4"
            android:textColor="@color/practice_record_subtitle"
            android:textSize="@dimen/core_ui_text_12" />

        <TextView
            android:id="@+id/tvDetailRecordSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_10"
            android:background="@drawable/module_home_bg_practice_entry_sheet"
            android:padding="@dimen/core_ui_dp_12"
            android:textColor="#475569"
            android:textSize="@dimen/core_ui_text_12"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRecordWords"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_12"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:id="@+id/tvRecordWordsEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_12"
            android:gravity="center"
            android:text="@string/practice_record_detail_empty"
            android:textColor="@color/practice_record_empty"
            android:textSize="@dimen/core_ui_text_12"
            android:visibility="gone" />
    </LinearLayout>
</layout>

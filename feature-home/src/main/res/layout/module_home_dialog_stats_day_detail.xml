<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/feature_home_stats_day_detail_sheet_bg"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:id="@+id/tvDetailDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:textColor="#06152A"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/ivClose"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="2023年10月24日" />

                <ImageView
                    android:id="@+id/ivClose"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/home_day_detail_close"
                    android:padding="10dp"
                    android:src="@drawable/feature_home_stats_ic_close"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#303544" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E8EBF1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:id="@+id/tvDayEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/feature_home_stats_day_detail_empty_bg"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="@string/home_day_detail_empty"
                    android:textColor="#7D8798"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cardPlanStatus"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/feature_home_stats_day_detail_status_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="10dp">

                    <ImageView
                        android:id="@+id/ivPlanStatus"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/feature_home_stats_ic_check_circle"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#047C63" />

                    <TextView
                        android:id="@+id/tvPlanStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:textColor="#076451"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@id/tvCheckInStatus"
                        app:layout_constraintEnd_toStartOf="@id/checkInActionContainer"
                        app:layout_constraintStart_toEndOf="@id/ivPlanStatus"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_chainStyle="packed"
                        tools:text="全部计划已完成" />

                    <TextView
                        android:id="@+id/tvCheckInStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:textColor="#16715F"
                        android:textSize="10sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/checkInActionContainer"
                        app:layout_constraintStart_toEndOf="@id/ivPlanStatus"
                        app:layout_constraintTop_toBottomOf="@id/tvPlanStatus"
                        tools:text="自动打卡成功" />

                    <FrameLayout
                        android:id="@+id/checkInActionContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:visibility="gone"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:id="@+id/btnMakeUpCheckIn"
                            android:layout_width="84dp"
                            android:layout_height="28dp"
                            android:background="@drawable/feature_home_stats_day_detail_makeup_bg"
                            android:ellipsize="end"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:text="@string/home_day_detail_makeup_button"
                            android:textColor="#076451"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </FrameLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="104dp"
                        android:layout_weight="1"
                        android:background="@drawable/feature_home_stats_day_detail_metric_bg"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/feature_home_stats_ic_words"
                            app:tint="#126BDB" />

                        <TextView
                            android:id="@+id/tvNewCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:includeFontPadding="false"
                            android:textColor="#06152A"
                            android:textSize="25sp"
                            android:textStyle="bold"
                            tools:text="20" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:includeFontPadding="false"
                            android:text="@string/home_day_detail_metric_new_words"
                            android:textColor="#333B4D"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="104dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/feature_home_stats_day_detail_metric_bg"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/feature_home_stats_ic_medal"
                            app:tint="#93621A" />

                        <TextView
                            android:id="@+id/tvReviewCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:includeFontPadding="false"
                            android:textColor="#06152A"
                            android:textSize="25sp"
                            android:textStyle="bold"
                            tools:text="50" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:includeFontPadding="false"
                            android:text="@string/home_day_detail_metric_review_words"
                            android:textColor="#333B4D"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="104dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/feature_home_stats_day_detail_metric_bg"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/feature_home_stats_ic_clock"
                            app:tint="#148E75" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvDuration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:includeFontPadding="false"
                                android:textColor="#06152A"
                                android:textSize="25sp"
                                android:textStyle="bold"
                                tools:text="45" />

                            <TextView
                                android:id="@+id/tvDurationUnit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="3dp"
                                android:textColor="#333B4D"
                                android:textSize="13sp"
                                tools:text="m" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:includeFontPadding="false"
                            android:text="@string/home_day_detail_metric_duration"
                            android:textColor="#333B4D"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/newWordsSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@drawable/feature_home_stats_day_detail_marker_new" />

                        <TextView
                            android:id="@+id/tvNewSectionTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:includeFontPadding="false"
                            android:textColor="#06152A"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            tools:text="新学词条 (20)" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvNewEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/feature_home_stats_day_detail_word_group_bg"
                        android:gravity="center"
                        android:padding="18dp"
                        android:text="@string/home_day_detail_new_empty"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/newWordsListCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/feature_home_stats_day_detail_word_group_bg"
                        android:orientation="vertical">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvNewWords"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never" />

                        <TextView
                            android:id="@+id/tvNewWordsMore"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:textColor="#0B5FE8"
                            android:textSize="15sp"
                            tools:text="查看全部 20 个新词" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/reviewWordsSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@drawable/feature_home_stats_day_detail_marker_review" />

                        <TextView
                            android:id="@+id/tvReviewSectionTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:includeFontPadding="false"
                            android:textColor="#06152A"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            tools:text="复习词条 (50)" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvReviewEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/feature_home_stats_day_detail_word_group_bg"
                        android:gravity="center"
                        android:padding="18dp"
                        android:text="@string/home_day_detail_review_empty"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/reviewWordsListCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/feature_home_stats_day_detail_word_group_bg"
                        android:orientation="vertical">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvReviewWords"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never" />

                        <TextView
                            android:id="@+id/tvReviewWordsMore"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:textColor="#0B5FE8"
                            android:textSize="15sp"
                            tools:text="查看全部 50 个复习词" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</layout>

<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/feature_home_stats_day_detail_sheet_bg"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="@dimen/core_ui_dp_16">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/core_ui_dp_74"
                android:paddingStart="@dimen/core_ui_dp_16"
                android:paddingEnd="@dimen/core_ui_dp_16">

                <TextView
                    android:id="@+id/tvDetailDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:textColor="#06152A"
                    android:textSize="@dimen/core_ui_text_22"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/ivClose"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="2023年10月24日" />

                <ImageView
                    android:id="@+id/ivClose"
                    android:layout_width="@dimen/core_ui_dp_40"
                    android:layout_height="@dimen/core_ui_dp_40"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/home_day_detail_close"
                    android:padding="@dimen/core_ui_dp_10"
                    android:src="@drawable/feature_home_stats_ic_close"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#303544" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/core_ui_dp_1"
                android:background="#E8EBF1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/core_ui_dp_16"
                android:paddingTop="@dimen/core_ui_dp_16"
                android:paddingEnd="@dimen/core_ui_dp_16">

                <TextView
                    android:id="@+id/tvDayEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/core_ui_dp_14"
                    android:background="@drawable/feature_home_stats_day_detail_empty_bg"
                    android:gravity="center"
                    android:padding="@dimen/core_ui_dp_12"
                    android:text="@string/home_day_detail_empty"
                    android:textColor="#7D8798"
                    android:textSize="@dimen/core_ui_text_13"
                    android:visibility="gone" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cardPlanStatus"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/core_ui_dp_54"
                    android:background="@drawable/feature_home_stats_day_detail_status_bg"
                    android:paddingStart="@dimen/core_ui_dp_12"
                    android:paddingEnd="@dimen/core_ui_dp_10">

                    <ImageView
                        android:id="@+id/ivPlanStatus"
                        android:layout_width="@dimen/core_ui_dp_16"
                        android:layout_height="@dimen/core_ui_dp_16"
                        android:src="@drawable/feature_home_stats_ic_check_circle"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#047C63" />

                    <TextView
                        android:id="@+id/tvPlanStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/core_ui_dp_8"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:textColor="#076451"
                        android:textSize="@dimen/core_ui_text_12"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@id/tvCheckInStatus"
                        app:layout_constraintEnd_toStartOf="@id/checkInActionContainer"
                        app:layout_constraintStart_toEndOf="@id/ivPlanStatus"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_chainStyle="packed"
                        tools:text="全部计划已完成" />

                    <TextView
                        android:id="@+id/tvCheckInStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/core_ui_dp_8"
                        android:layout_marginTop="@dimen/core_ui_dp_4"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:textColor="#16715F"
                        android:textSize="@dimen/core_ui_sp_10"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/checkInActionContainer"
                        app:layout_constraintStart_toEndOf="@id/ivPlanStatus"
                        app:layout_constraintTop_toBottomOf="@id/tvPlanStatus"
                        tools:text="自动打卡成功" />

                    <FrameLayout
                        android:id="@+id/checkInActionContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/core_ui_dp_6"
                        android:visibility="gone"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:id="@+id/btnMakeUpCheckIn"
                            android:layout_width="@dimen/core_ui_dp_84"
                            android:layout_height="@dimen/core_ui_dp_28"
                            android:background="@drawable/feature_home_stats_day_detail_makeup_bg"
                            android:ellipsize="end"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:paddingStart="@dimen/core_ui_dp_8"
                            android:paddingEnd="@dimen/core_ui_dp_8"
                            android:text="@string/home_day_detail_makeup_button"
                            android:textColor="#076451"
                            android:textSize="@dimen/core_ui_sp_10"
                            android:textStyle="bold" />
                    </FrameLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_20"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="@dimen/core_ui_dp_104"
                        android:layout_weight="1"
                        android:background="@drawable/feature_home_stats_day_detail_metric_bg"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="@dimen/core_ui_dp_26"
                            android:layout_height="@dimen/core_ui_dp_26"
                            android:src="@drawable/feature_home_stats_ic_words"
                            app:tint="#126BDB" />

                        <TextView
                            android:id="@+id/tvNewCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/core_ui_dp_12"
                            android:includeFontPadding="false"
                            android:textColor="#06152A"
                            android:textSize="@dimen/core_ui_text_25"
                            android:textStyle="bold"
                            tools:text="20" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/core_ui_dp_8"
                            android:includeFontPadding="false"
                            android:text="@string/home_day_detail_metric_new_words"
                            android:textColor="#333B4D"
                            android:textSize="@dimen/core_ui_text_13" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="@dimen/core_ui_dp_104"
                        android:layout_marginStart="@dimen/core_ui_dp_10"
                        android:layout_weight="1"
                        android:background="@drawable/feature_home_stats_day_detail_metric_bg"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="@dimen/core_ui_dp_26"
                            android:layout_height="@dimen/core_ui_dp_26"
                            android:src="@drawable/feature_home_stats_ic_medal"
                            app:tint="#93621A" />

                        <TextView
                            android:id="@+id/tvReviewCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/core_ui_dp_12"
                            android:includeFontPadding="false"
                            android:textColor="#06152A"
                            android:textSize="@dimen/core_ui_text_25"
                            android:textStyle="bold"
                            tools:text="50" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/core_ui_dp_8"
                            android:includeFontPadding="false"
                            android:text="@string/home_day_detail_metric_review_words"
                            android:textColor="#333B4D"
                            android:textSize="@dimen/core_ui_text_13" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="@dimen/core_ui_dp_104"
                        android:layout_marginStart="@dimen/core_ui_dp_10"
                        android:layout_weight="1"
                        android:background="@drawable/feature_home_stats_day_detail_metric_bg"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="@dimen/core_ui_dp_26"
                            android:layout_height="@dimen/core_ui_dp_26"
                            android:src="@drawable/feature_home_stats_ic_clock"
                            app:tint="#148E75" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/core_ui_dp_12"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvDuration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:includeFontPadding="false"
                                android:textColor="#06152A"
                                android:textSize="@dimen/core_ui_text_25"
                                android:textStyle="bold"
                                tools:text="45" />

                            <TextView
                                android:id="@+id/tvDurationUnit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/core_ui_dp_3"
                                android:textColor="#333B4D"
                                android:textSize="@dimen/core_ui_text_13"
                                tools:text="m" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/core_ui_dp_8"
                            android:includeFontPadding="false"
                            android:text="@string/home_day_detail_metric_duration"
                            android:textColor="#333B4D"
                            android:textSize="@dimen/core_ui_text_13" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/newWordsSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_22"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="@dimen/core_ui_dp_4"
                            android:layout_height="@dimen/core_ui_dp_20"
                            android:background="@drawable/feature_home_stats_day_detail_marker_new" />

                        <TextView
                            android:id="@+id/tvNewSectionTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/core_ui_dp_10"
                            android:includeFontPadding="false"
                            android:textColor="#06152A"
                            android:textSize="@dimen/core_ui_text_17"
                            android:textStyle="bold"
                            tools:text="新学词条 (20)" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvNewEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/core_ui_dp_12"
                        android:background="@drawable/feature_home_stats_day_detail_word_group_bg"
                        android:gravity="center"
                        android:padding="@dimen/core_ui_dp_18"
                        android:text="@string/home_day_detail_new_empty"
                        android:textColor="#94A3B8"
                        android:textSize="@dimen/core_ui_text_13"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/newWordsListCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/core_ui_dp_12"
                        android:background="@drawable/feature_home_stats_day_detail_word_group_bg"
                        android:orientation="vertical">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvNewWords"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never" />

                        <TextView
                            android:id="@+id/tvNewWordsMore"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/core_ui_dp_48"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:textColor="#0B5FE8"
                            android:textSize="@dimen/core_ui_text_15"
                            tools:text="查看全部 20 个新词" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/reviewWordsSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_22"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="@dimen/core_ui_dp_4"
                            android:layout_height="@dimen/core_ui_dp_20"
                            android:background="@drawable/feature_home_stats_day_detail_marker_review" />

                        <TextView
                            android:id="@+id/tvReviewSectionTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/core_ui_dp_10"
                            android:includeFontPadding="false"
                            android:textColor="#06152A"
                            android:textSize="@dimen/core_ui_text_17"
                            android:textStyle="bold"
                            tools:text="复习词条 (50)" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvReviewEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/core_ui_dp_12"
                        android:background="@drawable/feature_home_stats_day_detail_word_group_bg"
                        android:gravity="center"
                        android:padding="@dimen/core_ui_dp_18"
                        android:text="@string/home_day_detail_review_empty"
                        android:textColor="#94A3B8"
                        android:textSize="@dimen/core_ui_text_13"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/reviewWordsListCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/core_ui_dp_12"
                        android:background="@drawable/feature_home_stats_day_detail_word_group_bg"
                        android:orientation="vertical">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvReviewWords"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never" />

                        <TextView
                            android:id="@+id/tvReviewWordsMore"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/core_ui_dp_48"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:textColor="#0B5FE8"
                            android:textSize="@dimen/core_ui_text_15"
                            tools:text="查看全部 50 个复习词" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</layout>
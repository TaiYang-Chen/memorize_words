<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.chen.memorizewords.feature.home.ui.profile.ProfileViewModel" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="@dimen/page_margin"
        android:paddingStart="@dimen/page_margin"
        android:paddingEnd="@dimen/page_margin"
        android:background="@drawable/feature_home_bg_profile_page"
        android:orientation="vertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/title_margin">

            <ImageView
                android:id="@+id/feature_home_profile_qr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/feature_home_profile_personal_qr"
                android:onClick="@{()->viewModel.toPersonalQr()}"
                android:src="@drawable/module_home_qr_code_scanner_172337"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#172337" />

            <TextView
                android:id="@+id/feature_home_profile_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/profile"
                android:textColor="#000"
                android:textSize="@dimen/title_text_size"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/feature_home_profile_settings_top"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/feature_home_profile_settings"
                android:onClick="@{()->viewModel.toSettings()}"
                android:src="@drawable/feature_home_settings_172337"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fillViewport="false"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/feature_home_profile_hero_card"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/core_ui_dp_124"
                    android:layout_marginTop="@dimen/core_ui_dp_18"
                    android:background="@drawable/feature_home_bg_profile_hero_card"
                    android:clipChildren="false"
                    android:padding="@dimen/core_ui_dp_8"
                    android:clipToPadding="false">

                    <ImageView
                        android:id="@+id/feature_home_iv_profile_flame"
                        android:layout_width="@dimen/core_ui_dp_10"
                        android:layout_height="@dimen/core_ui_dp_10"
                        android:contentDescription="@null"
                        android:src="@drawable/feature_home_ic_profile_flame"
                        app:layout_constraintBottom_toBottomOf="@id/feature_home_tv_profile_streak"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@id/feature_home_tv_profile_streak" />

                    <TextView
                        android:id="@+id/feature_home_tv_profile_streak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/core_ui_dp_4"
                        android:text="@string/feature_home_profile_static_streak_prefix"
                        android:textColor="#142238"
                        android:textSize="@dimen/core_ui_sp_8"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/feature_home_iv_profile_flame"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/feature_home_tv_profile_streak_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/core_ui_dp_5"
                        android:text="@{viewModel.continuousCheckInText}"
                        android:textColor="#10B981"
                        android:textSize="@dimen/core_ui_sp_8"
                        android:textStyle="bold"
                        app:layout_constraintBaseline_toBaselineOf="@id/feature_home_tv_profile_streak"
                        app:layout_constraintStart_toEndOf="@id/feature_home_tv_profile_streak" />

                    <TextView
                        android:id="@+id/feature_home_tv_profile_streak_unit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/core_ui_dp_4"
                        android:text="天"
                        android:textColor="#142238"
                        android:textSize="@dimen/core_ui_sp_8"
                        android:textStyle="bold"
                        app:layout_constraintBaseline_toBaselineOf="@id/feature_home_tv_profile_streak"
                        app:layout_constraintStart_toEndOf="@id/feature_home_tv_profile_streak_count" />

                    <ImageView
                        android:id="@+id/feature_home_iv_profile_mascot"
                        android:layout_width="@dimen/core_ui_dp_80"
                        android:layout_height="@dimen/core_ui_dp_70"
                        android:contentDescription="@string/feature_home_profile_mascot"
                        android:scaleType="fitCenter"
                        android:src="@drawable/feature_home_profile_mascot"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <ImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="@dimen/core_ui_dp_68"
                        android:layout_height="@dimen/core_ui_dp_68"
                        android:background="@drawable/feature_home_bg_profile_avatar_frame"
                        android:clipToOutline="true"
                        android:padding="@dimen/core_ui_dp_7"
                        android:scaleType="centerCrop"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/feature_home_tv_profile_streak"
                        tools:src="@drawable/feature_home_ic_avatar_placeholder" />

                    <TextView
                        android:id="@+id/tv_user_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/core_ui_dp_8"
                        android:layout_marginTop="@dimen/core_ui_dp_8"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textSize="@dimen/core_ui_text_18"
                        android:text="@{viewModel.profileNicknameText}"
                        android:textColor="#10213F"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@id/tv_user_id"
                        app:layout_constraintStart_toEndOf="@id/ivAvatar"
                        app:layout_constraintTop_toTopOf="@id/ivAvatar"
                        app:layout_constraintVertical_chainStyle="packed"
                        tools:text="小生xBFHD" />

                    <TextView
                        android:id="@+id/tv_user_id"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/core_ui_dp_7"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@{viewModel.profileAccountIdDisplayText}"
                        android:textColor="#2D3D56"
                        android:textSize="@dimen/core_ui_text_12"
                        app:layout_constraintEnd_toStartOf="@id/feature_home_iv_profile_mascot"
                        app:layout_constraintStart_toStartOf="@id/tv_user_name"
                        app:layout_constraintTop_toBottomOf="@id/tv_user_name" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/core_ui_dp_96"
                    android:layout_marginTop="@dimen/core_ui_dp_10"
                    android:background="@drawable/feature_home_bg_profile_surface_card"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/core_ui_dp_10"
                    android:paddingEnd="@dimen/core_ui_dp_10">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/core_ui_dp_2"
                        android:paddingEnd="@dimen/core_ui_dp_6">

                        <ImageView
                            android:layout_width="@dimen/core_ui_dp_32"
                            android:layout_height="@dimen/core_ui_dp_32"
                            android:background="@drawable/feature_home_bg_profile_icon_green"
                            android:contentDescription="@null"
                            android:padding="@dimen/core_ui_dp_6"
                            android:src="@drawable/feature_home_ic_profile_calendar_check" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/core_ui_dp_9"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="bottom"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@{viewModel.continuousCheckInText}"
                                    android:textColor="#0B1D3A"
                                    android:textSize="@dimen/core_ui_text_16"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/core_ui_dp_4"
                                    android:text="天"
                                    android:textColor="#253851"
                                    android:textSize="@dimen/core_ui_sp_10" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/core_ui_dp_2"
                                android:text="@string/feature_home_profile_card_days"
                                android:textColor="#5C6C82"
                                android:textSize="@dimen/core_ui_sp_10" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_marginTop="@dimen/core_ui_dp_4"
                                android:layout_height="wrap_content"
                                android:text="@{viewModel.longestCheckInText}"
                                android:textColor="#10B981"
                                android:textSize="@dimen/core_ui_sp_10" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="@dimen/core_ui_dp_1"
                        android:layout_height="@dimen/core_ui_dp_64"
                        android:background="@drawable/feature_home_bg_profile_divider" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/core_ui_dp_10"
                        android:paddingEnd="@dimen/core_ui_dp_4">

                        <ImageView
                            android:layout_width="@dimen/core_ui_dp_32"
                            android:layout_height="@dimen/core_ui_dp_32"
                            android:background="@drawable/feature_home_bg_profile_icon_blue"
                            android:contentDescription="@null"
                            android:padding="@dimen/core_ui_dp_6"
                            android:src="@drawable/feature_home_ic_profile_book_open" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/core_ui_dp_9"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="bottom"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@{viewModel.studyTotalWordCountText}"
                                    android:textColor="#0B1D3A"
                                    android:textSize="@dimen/core_ui_text_16"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/core_ui_dp_4"
                                    android:text="词"
                                    android:textColor="#253851"
                                    android:textSize="@dimen/core_ui_sp_10" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/core_ui_dp_2"
                                android:text="@string/feature_home_profile_card_words"
                                android:textColor="#5C6C82"
                                android:textSize="@dimen/core_ui_sp_10" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/core_ui_dp_4"
                                android:text="@{viewModel.wordsVsYesterdayText}"
                                android:textColor="#10B981"
                                android:textSize="@dimen/core_ui_sp_10" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="@dimen/core_ui_dp_1"
                        android:layout_height="@dimen/core_ui_dp_64"
                        android:background="@drawable/feature_home_bg_profile_divider" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/core_ui_dp_10">

                        <ImageView
                            android:layout_width="@dimen/core_ui_dp_32"
                            android:layout_height="@dimen/core_ui_dp_32"
                            android:background="@drawable/feature_home_bg_profile_icon_purple"
                            android:contentDescription="@null"
                            android:padding="@dimen/core_ui_dp_6"
                            android:src="@drawable/feature_home_ic_profile_clock" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/core_ui_dp_9"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="bottom"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@{viewModel.totalStudyDurationHoursText}"
                                    android:textColor="#0B1D3A"
                                    android:textSize="@dimen/core_ui_text_16"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/core_ui_dp_4"
                                    android:text="小时"
                                    android:textColor="#253851"
                                    android:textSize="@dimen/core_ui_sp_10" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/core_ui_dp_2"
                                android:text="@string/feature_home_profile_card_hours"
                                android:textColor="#5C6C82"
                                android:textSize="@dimen/core_ui_sp_10" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/core_ui_dp_4"
                                android:text="@{viewModel.durationVsYesterdayText}"
                                android:textColor="#10B981"
                                android:textSize="@dimen/core_ui_sp_10" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/feature_home_member_card"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/core_ui_dp_92"
                    android:layout_marginTop="@dimen/core_ui_dp_10"
                    android:background="@drawable/feature_home_bg_profile_pro_card"
                    android:clickable="true"
                    android:onClick="@{()->viewModel.toMembership()}"
                    android:paddingStart="@dimen/core_ui_dp_15"
                    android:paddingTop="@dimen/core_ui_dp_12"
                    android:paddingEnd="@dimen/core_ui_dp_15"
                    android:paddingBottom="@dimen/core_ui_dp_10"
                    android:stateListAnimator="@animator/btn_scale_animator">

                    <TextView
                        android:id="@+id/feature_home_profile_pro_crown"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="♛"
                        android:textColor="#FFD98A"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/feature_home_profile_pro_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/core_ui_dp_8"
                        android:text="@{viewModel.membershipTitleText}"
                        android:textColor="#FFE7B2"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/feature_home_profile_pro_crown"
                        app:layout_constraintStart_toEndOf="@id/feature_home_profile_pro_crown"
                        app:layout_constraintTop_toTopOf="@id/feature_home_profile_pro_crown" />

                    <TextView
                        android:id="@+id/feature_home_profile_pro_subtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/core_ui_dp_3"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@{viewModel.membershipSubtitleText}"
                        android:textColor="#D8E2EA"
                        android:textSize="@dimen/core_ui_text_11"
                        app:layout_constraintEnd_toStartOf="@id/feature_home_btn_open_member"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/feature_home_profile_pro_title" />

                    <TextView
                        android:id="@+id/feature_home_btn_open_member"
                        android:layout_width="wrap_content"
                        android:paddingTop="@dimen/core_ui_dp_4"
                        android:paddingBottom="@dimen/core_ui_dp_4"
                        android:paddingStart="@dimen/core_ui_dp_8"
                        android:paddingEnd="@dimen/core_ui_dp_8"
                        android:layout_height="wrap_content"
                        android:background="@drawable/feature_home_bg_profile_pro_button"
                        android:gravity="center"
                        android:onClick="@{()->viewModel.toMembership()}"
                        android:stateListAnimator="@animator/btn_scale_animator"
                        android:text="@{viewModel.membershipActionText}"
                        android:textColor="#4A2600"
                        android:textSize="@dimen/core_ui_text_12"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/feature_home_profile_pro_books"
                            android:textColor="#FFEFC4"
                            android:textSize="@dimen/core_ui_sp_10"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/feature_home_profile_pro_bubble"
                            android:textColor="#FFEFC4"
                            android:textSize="@dimen/core_ui_sp_10"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/feature_home_profile_pro_stats"
                            android:textColor="#FFEFC4"
                            android:textSize="@dimen/core_ui_sp_10"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/feature_home_profile_pro_ai"
                            android:textColor="#FFEFC4"
                            android:textSize="@dimen/core_ui_sp_10"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/feature_home_profile_pro_more"
                            android:textColor="#FFEFC4"
                            android:textSize="@dimen/core_ui_sp_10"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>


                <LinearLayout
                    android:orientation="vertical"
                    android:layout_marginTop="@dimen/core_ui_dp_10"
                    android:background="@drawable/feature_home_bg_profile_surface_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                            android:gravity="center"
                            android:padding="@dimen/core_ui_dp_12"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:clickable="true"
                            android:onClick="@{()->viewModel.toMyWordBooks()}"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:layout_width="@dimen/core_ui_dp_28"
                                android:layout_height="@dimen/core_ui_dp_28"
                                android:background="@drawable/feature_home_bg_profile_icon_green"
                                android:contentDescription="@null"
                                android:padding="@dimen/core_ui_dp_6"
                                android:src="@drawable/feature_home_ic_profile_menu_book" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/core_ui_dp_12"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@string/feature_home_profile_my_books"
                                android:textColor="#101C32"
                                android:textSize="@dimen/core_ui_text_14"
                                android:textStyle="bold" />

                            <ImageView
                                android:layout_width="@dimen/core_ui_dp_10"
                                android:layout_height="@dimen/core_ui_dp_10"
                                android:contentDescription="@null"
                                android:src="@drawable/module_home_ic_right" />

                        </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/core_ui_dp_1"
                        android:background="@drawable/feature_home_bg_profile_divider" />

                    <LinearLayout
                        android:gravity="center"
                        android:padding="@dimen/core_ui_dp_12"
                        android:layout_width="match_parent"
                        android:clickable="true"
                        android:onClick="@{()->viewModel.toFavorites()}"
                        android:orientation="horizontal"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:layout_width="@dimen/core_ui_dp_28"
                            android:layout_height="@dimen/core_ui_dp_28"
                            android:background="@drawable/feature_home_bg_profile_icon_pink"
                            android:contentDescription="@null"
                            android:padding="@dimen/core_ui_dp_6"
                            android:src="@drawable/feature_home_ic_profile_menu_heart" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/core_ui_dp_12"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/feature_home_profile_favorites"
                            android:textColor="#101C32"
                            android:textSize="@dimen/core_ui_text_14"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="@dimen/core_ui_dp_10"
                            android:layout_height="@dimen/core_ui_dp_10"
                            android:contentDescription="@null"
                            android:src="@drawable/module_home_ic_right" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/core_ui_dp_1"
                        android:background="@drawable/feature_home_bg_profile_divider" />

                    <LinearLayout
                        android:padding="@dimen/core_ui_dp_12"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:clickable="true"
                        android:onClick="@{()->viewModel.toLearningReport()}"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:layout_width="@dimen/core_ui_dp_28"
                            android:layout_height="@dimen/core_ui_dp_28"
                            android:background="@drawable/feature_home_bg_profile_icon_purple"
                            android:contentDescription="@null"

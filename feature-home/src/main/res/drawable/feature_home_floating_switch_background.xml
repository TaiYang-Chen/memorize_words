<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <layer-list>
            <item>
                <shape>
                    <size
                        android:width="@dimen/core_ui_dp_44"
                        android:height="@dimen/core_ui_dp_18" />
                    <corners android:radius="@dimen/core_ui_dp_9" />
                    <solid android:color="#5B4BE8" />
                </shape>
            </item>
            <item
                android:width="@dimen/core_ui_dp_16"
                android:height="@dimen/core_ui_dp_16"
                android:gravity="end|center_vertical"
                android:right="@dimen/core_ui_dp_1">
                <shape android:shape="oval">
                    <solid android:color="#FFFFFF" />
                    <stroke
                        android:width="@dimen/core_ui_dp_1"
                        android:color="#DDE4F0" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape>
                    <size
                        android:width="@dimen/core_ui_dp_44"
                        android:height="@dimen/core_ui_dp_18" />
                    <corners android:radius="@dimen/core_ui_dp_9" />
                    <solid android:color="#E8EDF5" />
                </shape>
            </item>
            <item
                android:width="@dimen/core_ui_dp_16"
                android:height="@dimen/core_ui_dp_16"
                android:gravity="start|center_vertical"
                android:left="@dimen/core_ui_dp_1">
                <shape android:shape="oval">
                    <solid android:color="#FFFFFF" />
                    <stroke
                        android:width="@dimen/core_ui_dp_1"
                        android:color="#DDE4F0" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>

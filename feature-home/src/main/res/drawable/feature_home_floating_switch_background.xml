<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <layer-list>
            <item>
                <shape>
                    <size
                        android:width="44dp"
                        android:height="18dp" />
                    <corners android:radius="9dp" />
                    <solid android:color="#5B4BE8" />
                </shape>
            </item>
            <item
                android:width="16dp"
                android:height="16dp"
                android:gravity="end|center_vertical"
                android:right="1dp">
                <shape android:shape="oval">
                    <solid android:color="#FFFFFF" />
                    <stroke
                        android:width="1dp"
                        android:color="#DDE4F0" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape>
                    <size
                        android:width="44dp"
                        android:height="18dp" />
                    <corners android:radius="9dp" />
                    <solid android:color="#E8EDF5" />
                </shape>
            </item>
            <item
                android:width="16dp"
                android:height="16dp"
                android:gravity="start|center_vertical"
                android:left="1dp">
                <shape android:shape="oval">
                    <solid android:color="#FFFFFF" />
                    <stroke
                        android:width="1dp"
                        android:color="#DDE4F0" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>

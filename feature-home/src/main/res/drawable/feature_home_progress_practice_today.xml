<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="@dimen/core_ui_dp_6" />
            <solid android:color="#E8EEF7" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <corners android:radius="@dimen/core_ui_dp_6" />
                <gradient
                    android:angle="0"
                    android:endColor="#19C970"
                    android:startColor="#2DD889" />
            </shape>
        </clip>
    </item>
</layer-list>

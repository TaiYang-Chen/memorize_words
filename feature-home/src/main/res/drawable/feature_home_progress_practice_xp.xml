<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="@dimen/core_ui_dp_5" />
            <solid android:color="#E8EEF7" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <corners android:radius="@dimen/core_ui_dp_5" />
                <gradient
                    android:angle="0"
                    android:endColor="#21A5FF"
                    android:startColor="#1688F2" />
            </shape>
        </clip>
    </item>
</layer-list>

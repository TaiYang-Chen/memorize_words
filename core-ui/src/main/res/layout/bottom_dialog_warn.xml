<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:gravity="center"
        android:layout_height="wrap_content"
        android:background="@drawable/bottom_dialog_bg"
        android:orientation="vertical">

        <!-- 拖拽条 -->
        <View
            android:layout_width="@dimen/core_ui_dp_40"
            android:layout_height="@dimen/core_ui_dp_6"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/core_ui_dp_16"
            android:background="@drawable/bg_drag_handle" />

        <ImageView
            android:layout_width="@dimen/core_ui_dp_80"
            android:layout_height="@dimen/core_ui_dp_80"
            android:layout_margin="@dimen/core_ui_dp_24"
            android:src="@drawable/ic_warn" />

        <TextView
            android:id="@+id/title"
            tools:text="确认重置进度"
            android:textSize="@dimen/core_ui_text_18"
            android:textStyle="bold"
            android:textColor="@color/core_ui_bottom_dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/message"
            tools:text="重置后，当前的单词学习进度将被完全清空，所有已掌握单词将恢复为未学状态。此操作无法撤销。"
            android:layout_width="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_20"
            android:layout_marginBottom="@dimen/core_ui_dp_40"
            android:layout_marginStart="@dimen/core_ui_dp_32"
            android:layout_marginEnd="@dimen/core_ui_dp_32"
            android:lineHeight="@dimen/core_ui_text_25"
            android:textColor="@color/core_ui_bottom_dialog_body"
            android:textStyle="bold"
            android:textSize="@dimen/core_ui_text_14"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/confirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:backgroundTint="@null"
            android:background="@drawable/bottom_dialog_primary_button_selector"
            android:elevation="@dimen/core_ui_dp_4"
            android:text="确定"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="@dimen/core_ui_dp_16"
            android:layout_marginStart="@dimen/core_ui_dp_32"
            android:layout_marginEnd="@dimen/core_ui_dp_32"
            android:textSize="@dimen/core_ui_text_16"
            android:textStyle="bold"
            android:padding="@dimen/core_ui_dp_8"
            android:stateListAnimator="@null" />

        <TextView
            android:id="@+id/cancel"
            android:text="我在想想"
            android:layout_width="wrap_content"
            android:layout_marginBottom="@dimen/core_ui_dp_40"
            android:textSize="@dimen/core_ui_text_14"
            android:textColor="@color/core_ui_bottom_dialog_body"
            android:textStyle="bold"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</layout>
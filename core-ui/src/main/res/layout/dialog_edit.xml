<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/core_ui_dp_24"
            app:cardCornerRadius="@dimen/core_ui_dp_16">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_32"
                    android:textColor="#000"
                    android:textSize="@dimen/core_ui_text_18"
                    android:textStyle="bold"
                    tools:text="确认重置进度" />

                <EditText
                    android:id="@+id/content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/core_ui_dp_20"
                    android:layout_marginTop="@dimen/core_ui_dp_20"
                    android:layout_marginEnd="@dimen/core_ui_dp_20"
                    android:layout_marginBottom="@dimen/core_ui_dp_32"
                    android:maxLines="1"
                    android:lineHeight="@dimen/core_ui_text_25"
                    android:textColor="#949494"
                    android:textSize="@dimen/core_ui_text_14"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/core_ui_dp_1"
                    android:background="#BABABA" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/cancel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/button_write_selector"
                        android:backgroundTint="@null"
                        android:elevation="@dimen/core_ui_dp_4"
                        android:padding="@dimen/core_ui_dp_14"
                        android:stateListAnimator="@null"
                        android:text="取消"
                        android:textColor="#717171"
                        android:textSize="@dimen/core_ui_text_16"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:backgroundTint="@null" />


                    <View
                        android:layout_width="@dimen/core_ui_dp_1"
                        android:layout_height="match_parent"
                        android:background="#BABABA" />


                    <Button
                        android:id="@+id/confirm"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/button_write_selector"
                        android:backgroundTint="@null"
                        android:elevation="@dimen/core_ui_dp_4"
                        android:padding="@dimen/core_ui_dp_14"
                        android:stateListAnimator="@null"
                        android:text="确定"
                        android:textColor="#6B7280"
                        android:textSize="@dimen/core_ui_text_16"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:backgroundTint="@null" />

                </LinearLayout>


            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</layout>
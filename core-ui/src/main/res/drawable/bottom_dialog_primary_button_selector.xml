<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="@color/core_ui_bottom_dialog_button_pressed_end"
                android:startColor="@color/core_ui_bottom_dialog_button_pressed_start" />
            <corners android:radius="24dp" />
            <padding
                android:bottom="1dp"
                android:left="1dp"
                android:right="1dp"
                android:top="1dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="@color/core_ui_bottom_dialog_button_end"
                android:startColor="@color/core_ui_bottom_dialog_button_start" />
            <corners android:radius="24dp" />
            <padding
                android:bottom="2dp"
                android:left="2dp"
                android:right="2dp"
                android:top="2dp" />
        </shape>
    </item>
</selector>

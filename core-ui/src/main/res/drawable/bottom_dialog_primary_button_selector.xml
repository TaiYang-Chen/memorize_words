<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="@color/core_ui_bottom_dialog_button_pressed_end"
                android:startColor="@color/core_ui_bottom_dialog_button_pressed_start" />
            <corners android:radius="@dimen/core_ui_dp_24" />
            <padding
                android:bottom="@dimen/core_ui_dp_1"
                android:left="@dimen/core_ui_dp_1"
                android:right="@dimen/core_ui_dp_1"
                android:top="@dimen/core_ui_dp_1" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="@color/core_ui_bottom_dialog_button_end"
                android:startColor="@color/core_ui_bottom_dialog_button_start" />
            <corners android:radius="@dimen/core_ui_dp_24" />
            <padding
                android:bottom="@dimen/core_ui_dp_2"
                android:left="@dimen/core_ui_dp_2"
                android:right="@dimen/core_ui_dp_2"
                android:top="@dimen/core_ui_dp_2" />
        </shape>
    </item>
</selector>

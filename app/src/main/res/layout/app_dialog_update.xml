<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/core_ui_dp_24"
    android:paddingEnd="@dimen/core_ui_dp_24">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="@dimen/core_ui_dp_12"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/core_ui_dp_22"
            android:paddingTop="@dimen/core_ui_dp_22"
            android:paddingEnd="@dimen/core_ui_dp_22"
            android:paddingBottom="@dimen/core_ui_dp_18">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#21457;&#29616;&#26032;&#29256;&#26412;"
                android:textColor="#0f172a"
                android:textSize="@dimen/core_ui_text_20"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvUpdateVersionSpan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/core_ui_dp_8"
                android:textColor="#475569"
                android:textSize="@dimen/core_ui_text_15"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/llUpdateMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/core_ui_dp_10"
                android:orientation="vertical" />

            <LinearLayout
                android:id="@+id/llUpdateNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/core_ui_dp_12"
                android:orientation="vertical" />

            <ProgressBar
                android:id="@+id/pbUpdateDownload"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="@dimen/core_ui_dp_8"
                android:layout_marginTop="@dimen/core_ui_dp_16"
                android:max="100"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvUpdateProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/core_ui_dp_8"
                android:textColor="#475569"
                android:textSize="@dimen/core_ui_text_13"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/core_ui_dp_20"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvUpdateLater"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/core_ui_dp_46"
                    android:layout_weight="1"
                    android:background="@drawable/app_update_secondary_button_bg"
                    android:gravity="center"
                    android:text="&#31245;&#21518;&#25552;&#37266;"
                    android:textColor="#334155"
                    android:textSize="@dimen/core_ui_text_15"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUpdateNow"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/core_ui_dp_46"
                    android:layout_marginStart="@dimen/core_ui_dp_12"
                    android:layout_weight="1"
                    android:background="@drawable/app_update_primary_button_bg"
                    android:gravity="center"
                    android:text="&#31435;&#21363;&#26356;&#26032;"
                    android:textColor="#FFFFFF"
                    android:textSize="@dimen/core_ui_text_15"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>

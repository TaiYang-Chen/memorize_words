<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_splash_background"
    android:paddingHorizontal="@dimen/app_splash_horizontal_padding">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/logo_top_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="@dimen/app_splash_logo_top" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/brand_title_top_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="@dimen/app_splash_brand_title_top" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/brand_subtitle_top_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="@dimen/app_splash_brand_subtitle_top" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/divider_top_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="@dimen/app_splash_divider_top" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/divider_bottom_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="@dimen/app_splash_divider_bottom" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/quote_title_top_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="@dimen/app_splash_quote_title_top" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/quote_subtitle_top_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="@dimen/app_splash_quote_subtitle_top" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/logo_card"
        android:layout_width="@dimen/app_splash_logo_card_size"
        android:layout_height="@dimen/app_splash_logo_card_size"
        android:background="@drawable/app_splash_logo_card"
        android:elevation="@dimen/app_splash_logo_card_elevation"
        android:outlineProvider="background"
        android:padding="@dimen/app_splash_logo_card_padding"
        android:scaleType="centerInside"
        android:src="@drawable/module_floating_review_ic_assignment"
        android:tint="@color/app_splash_logo_icon_tint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/logo_top_guideline" />

    <TextView
        android:id="@+id/brand_title"
        style="@style/AppSplashBrandTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_splash_brand_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/brand_title_top_guideline" />

    <TextView
        android:id="@+id/brand_subtitle"
        style="@style/AppSplashBrandSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_splash_brand_subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/brand_subtitle_top_guideline" />

    <View
        android:id="@+id/center_divider"
        android:layout_width="@dimen/app_splash_divider_width"
        android:layout_height="0dp"
        android:background="@drawable/app_splash_divider"
        app:layout_constraintBottom_toTopOf="@id/divider_bottom_guideline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/divider_top_guideline" />

    <TextView
        android:id="@+id/quote_title"
        style="@style/AppSplashQuoteTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/app_splash_quote_zh"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/quote_title_top_guideline" />

    <TextView
        android:id="@+id/quote_subtitle"
        style="@style/AppSplashQuoteSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/app_splash_quote_en"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/quote_subtitle_top_guideline" />

</androidx.constraintlayout.widget.ConstraintLayout>

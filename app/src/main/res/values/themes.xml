<resources>
    <!-- Base app theme -->
    <style name="Base.Theme.Memorize_words" parent="Theme.Material3.Light.NoActionBar">
    </style>

    <style name="Theme.Memorize_words" parent="Base.Theme.Memorize_words">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:windowBackground">@color/app_splash_background</item>
    </style>

    <style name="Theme.Memorize_words.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/app_splash_brandmark</item>
        <item name="windowSplashScreenBackground">@color/app_splash_background</item>
        <item name="postSplashScreenTheme">@style/Theme.Memorize_words</item>
    </style>
</resources>

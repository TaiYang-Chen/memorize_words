<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppSplashBrandTitle">
        <item name="android:fontFamily">serif</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/app_splash_brand_title</item>
        <item name="android:textSize">@dimen/app_splash_brand_title_text_size</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="AppSplashBrandSubtitle">
        <item name="android:fontFamily">serif</item>
        <item name="android:textColor">@color/app_splash_brand_subtitle</item>
        <item name="android:textSize">@dimen/app_splash_brand_subtitle_text_size</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:letterSpacing">0.42</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="AppSplashQuoteTitle">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/app_splash_quote_title</item>
        <item name="android:textSize">@dimen/app_splash_quote_title_text_size</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="AppSplashQuoteSubtitle">
        <item name="android:fontFamily">serif</item>
        <item name="android:textColor">@color/app_splash_quote_subtitle</item>
        <item name="android:textSize">@dimen/app_splash_quote_subtitle_text_size</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:letterSpacing">0.28</item>
        <item name="android:textAllCaps">true</item>
    </style>
</resources>

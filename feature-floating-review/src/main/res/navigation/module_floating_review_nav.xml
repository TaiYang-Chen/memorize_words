<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/module_floating_review_nav"
    app:startDestination="@id/floatingReviewSettingsFragment">

    <fragment
        android:id="@+id/floatingReviewSettingsFragment"
        android:name="com.chen.memorizewords.feature.floatingreview.ui.settings.FloatingReviewSettingsFragment"
        android:label="@string/module_floating_review_settings_title">
        <action
            android:id="@+id/action_floatingReviewSettings_to_characterPacks"
            app:destination="@id/characterPackFragment" />
    </fragment>

    <fragment
        android:id="@+id/characterPackFragment"
        android:name="com.chen.memorizewords.feature.floatingreview.ui.character.CharacterPackFragment"
        android:label="@string/module_floating_review_character_title">
        <argument
            android:name="floating_character_mode"
            app:argType="string"
            android:defaultValue="MANAGE" />
        <argument
            android:name="floating_activation_request_id"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>
</navigation>

<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/module_floating_review_back"
                android:padding="8dp"
                android:src="@drawable/module_floating_review_ic_arrow_back"
                app:tint="#0F172A" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="@string/module_floating_review_settings_title"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/module_floating_review_settings_subtitle"
            android:textColor="#64748B"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/module_floating_review_auto_start"
                android:textColor="#334155"
                android:textSize="13sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchFloatingAutoStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/module_floating_review_card_opacity_title"
                    android:textColor="#334155"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvCardOpacityValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textColor="#0F172A"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekCardOpacity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:max="100"
                android:progress="100" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/module_floating_review_source_title"
            android:textColor="#334155"
            android:textSize="13sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgSource"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbSourceCurrent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/module_floating_review_source_current"
                android:textColor="#0F172A"
                android:textSize="13sp" />

            <RadioButton
                android:id="@+id/rbSourceSelf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/module_floating_review_source_self"
                android:textColor="#0F172A"
                android:textSize="13sp" />
        </RadioGroup>

        <LinearLayout
            android:id="@+id/layoutPickWords"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickWords"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/module_floating_review_pick_words"
                android:textColor="#0F172A"
                android:textSize="12sp"
                app:backgroundTint="#F1F5F9"
                app:cornerRadius="10dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp" />

            <TextView
                android:id="@+id/tvSelectedCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/module_floating_review_selected_count"
                android:textColor="#64748B"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/module_floating_review_order_title"
            android:textColor="#334155"
            android:textSize="13sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgOrder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbOrderRandom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/module_floating_review_order_random"
                android:textColor="#0F172A"
                android:textSize="13sp" />

            <RadioButton
                android:id="@+id/rbOrderMemory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/module_floating_review_order_memory"
                android:textColor="#0F172A"
                android:textSize="13sp" />

            <RadioButton
                android:id="@+id/rbOrderAlphaAsc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/module_floating_review_order_alpha_asc"
                android:textColor="#0F172A"
                android:textSize="13sp" />

            <RadioButton
                android:id="@+id/rbOrderAlphaDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/module_floating_review_order_alpha_desc"
                android:textColor="#0F172A"
                android:textSize="13sp" />

            <RadioButton
                android:id="@+id/rbOrderLengthAsc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/module_floating_review_order_length_asc"
                android:textColor="#0F172A"
                android:textSize="13sp" />

            <RadioButton
                android:id="@+id/rbOrderLengthDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/module_floating_review_order_length_desc"
                android:textColor="#0F172A"
                android:textSize="13sp" />
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/module_floating_review_fields_title"
            android:textColor="#334155"
            android:textSize="13sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFieldConfigs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/module_floating_review_card_width"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingBottom="14dp">

    <LinearLayout
        android:id="@+id/module_floating_review_card_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:background="@drawable/module_floating_review_bg_popup_card"
        android:clipToOutline="true"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/module_floating_review_header_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingTop="18dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/module_floating_review_tv_word"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="sans"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="#111827"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/module_floating_review_btn_close"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:contentDescription="@string/module_floating_review_close"
                android:focusable="true"
                android:gravity="center"
                android:padding="5dp"
                android:scaleType="center"
                android:src="@drawable/module_floating_review_ic_close" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/module_floating_review_phonetic_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="18dp">

            <LinearLayout
                android:id="@+id/module_floating_review_phonetic_uk_group"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/module_floating_review_phonetic_uk_label"
                    android:textColor="#4F46E5"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/module_floating_review_tv_phonetic_uk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:textColor="#6B7280"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="6dp"
                    android:contentDescription="@string/module_floating_review_pronunciation_icon"
                    android:padding="2dp"
                    android:src="@drawable/module_floating_review_ic_volume_up" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/module_floating_review_phonetic_us_group"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/module_floating_review_phonetic_us_label"
                    android:textColor="#4F46E5"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/module_floating_review_tv_phonetic_us"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:textColor="#6B7280"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="6dp"
                    android:contentDescription="@string/module_floating_review_pronunciation_icon"
                    android:padding="2dp"
                    android:src="@drawable/module_floating_review_ic_volume_up" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:id="@+id/module_floating_review_phonetic_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="22dp"
            android:layout_marginEnd="20dp"
            android:background="#EEF0F5" />

        <LinearLayout
            android:id="@+id/module_floating_review_floating_fields_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp" />

        <View
            android:id="@+id/module_floating_review_bottom_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="20dp"
            android:background="#EEF0F5" />

        <LinearLayout
            android:id="@+id/module_floating_review_action_row"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/module_floating_review_btn_favorite"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:contentDescription="@string/module_floating_review_favorite"
                android:padding="8dp"
                android:scaleType="center"
                android:src="@drawable/module_floating_review_ic_star" />

            <View
                android:layout_width="1dp"
                android:layout_height="18dp"
                android:background="#E5E7EB" />

            <ImageButton
                android:id="@+id/module_floating_review_btn_refresh"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:contentDescription="@string/module_floating_review_refresh"
                android:padding="7dp"
                android:scaleType="center"
                android:src="@drawable/module_floating_review_ic_refresh" />

            <View
                android:layout_width="1dp"
                android:layout_height="18dp"
                android:background="#E5E7EB" />

            <ImageButton
                android:id="@+id/module_floating_review_btn_copy"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:contentDescription="@string/module_floating_review_copy"
                android:padding="8dp"
                android:scaleType="center"
                android:src="@drawable/module_floating_review_ic_copy" />
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/module_floating_review_card_tail"
        android:layout_width="26dp"
        android:layout_height="16dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="50dp"
        android:contentDescription="@null"
        android:elevation="8dp"
        android:src="@drawable/module_floating_review_bg_popup_tail" />
</FrameLayout>

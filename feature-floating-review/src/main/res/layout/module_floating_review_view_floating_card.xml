<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/module_floating_review_card_width"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:id="@+id/module_floating_review_card_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/module_floating_review_tail_panel_offset"
        android:background="@drawable/module_floating_review_bg_popup_card"
        android:clipToOutline="true"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/module_floating_review_header_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/core_ui_dp_20"
            android:paddingTop="@dimen/core_ui_dp_18"
            android:paddingEnd="@dimen/core_ui_dp_12">

            <TextView
                android:id="@+id/module_floating_review_tv_word"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="sans"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="#111827"
                android:textSize="@dimen/core_ui_text_22"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/module_floating_review_btn_close"
                android:layout_width="@dimen/core_ui_dp_36"
                android:layout_height="@dimen/core_ui_dp_36"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:contentDescription="@string/module_floating_review_close"
                android:focusable="true"
                android:gravity="center"
                android:padding="@dimen/core_ui_dp_5"
                android:scaleType="center"
                android:src="@drawable/module_floating_review_ic_close" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/module_floating_review_phonetic_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_14"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/core_ui_dp_20"
            android:paddingEnd="@dimen/core_ui_dp_18">

            <LinearLayout
                android:id="@+id/module_floating_review_phonetic_uk_group"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/module_floating_review_phonetic_uk_label"
                    android:textColor="#4F46E5"
                    android:textSize="@dimen/core_ui_text_15"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/module_floating_review_tv_phonetic_uk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/core_ui_dp_4"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:textColor="#6B7280"
                    android:textSize="@dimen/core_ui_text_15" />

                <ImageView
                    android:layout_width="@dimen/core_ui_dp_20"
                    android:layout_height="@dimen/core_ui_dp_20"
                    android:layout_marginStart="@dimen/core_ui_dp_6"
                    android:contentDescription="@string/module_floating_review_pronunciation_icon"
                    android:padding="@dimen/core_ui_dp_2"
                    android:src="@drawable/module_floating_review_ic_volume_up" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/module_floating_review_phonetic_us_group"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/core_ui_dp_10"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/module_floating_review_phonetic_us_label"
                    android:textColor="#4F46E5"
                    android:textSize="@dimen/core_ui_text_15"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/module_floating_review_tv_phonetic_us"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/core_ui_dp_4"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:textColor="#6B7280"
                    android:textSize="@dimen/core_ui_text_15" />

                <ImageView
                    android:layout_width="@dimen/core_ui_dp_20"
                    android:layout_height="@dimen/core_ui_dp_20"
                    android:layout_marginStart="@dimen/core_ui_dp_6"
                    android:contentDescription="@string/module_floating_review_pronunciation_icon"
                    android:padding="@dimen/core_ui_dp_2"
                    android:src="@drawable/module_floating_review_ic_volume_up" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:id="@+id/module_floating_review_phonetic_divider"
            android:layout_width="match_parent"
            android:layout_height="@dimen/core_ui_dp_1"
            android:layout_marginStart="@dimen/core_ui_dp_20"
            android:layout_marginTop="@dimen/core_ui_dp_22"
            android:layout_marginEnd="@dimen/core_ui_dp_20"
            android:background="#EEF0F5" />

        <LinearLayout
            android:id="@+id/module_floating_review_floating_fields_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_24"
            android:orientation="vertical"
            android:paddingStart="@dimen/core_ui_dp_20"
            android:paddingEnd="@dimen/core_ui_dp_20" />

        <View
            android:id="@+id/module_floating_review_bottom_divider"
            android:layout_width="match_parent"
            android:layout_height="@dimen/core_ui_dp_1"
            android:layout_marginStart="@dimen/core_ui_dp_20"
            android:layout_marginTop="@dimen/core_ui_dp_24"
            android:layout_marginEnd="@dimen/core_ui_dp_20"
            android:background="#EEF0F5" />

        <LinearLayout
            android:id="@+id/module_floating_review_action_row"
            android:layout_width="match_parent"
            android:layout_height="@dimen/core_ui_dp_52"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/module_floating_review_btn_favorite"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:contentDescription="@string/module_floating_review_favorite"
                android:padding="@dimen/core_ui_dp_8"
                android:scaleType="center"
                android:src="@drawable/module_floating_review_ic_star" />

            <View
                android:layout_width="@dimen/core_ui_dp_1"
                android:layout_height="@dimen/core_ui_dp_18"
                android:background="#E5E7EB" />

            <ImageButton
                android:id="@+id/module_floating_review_btn_refresh"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:contentDescription="@string/module_floating_review_refresh"
                android:padding="@dimen/core_ui_dp_7"
                android:scaleType="center"
                android:src="@drawable/module_floating_review_ic_refresh" />

            <View
                android:layout_width="@dimen/core_ui_dp_1"
                android:layout_height="@dimen/core_ui_dp_18"
                android:background="#E5E7EB" />

            <ImageButton
                android:id="@+id/module_floating_review_btn_copy"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:contentDescription="@string/module_floating_review_copy"
                android:padding="@dimen/core_ui_dp_8"
                android:scaleType="center"
                android:src="@drawable/module_floating_review_ic_copy" />
        </LinearLayout>
    </LinearLayout>

    <com.chen.memorizewords.feature.floatingreview.ui.floating.FloatingSpeechTailView
        android:id="@+id/module_floating_review_card_tail"
        android:layout_width="@dimen/module_floating_review_tail_width"
        android:layout_height="@dimen/module_floating_review_tail_height"
        android:layout_gravity="bottom|start"
        android:contentDescription="@null" />
</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white"
        android:paddingStart="@dimen/module_floating_review_page_horizontal_padding"
        android:paddingTop="@dimen/page_margin"
        android:paddingEnd="@dimen/module_floating_review_page_horizontal_padding">

        <LinearLayout
            android:id="@+id/layoutCharacterHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/title_margin"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnCharacterBack"
                    android:layout_width="@dimen/title_icon_size"
                    android:layout_height="@dimen/title_icon_size"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/module_floating_review_back"
                    android:padding="@dimen/core_ui_dp_7"
                    android:src="@drawable/module_floating_review_ic_arrow_back" />

                <TextView
                    android:id="@+id/tvCharacterTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/core_ui_dp_6"
                    android:layout_weight="1"
                    android:text="@string/module_floating_review_character_title"
                    android:textColor="#111827"
                    android:textSize="@dimen/title_text_size"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btnCharacterRefresh"
                    android:layout_width="@dimen/title_icon_size"
                    android:layout_height="@dimen/title_icon_size"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/module_floating_review_character_refresh"
                    android:padding="4dp"
                    android:src="@drawable/module_floating_review_ic_refresh" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvCharacterSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/core_ui_dp_14"
                android:text="@string/module_floating_review_character_subtitle"
                android:textColor="#4B5563"
                android:textSize="@dimen/core_ui_text_13" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCharacterPacks"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/core_ui_dp_16"
            android:clipToPadding="false"
            android:paddingBottom="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutCharacterHeader" />

        <TextView
            android:id="@+id/tvCharacterEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/module_floating_review_character_empty"
            android:textColor="#64748B"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutCharacterHeader" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>

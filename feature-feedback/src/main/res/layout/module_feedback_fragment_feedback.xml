<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="viewModel"
            type="com.chen.memorizewords.feature.feedback.ui.feedback.FeedbackViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F7F9"
        android:padding="@dimen/page_margin">

        <FrameLayout
            android:id="@+id/frameLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/title_margin"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:clickable="true"
                android:layout_width="@dimen/title_icon_size"
                android:layout_height="@dimen/title_icon_size"
                android:layout_gravity="center_vertical"
                android:onClick="@{()->viewModel.back()}"
                android:src="@drawable/ic_arrow_back" />

            <TextView
                android:id="@+id/textView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:gravity="center"
                android:text="@string/module_feedback_feedback_title"
                android:textColor="#000000"
                android:textSize="@dimen/title_text_size"
                android:textStyle="bold" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvDesc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_12"
            android:text="@string/module_feedback_feedback_description"
            android:textColor="#6B7280"
            android:textSize="@dimen/core_ui_text_14"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/frameLayout" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardFeedback"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_12"
            app:cardCornerRadius="@dimen/core_ui_dp_16"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvDesc">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/core_ui_dp_12">

                <EditText
                    android:id="@+id/etFeedback"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/core_ui_dp_200"
                    android:background="@android:color/transparent"
                    android:gravity="top"
                    android:hint="@string/module_feedback_feedback_hint"
                    android:inputType="textMultiLine"
                    android:maxLines="6"
                    android:paddingBottom="@dimen/core_ui_dp_28"
                    android:textColor="#0F1720"
                    android:textSize="@dimen/core_ui_text_16" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvImages"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <LinearLayout
                    android:id="@+id/btnAddImage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/core_ui_dp_18"
                        android:layout_height="@dimen/core_ui_dp_18"
                        android:contentDescription="@null"
                        android:src="@drawable/feature_feedback_ic_add_image" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/core_ui_dp_8"
                        android:layout_weight="1"
                        android:text="@string/module_feedback_add_image"
                        android:textColor="#6B7280"
                        android:textSize="@dimen/core_ui_text_13" />

                    <TextView
                        android:id="@+id/tvCharCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/module_feedback_char_count"
                        android:textColor="#9CA3AF"
                        android:textSize="@dimen/core_ui_text_12" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardContact"
            android:layout_width="0dp"
            android:layout_height="@dimen/core_ui_dp_56"
            android:layout_marginTop="@dimen/core_ui_dp_18"
            app:cardCornerRadius="@dimen/core_ui_dp_28"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardFeedback">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/core_ui_dp_16"
                android:paddingEnd="@dimen/core_ui_dp_16">

                <ImageView
                    android:layout_width="@dimen/core_ui_dp_18"
                    android:layout_height="@dimen/core_ui_dp_18"
                    android:contentDescription="@null"
                    android:src="@drawable/feature_feedback_ic_mail" />

                <EditText
                    android:id="@+id/etContact"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/core_ui_dp_12"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/module_feedback_contact_hint"
                    android:inputType="textEmailAddress"
                    android:textColor="#374151"
                    android:textSize="@dimen/core_ui_text_14" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnSend"
            android:layout_width="0dp"
            android:layout_height="@dimen/core_ui_dp_56"
            android:layout_marginBottom="@dimen/core_ui_dp_28"
            android:backgroundTint="#0B1220"
            android:enabled="false"
            android:stateListAnimator="@null"
            android:text="@string/module_feedback_feedback_send"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/core_ui_text_16"
            app:cornerRadius="@dimen/core_ui_dp_28"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>

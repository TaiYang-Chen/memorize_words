<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="com.chen.memorizewords.feature.feedback.ui.about.AboutViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="@dimen/page_margin"
        android:background="@color/module_feedback_about_page_bg"
        tools:context=".AboutFragment">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/title_margin"
            android:background="@color/module_feedback_about_page_bg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/module_feedback_back"
                android:onClick="@{()->viewModel.back()}"
                android:src="@drawable/ic_arrow_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/module_feedback_about_title"
                android:textColor="@color/module_feedback_about_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHeroLogo"
                    android:layout_width="@dimen/module_feedback_about_hero_logo_card_size"
                    android:layout_height="@dimen/module_feedback_about_hero_logo_card_size"
                    android:layout_marginTop="@dimen/module_feedback_about_hero_top_margin"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="@dimen/module_feedback_about_hero_logo_card_radius"
                    app:cardElevation="@dimen/module_feedback_about_card_elevation"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:strokeColor="@color/module_feedback_about_stroke"
                    app:strokeWidth="@dimen/module_feedback_about_card_stroke_width">

                    <ImageView
                        android:layout_width="@dimen/module_feedback_about_hero_logo_size"
                        android:layout_height="@dimen/module_feedback_about_hero_logo_size"
                        android:layout_gravity="center"
                        android:contentDescription="@string/module_feedback_app_icon_desc"
                        android:src="@drawable/app_brand_logo" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvAppName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/module_feedback_about_app_name_top_margin"
                    android:text="@string/module_feedback_app_name"
                    android:textColor="@color/module_feedback_about_text_primary"
                    android:textSize="@dimen/module_feedback_about_app_name_size"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardHeroLogo" />

                <TextView
                    android:id="@+id/tvVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/module_feedback_about_version_top_margin"
                    android:background="@drawable/module_feedback_bg_about_version_badge"
                    android:gravity="center"
                    android:paddingStart="@dimen/module_feedback_about_version_horizontal_padding"
                    android:paddingTop="@dimen/module_feedback_about_version_vertical_padding"
                    android:paddingEnd="@dimen/module_feedback_about_version_horizontal_padding"
                    android:paddingBottom="@dimen/module_feedback_about_version_vertical_padding"
                    android:textColor="@color/module_feedback_about_text_secondary"
                    android:textSize="@dimen/module_feedback_about_version_size"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvAppName"
                    tools:text="版本 1.0.0" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMission"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/module_feedback_about_mission_top_margin"
                    app:cardBackgroundColor="@color/module_feedback_about_card_bg"
                    app:cardCornerRadius="@dimen/module_feedback_about_card_radius"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvVersion"
                    app:strokeColor="@color/module_feedback_about_stroke"
                    app:strokeWidth="@dimen/module_feedback_about_card_stroke_width">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/module_feedback_about_mission_card_padding">

                        <View
                            android:layout_width="@dimen/module_feedback_about_mission_orb_size"
                            android:layout_height="@dimen/module_feedback_about_mission_orb_size"
                            android:background="@drawable/module_feedback_bg_about_mission_orb"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                        <FrameLayout
                            android:id="@+id/missionBadge"
                            android:layout_width="@dimen/module_feedback_about_icon_circle_size"
                            android:layout_height="@dimen/module_feedback_about_icon_circle_size"
                            android:background="@drawable/module_feedback_bg_about_mission_badge"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:layout_width="@dimen/module_feedback_about_icon_circle_inner"
                                android:layout_height="@dimen/module_feedback_about_icon_circle_inner"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/module_feedback_ic_about_lightbulb" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvMissionTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="@string/module_feedback_mission_title"
                            android:textColor="@color/module_feedback_about_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="@id/missionBadge"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/missionBadge"
                            app:layout_constraintTop_toTopOf="@id/missionBadge" />

                        <TextView
                            android:id="@+id/tvMission"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="22dp"
                            android:lineSpacingExtra="@dimen/module_feedback_about_body_line_spacing"
                            android:textColor="@color/module_feedback_about_text_secondary"
                            android:textSize="@dimen/module_feedback_about_body_size"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/missionBadge"
                            tools:text="通过简洁设计与智能技术，为用户提供稳定、轻量、专注的背单词体验。" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMenu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/module_feedback_about_menu_top_margin"
                    app:cardBackgroundColor="@color/module_feedback_about_card_bg"
                    app:cardCornerRadius="@dimen/module_feedback_about_card_radius"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardMission"
                    app:strokeColor="@color/module_feedback_about_stroke"
                    app:strokeWidth="@dimen/module_feedback_about_card_stroke_width">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/rowCheckUpdate"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/module_feedback_about_menu_row_height"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/module_feedback_about_menu_row_padding_horizontal"
                            android:paddingEnd="@dimen/module_feedback_about_menu_row_padding_horizontal">

                            <ImageView
                                android:layout_width="@dimen/module_feedback_about_menu_icon_size"
                                android:layout_height="@dimen/module_feedback_about_menu_icon_size"
                                android:contentDescription="@null"
                                android:src="@drawable/module_feedback_ic_about_refresh" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="18dp"
                                android:layout_weight="1"
                                android:maxLines="1"
                                android:text="@string/module_feedback_check_update"
                                android:textColor="@color/module_feedback_about_text_primary"
                                android:textSize="@dimen/module_feedback_about_menu_label_size" />

                            <TextView
                                android:id="@+id/tvCheckUpdateStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:maxLines="1"
                                android:text="@string/module_feedback_latest_version"
                                android:textColor="@color/module_feedback_about_text_muted"
                                android:textSize="@dimen/module_feedback_about_status_size" />

                            <ImageView
                                android:layout_width="@dimen/module_feedback_about_menu_chevron_size"
                                android:layout_height="@dimen/module_feedback_about_menu_chevron_size"
                                android:layout_marginStart="10dp"
                                android:contentDescription="@null"
                                android:src="@drawable/module_feedback_ic_about_chevron" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/module_feedback_about_divider" />

                        <LinearLayout
                            android:id="@+id/rowRateUs"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/module_feedback_about_menu_row_height"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/module_feedback_about_menu_row_padding_horizontal"
                            android:paddingEnd="@dimen/module_feedback_about_menu_row_padding_horizontal">

                            <ImageView
                                android:layout_width="@dimen/module_feedback_about_menu_icon_size"
                                android:layout_height="@dimen/module_feedback_about_menu_icon_size"
                                android:contentDescription="@null"
                                android:src="@drawable/module_feedback_ic_star"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="18dp"
                                android:layout_weight="1"
                                android:maxLines="1"
                                android:text="@string/module_feedback_rate_us"
                                android:textColor="@color/module_feedback_about_text_primary"
                                android:textSize="@dimen/module_feedback_about_menu_label_size" />

                            <ImageView
                                android:layout_width="@dimen/module_feedback_about_menu_chevron_size"
                                android:layout_height="@dimen/module_feedback_about_menu_chevron_size"
                                android:contentDescription="@null"
                                android:src="@drawable/module_feedback_ic_about_chevron" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/module_feedback_about_divider" />

                        <LinearLayout
                            android:id="@+id/rowOfficialWebsite"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/module_feedback_about_menu_row_height"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/module_feedback_about_menu_row_padding_horizontal"
                            android:paddingEnd="@dimen/module_feedback_about_menu_row_padding_horizontal">

                            <ImageView
                                android:layout_width="@dimen/module_feedback_about_menu_icon_size"
                                android:layout_height="@dimen/module_feedback_about_menu_icon_size"
                                android:contentDescription="@null"
                                android:src="@drawable/module_feedback_ic_about_globe" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="18dp"
                                android:layout_weight="1"
                                android:maxLines="1"
                                android:text="@string/module_feedback_official_website"
                                android:textColor="@color/module_feedback_about_text_primary"
                                android:textSize="@dimen/module_feedback_about_menu_label_size" />

                            <ImageView
                                android:layout_width="@dimen/module_feedback_about_menu_chevron_size"
                                android:layout_height="@dimen/module_feedback_about_menu_chevron_size"
                                android:contentDescription="@null"
                                android:src="@drawable/module_feedback_ic_about_chevron" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/module_feedback_about_divider" />

                        <LinearLayout
                            android:id="@+id/rowTerms"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/module_feedback_about_menu_row_height"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/module_feedback_about_menu_row_padding_horizontal"
                            android:paddingEnd="@dimen/module_feedback_about_menu_row_padding_horizontal">

                            <ImageView
                                android:layout_width="@dimen/module_feedback_about_menu_icon_size"
                                android:layout_height="@dimen/module_feedback_about_menu_icon_size"
                                android:contentDescription="@null"
                                android:src="@drawable/module_feedback_ic_description"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="18dp"
                                android:layout_weight="1"
                                android:maxLines="1"
                                android:text="@string/module_feedback_terms"
                                android:textColor="@color/module_feedback_about_text_primary"
                                android:textSize="@dimen/module_feedback_about_menu_label_size" />

                            <ImageView
                                android:layout_width="@dimen/module_feedback_about_menu_chevron_size"
                                android:layout_height="@dimen/module_feedback_about_menu_chevron_size"
                                android:contentDescription="@null"
                                android:src="@drawable/module_feedback_ic_about_chevron" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/module_feedback_about_divider" />

                        <LinearLayout
                            android:id="@+id/rowPrivacy"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/module_feedback_about_menu_row_height"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/module_feedback_about_menu_row_padding_horizontal"
                            android:paddingEnd="@dimen/module_feedback_about_menu_row_padding_horizontal">

                            <ImageView
                                android:layout_width="@dimen/module_feedback_about_menu_icon_size"
                                android:layout_height="@dimen/module_feedback_about_menu_icon_size"
                                android:contentDescription="@null"
                                android:src="@drawable/module_feedback_ic_lock"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="18dp"
                                android:layout_weight="1"
                                android:maxLines="1"
                                android:text="@string/module_feedback_privacy"
                                android:textColor="@color/module_feedback_about_text_primary"
                                android:textSize="@dimen/module_feedback_about_menu_label_size" />

                            <ImageView
                                android:layout_width="@dimen/module_feedback_about_menu_chevron_size"
                                android:layout_height="@dimen/module_feedback_about_menu_chevron_size"
                                android:contentDescription="@null"
                                android:src="@drawable/module_feedback_ic_about_chevron" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvCopyright"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/module_feedback_about_footer_top_margin"
                    android:gravity="center"
                    android:text="@string/module_feedback_company_copyright"
                    android:textColor="@color/module_feedback_about_text_secondary"
                    android:textSize="@dimen/module_feedback_about_footer_size"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginBottom="15dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardMenu" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>

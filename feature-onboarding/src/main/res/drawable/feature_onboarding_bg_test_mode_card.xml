<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#E8F3FF" />
            <stroke
                android:width="@dimen/core_ui_dp_1"
                android:color="@color/feature_onboarding_action_blue" />
            <corners android:radius="@dimen/core_ui_dp_12" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/white" />
            <stroke
                android:width="@dimen/core_ui_dp_1"
                android:color="@color/feature_onboarding_test_mode_stroke" />
            <corners android:radius="@dimen/core_ui_dp_12" />
        </shape>
    </item>
</selector>

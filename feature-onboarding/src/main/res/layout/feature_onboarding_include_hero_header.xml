<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="headerLabelText"
            type="String" />

        <variable
            name="titleText"
            type="String" />

        <variable
            name="subtitleText"
            type="String" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvHeaderLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@{headerLabelText}"
            android:textColor="@color/feature_onboarding_header_label"
            android:textSize="@dimen/feature_onboarding_header_label_text_size"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/feature_onboarding_header_title_margin_top"
            android:gravity="center"
            android:maxWidth="@dimen/feature_onboarding_header_title_max_width"
            android:text="@{titleText}"
            tools:text="dasgfdgdfgdfg"
            android:textColor="@color/feature_onboarding_header_title"
            android:textSize="@dimen/feature_onboarding_header_title_text_size"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHeaderSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/feature_onboarding_header_subtitle_margin_top"
            android:gravity="center"
            android:lineSpacingExtra="@dimen/feature_onboarding_header_subtitle_line_spacing"
            android:maxWidth="@dimen/feature_onboarding_header_subtitle_max_width"
            android:text="@{subtitleText}"
            tools:text="dasgfdgdsdfsdfdsfdsffgdfg"
            android:textColor="@color/feature_onboarding_header_subtitle"
            android:textSize="@dimen/feature_onboarding_header_subtitle_text_size" />
    </LinearLayout>
</layout>

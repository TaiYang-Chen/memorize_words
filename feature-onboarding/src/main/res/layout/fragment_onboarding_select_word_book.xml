<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/feature_onboarding_select_page_background"
        android:padding="@dimen/feature_onboarding_page_padding">

        <LinearLayout
            android:id="@+id/selectionErrorGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@color/feature_onboarding_select_error_background"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/tvSelectionError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/feature_onboarding_select_error_text"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnRetrySelection"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/feature_onboarding_action_blue"
                    android:text="@string/feature_onboarding_retry"
                    android:textColor="@android:color/white" />

                <Button
                    android:id="@+id/btnDismissSelectionError"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/feature_onboarding_goal_control_track"
                    android:text="@string/feature_onboarding_dismiss"
                    android:textColor="@color/feature_onboarding_action_blue" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/nextStepContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp"
            app:layout_constraintBottom_toTopOf="@id/selectionErrorGroup"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_goneMarginBottom="0dp">

            <Button
                android:id="@+id/btnNextStep"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:minHeight="52dp"
                android:backgroundTint="@color/feature_onboarding_next_step_button_background_tint"
                android:text="@string/feature_onboarding_next_step"
                android:textColor="@android:color/white" />
        </FrameLayout>

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:id="@+id/contentCoordinator"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@id/nextStepContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.appbar.AppBarLayout
                android:id="@+id/onboardingAppBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/feature_onboarding_select_page_background"
                android:elevation="0dp"
                android:stateListAnimator="@null">

                <LinearLayout
                    android:id="@+id/collapsibleHeaderContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_scrollFlags="scroll|snap">

                    <include
                        android:id="@+id/heroContentLayout"
                        layout="@layout/feature_onboarding_include_hero_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/feature_onboarding_select_book_hero_margin_top"
                        app:subtitleText="@{@string/feature_onboarding_select_book_subtitle}"
                        app:titleText="@{@string/feature_onboarding_select_book_title}" />
                </LinearLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/searchHeaderContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/feature_onboarding_body_margin_top">

                    <LinearLayout
                        android:id="@+id/searchLayout"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:background="@drawable/feature_onboarding_bg_search"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginEnd="@dimen/feature_onboarding_search_cancel_spacing"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        app:layout_constraintEnd_toStartOf="@id/btnCancel"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_goneMarginEnd="0dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/feature_onboarding_ic_search"
                            app:tint="@color/feature_onboarding_select_search_icon" />

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/etSearch"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:gravity="center_vertical"
                            android:hint="@string/feature_onboarding_search_hint"
                            android:imeOptions="actionSearch"
                            android:inputType="text"
                            android:maxLines="1"
                            android:padding="0dp"
                            android:textColor="@color/feature_onboarding_select_search_text"
                            android:textColorHint="@color/feature_onboarding_select_search_hint"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnCancel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/feature_onboarding_cancel"
                        android:textColor="@color/feature_onboarding_select_search_text"
                        android:textSize="16sp"
                        android:visibility="gone"
                        app:layout_constraintBottom_toBottomOf="@id/searchLayout"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/searchLayout" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tabLayout"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_marginTop="12dp"
                    android:background="@android:color/transparent"
                    android:minHeight="36dp"
                    app:tabContentStart="0dp"
                    app:tabGravity="start"
                    app:tabIndicatorAnimationMode="linear"
                    app:tabIndicator="@drawable/feature_onboarding_tab_indicator_rounded"
                    app:tabIndicatorFullWidth="false"
                    app:tabIndicatorHeight="3dp"
                    app:tabMinWidth="0dp"
                    app:tabMode="scrollable"
                    app:tabPaddingBottom="0dp"
                    app:tabPaddingTop="0dp"
                    app:tabRippleColor="@android:color/transparent" />
            </com.google.android.material.appbar.AppBarLayout>

            <FrameLayout
                android:id="@+id/contentContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_behavior="@string/appbar_scrolling_view_behavior">

                <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                    android:id="@+id/swipeRefresh"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvBooks"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp" />
                </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

                <LinearLayout
                    android:id="@+id/emptyStateGroup"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvStateMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/feature_onboarding_select_state_text"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btnRetryList"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="@color/feature_onboarding_action_blue"
                        android:text="@string/feature_onboarding_retry"
                        android:textColor="@android:color/white"
                        android:visibility="gone" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone" />

                <ProgressBar
                    android:id="@+id/selectionProgress"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:visibility="gone" />
            </FrameLayout>
        </androidx.coordinatorlayout.widget.CoordinatorLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>

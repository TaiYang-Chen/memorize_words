<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/feature_onboarding_page_background"
        android:padding="@dimen/feature_onboarding_page_padding">

        <ProgressBar
            android:id="@+id/planLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/feature_onboarding_header_margin_top"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/planStateGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/feature_onboarding_header_margin_top"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvPlanStateMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/feature_onboarding_plan_state_text"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnRetryPlanState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/feature_onboarding_action_blue"
                android:text="@string/feature_onboarding_retry"
                android:textColor="@android:color/white" />

            <Button
                android:id="@+id/btnBackToSelectBook"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/feature_onboarding_goal_control_track"
                android:text="@string/feature_onboarding_back_to_select_book"
                android:textColor="@color/feature_onboarding_action_blue" />
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/contentScrollView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/feature_onboarding_header_margin_top"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingBottom="24dp"
            app:layout_constraintBottom_toBottomOf="@+id/btnComplete"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="40sp">

                <include
                    android:id="@+id/heroContentLayout"
                    layout="@layout/feature_onboarding_include_hero_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/feature_onboarding_body_margin_top"
                    app:subtitleText="@{@string/feature_onboarding_plan_subtitle}"
                    app:titleText="@{@string/feature_onboarding_plan_title}" />

                <LinearLayout
                    android:id="@+id/cardWordBookInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/feature_onboarding_bg_book_info_card"
                    android:gravity="center_vertical"
                    android:minHeight="88dp"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/feature_onboarding_bg_book_cover_surface">

                        <ImageView
                            android:id="@+id/ivBookCover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@null"
                            android:scaleType="centerCrop"
                            android:visibility="gone" />

                        <ImageView
                            android:id="@+id/ivBookCoverFallback"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/feature_onboarding_ic_book"
                            app:tint="@android:color/white" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvBookTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/feature_onboarding_book_title"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvBookSummary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/feature_onboarding_book_summary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnModifyBook"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingHorizontal="4dp"
                        android:paddingVertical="2dp"
                        android:text="@string/feature_onboarding_modify_book"
                        android:textColor="@color/feature_onboarding_action_blue"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:paddingTop="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/feature_onboarding_daily_goal_title"
                            android:textColor="@color/feature_onboarding_section_title"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvBalancedSuggestion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingHorizontal="4dp"
                            android:paddingVertical="2dp"
                            android:text="@string/feature_onboarding_balanced_suggestion"
                            android:textColor="@color/feature_onboarding_action_blue"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/feature_onboarding_section_spacing_compact"
                        android:orientation="horizontal">


                        <LinearLayout
                            android:id="@+id/cardDailyNew"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/feature_onboarding_bg_panel"
                            android:orientation="vertical"
                            android:outlineProvider="background"
                            android:padding="@dimen/feature_onboarding_goal_panel_padding">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:layout_weight="1"
                                    android:text="@string/feature_onboarding_daily_new"
                                    android:textColor="@color/feature_onboarding_book_card_title"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/feature_onboarding_daily_new_subtitle"
                                    android:textColor="@color/feature_onboarding_goal_hint"
                                    android:textSize="10sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="18dp"
                                android:background="@drawable/feature_onboarding_bg_goal_control_track"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:padding="@dimen/feature_onboarding_goal_control_padding_horizontal">

                                <ImageButton
                                    android:id="@+id/btnDailyNewDecrease"
                                    android:layout_width="@dimen/feature_onboarding_goal_control_button_size"
                                    android:layout_height="@dimen/feature_onboarding_goal_control_button_size"
                                    android:background="@drawable/feature_onboarding_bg_goal_control_button_decrease"
                                    android:contentDescription="@string/feature_onboarding_decrease_new_words"
                                    android:padding="@dimen/feature_onboarding_goal_button_padding"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/feature_onboarding_ic_minus"
                                    app:tint="@color/feature_onboarding_goal_button_subtle_icon" />

                                <EditText
                                    android:id="@+id/etDailyNewValue"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/feature_onboarding_goal_button_spacing"
                                    android:layout_marginEnd="@dimen/feature_onboarding_goal_button_spacing"
                                    android:layout_weight="1"
                                    android:background="@android:color/transparent"
                                    android:contentDescription="@string/feature_onboarding_daily_new_input_hint"
                                    android:digits="0123456789"
                                    android:fontFamily="sans-serif-medium"
                                    android:gravity="center"
                                    android:importantForAutofill="no"
                                    android:includeFontPadding="false"
                                    android:inputType="number"
                                    android:maxLength="3"
                                    android:padding="0dp"
                                    android:selectAllOnFocus="true"
                                    android:singleLine="true"
                                    android:textColor="@color/feature_onboarding_book_card_title"
                                    android:textSize="@dimen/feature_onboarding_goal_control_value_text_size"
                                    tools:text="20" />

                                <ImageButton
                                    android:id="@+id/btnDailyNewIncrease"
                                    android:layout_width="@dimen/feature_onboarding_goal_control_button_size"
                                    android:layout_height="@dimen/feature_onboarding_goal_control_button_size"
                                    android:background="@drawable/feature_onboarding_bg_goal_control_button_increase"
                                    android:contentDescription="@string/feature_onboarding_increase_new_words"
                                    android:padding="@dimen/feature_onboarding_goal_button_padding"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/feature_onboarding_ic_add"
                                    app:tint="@color/feature_onboarding_goal_button_subtle_icon" />
                            </LinearLayout>
                        </LinearLayout>


                        <View
                            android:layout_width="25dp"
                            android:layout_height="25dp" />

                        <LinearLayout
                            android:id="@+id/cardDailyReview"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/feature_onboarding_bg_panel"
                            android:orientation="vertical"
                            android:outlineProvider="background"
                            android:padding="@dimen/feature_onboarding_goal_panel_padding">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">


                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:layout_weight="1"
                                    android:text="@string/feature_onboarding_daily_review"
                                    android:textColor="@color/feature_onboarding_book_card_title"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/feature_onboarding_daily_review_subtitle"
                                    android:textColor="@color/feature_onboarding_goal_hint"
                                    android:textSize="10sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="18dp"
                                android:background="@drawable/feature_onboarding_bg_goal_control_track"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:padding="@dimen/feature_onboarding_goal_control_padding_horizontal">

                                <ImageButton
                                    android:id="@+id/btnDailyReviewDecrease"
                                    android:layout_width="@dimen/feature_onboarding_goal_control_button_size"
                                    android:layout_height="@dimen/feature_onboarding_goal_control_button_size"
                                    android:background="@drawable/feature_onboarding_bg_goal_control_button_decrease"
                                    android:contentDescription="@string/feature_onboarding_decrease_review_words"
                                    android:padding="@dimen/feature_onboarding_goal_button_padding"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/feature_onboarding_ic_minus"
                                    app:tint="@color/feature_onboarding_goal_button_subtle_icon" />

                                <EditText
                                    android:id="@+id/etDailyReviewValue"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_marginStart="@dimen/feature_onboarding_goal_button_spacing"
                                    android:layout_marginEnd="@dimen/feature_onboarding_goal_button_spacing"
                                    android:layout_weight="1"
                                    android:background="@android:color/transparent"
                                    android:contentDescription="@string/feature_onboarding_daily_review_input_hint"
                                    android:digits="0123456789"
                                    android:fontFamily="sans-serif-medium"
                                    android:gravity="center"
                                    android:importantForAutofill="no"
                                    android:includeFontPadding="false"
                                    android:inputType="number"
                                    android:maxLength="3"
                                    android:padding="0dp"
                                    android:selectAllOnFocus="true"
                                    android:singleLine="true"
                                    android:textColor="@color/feature_onboarding_book_card_title"
                                    android:textSize="@dimen/feature_onboarding_goal_control_value_text_size"
                                    tools:text="50" />

                                <ImageButton
                                    android:id="@+id/btnDailyReviewIncrease"
                                    android:layout_width="@dimen/feature_onboarding_goal_control_button_size"
                                    android:layout_height="@dimen/feature_onboarding_goal_control_button_size"
                                    android:background="@drawable/feature_onboarding_bg_goal_control_button_increase"
                                    android:contentDescription="@string/feature_onboarding_increase_review_words"
                                    android:padding="@dimen/feature_onboarding_goal_button_padding"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/feature_onboarding_ic_add"
                                    app:tint="@color/feature_onboarding_goal_button_subtle_icon" />
                            </LinearLayout>
                        </LinearLayout>


                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/feature_onboarding_section_spacing_large"
                    android:orientation="vertical"
                    android:paddingTop="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_onboarding_test_mode"
                        android:textColor="@color/feature_onboarding_section_title"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/feature_onboarding_section_spacing_compact"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/cardMeaningMode"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/feature_onboarding_bg_test_mode_card"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:minHeight="@dimen/feature_onboarding_test_mode_card_min_height"
                            android:orientation="vertical"
                            android:paddingHorizontal="@dimen/feature_onboarding_test_mode_card_padding_horizontal"
                            android:paddingVertical="@dimen/feature_onboarding_test_mode_card_padding_vertical">

                            <ImageView
                                android:id="@+id/ivMeaningMode"
                                android:layout_width="@dimen/feature_onboarding_test_mode_icon_size"
                                android:layout_height="@dimen/feature_onboarding_test_mode_icon_size"
                                android:duplicateParentState="true"
                                android:src="@drawable/feature_onboarding_ic_test_mode_meaning"
                                app:tint="@color/feature_onboarding_test_mode_icon_tint" />

                            <TextView
                                android:id="@+id/tvMeaningMode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/feature_onboarding_test_mode_text_margin_top"
                                android:duplicateParentState="true"
                                android:text="@string/feature_onboarding_test_mode_meaning"
                                android:textColor="@color/feature_onboarding_test_mode_text_color"
                                android:textSize="@dimen/feature_onboarding_test_mode_text_size"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/cardSpellingMode"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/feature_onboarding_test_mode_card_spacing"
                            android:layout_weight="1"
                            android:background="@drawable/feature_onboarding_bg_test_mode_card"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:minHeight="@dimen/feature_onboarding_test_mode_card_min_height"
                            android:orientation="vertical"
                            android:paddingHorizontal="@dimen/feature_onboarding_test_mode_card_padding_horizontal"
                            android:paddingVertical="@dimen/feature_onboarding_test_mode_card_padding_vertical">

                            <ImageView
                                android:id="@+id/ivSpellingMode"
                                android:layout_width="@dimen/feature_onboarding_test_mode_icon_size"
                                android:layout_height="@dimen/feature_onboarding_test_mode_icon_size"
                                android:duplicateParentState="true"
                                android:src="@drawable/feature_onboarding_ic_test_mode_spelling"
                                app:tint="@color/feature_onboarding_test_mode_icon_tint" />

                            <TextView
                                android:id="@+id/tvSpellingMode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/feature_onboarding_test_mode_text_margin_top"
                                android:duplicateParentState="true"
                                android:text="@string/feature_onboarding_test_mode_spelling"
                                android:textColor="@color/feature_onboarding_test_mode_text_color"
                                android:textSize="@dimen/feature_onboarding_test_mode_text_size"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/cardListeningMode"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/feature_onboarding_test_mode_card_spacing"
                            android:layout_weight="1"
                            android:background="@drawable/feature_onboarding_bg_test_mode_card"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:minHeight="@dimen/feature_onboarding_test_mode_card_min_height"
                            android:orientation="vertical"
                            android:paddingHorizontal="@dimen/feature_onboarding_test_mode_card_padding_horizontal"
                            android:paddingVertical="@dimen/feature_onboarding_test_mode_card_padding_vertical">

                            <ImageView
                                android:id="@+id/ivListeningMode"
                                android:layout_width="@dimen/feature_onboarding_test_mode_icon_size"
                                android:layout_height="@dimen/feature_onboarding_test_mode_icon_size"
                                android:duplicateParentState="true"
                                android:src="@drawable/feature_onboarding_ic_test_mode_listening"
                                app:tint="@color/feature_onboarding_test_mode_icon_tint" />

                            <TextView
                                android:id="@+id/tvListeningMode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/feature_onboarding_test_mode_text_margin_top"
                                android:duplicateParentState="true"
                                android:text="@string/feature_onboarding_test_mode_listening"
                                android:textColor="@color/feature_onboarding_test_mode_text_color"
                                android:textSize="@dimen/feature_onboarding_test_mode_text_size"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/feature_onboarding_bg_goal_panel"
                    android:orientation="vertical"
                    android:outlineProvider="background"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_onboarding_word_order"
                        android:textColor="@color/feature_onboarding_section_title"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">

                        <androidx.appcompat.widget.AppCompatRadioButton
                            android:id="@+id/radioOrderRandom"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:buttonTint="@color/feature_onboarding_order_radio_tint"
                            android:text="@string/feature_onboarding_order_random"
                            android:textColor="@color/feature_onboarding_book_card_title" />

                        <androidx.appcompat.widget.AppCompatRadioButton
                            android:id="@+id/radioOrderAlphabeticAsc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:buttonTint="@color/feature_onboarding_order_radio_tint"
                            android:text="@string/feature_onboarding_order_alphabetic_asc"
                            android:textColor="@color/feature_onboarding_book_card_title" />

                        <androidx.appcompat.widget.AppCompatRadioButton
                            android:id="@+id/radioOrderAlphabeticDesc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:buttonTint="@color/feature_onboarding_order_radio_tint"
                            android:text="@string/feature_onboarding_order_alphabetic_desc"
                            android:textColor="@color/feature_onboarding_book_card_title" />

                        <androidx.appcompat.widget.AppCompatRadioButton
                            android:id="@+id/radioOrderLengthAsc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:buttonTint="@color/feature_onboarding_order_radio_tint"
                            android:text="@string/feature_onboarding_order_length_asc"
                            android:textColor="@color/feature_onboarding_book_card_title" />

                        <androidx.appcompat.widget.AppCompatRadioButton
                            android:id="@+id/radioOrderLengthDesc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:buttonTint="@color/feature_onboarding_order_radio_tint"
                            android:text="@string/feature_onboarding_order_length_desc"
                            android:textColor="@color/feature_onboarding_book_card_title" />
                    </RadioGroup>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvSubmitError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textColor="@color/feature_onboarding_plan_error_text"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>


        <Button
            android:id="@+id/btnComplete"
            android:enabled="false"
            android:minHeight="52dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/feature_onboarding_action_blue"
            android:text="@string/feature_onboarding_complete"
            android:textColor="@android:color/white"
            app:cornerRadius="@dimen/feature_onboarding_action_button_corner_radius"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:layout_editor_absoluteX="24dp" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>

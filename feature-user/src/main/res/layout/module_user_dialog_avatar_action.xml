<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bottom_dialog_bg"
        android:paddingStart="@dimen/core_ui_dp_16"
        android:paddingEnd="@dimen/core_ui_dp_16"
        android:paddingTop="@dimen/core_ui_dp_12"
        android:paddingBottom="@dimen/core_ui_dp_12">

        <View
            android:layout_width="@dimen/core_ui_dp_40"
            android:layout_height="@dimen/core_ui_dp_4"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/core_ui_dp_12"
            android:background="@drawable/bg_drag_handle" />

        <TextView
            android:id="@+id/tvViewAvatar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/core_ui_dp_48"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/core_ui_dp_8"
            android:paddingEnd="@dimen/core_ui_dp_8"
            android:text="查看头像"
            android:textColor="#111111"
            android:textSize="@dimen/core_ui_text_16" />

        <TextView
            android:id="@+id/tvPickFromGallery"
            android:layout_width="match_parent"
            android:layout_height="@dimen/core_ui_dp_48"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/core_ui_dp_8"
            android:paddingEnd="@dimen/core_ui_dp_8"
            android:text="从相册选择"
            android:textColor="#111111"
            android:textSize="@dimen/core_ui_text_16" />

        <TextView
            android:id="@+id/tvTakePhoto"
            android:layout_width="match_parent"
            android:layout_height="@dimen/core_ui_dp_48"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/core_ui_dp_8"
            android:paddingEnd="@dimen/core_ui_dp_8"
            android:text="拍照"
            android:textColor="#111111"
            android:textSize="@dimen/core_ui_text_16" />

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/core_ui_dp_1"
            android:background="#EEEEEE" />

        <TextView
            android:id="@+id/tvCancel"
            android:layout_width="match_parent"
            android:layout_height="@dimen/core_ui_dp_48"
            android:gravity="center"
            android:text="取消"
            android:textColor="#666666"
            android:textSize="@dimen/core_ui_text_15" />
    </LinearLayout>
</layout>
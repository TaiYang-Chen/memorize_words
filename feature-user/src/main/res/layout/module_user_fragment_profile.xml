<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.chen.memorizewords.feature.user.ui.profile.ProfileViewModel" />

        <variable
            name="user"
            type="com.chen.memorizewords.domain.model.user.User" />
    </data>

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:padding="@dimen/page_margin"
        android:background="@android:color/white"
        android:layout_height="match_parent">

        <RelativeLayout
            android:layout_marginTop="@dimen/title_margin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="@dimen/feature_user_profile_toolbar_icon_size"
                android:layout_height="@dimen/feature_user_profile_toolbar_icon_size"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:contentDescription="@string/feature_user_profile_back"
                android:onClick="@{()->viewModel.back()}"
                android:padding="1dp"
                android:src="@drawable/ic_arrow_back" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/feature_user_profile_title"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivMore"
                android:layout_width="@dimen/feature_user_profile_toolbar_icon_size"
                android:layout_height="@dimen/feature_user_profile_toolbar_icon_size"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:contentDescription="@string/feature_user_profile_more"
                android:onClick="@{()->viewModel.onMoreClick()}"
                android:padding="1dp"
                android:src="@drawable/feature_user_ic_profile_more" />
        </RelativeLayout>



        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/feature_user_profile_screen_bottom_padding">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/feature_user_profile_avatar_top_margin"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="@dimen/feature_user_profile_avatar_size"
                            android:layout_height="@dimen/feature_user_profile_avatar_size"
                            android:layout_gravity="center"
                            android:onClick="@{()->viewModel.onAvatarClick()}"
                            app:cardBackgroundColor="@android:color/white"
                            app:cardCornerRadius="@dimen/feature_user_profile_avatar_corner_radius"
                            app:strokeColor="@color/feature_user_profile_avatar_stroke"
                            app:strokeWidth="1dp">

                            <ImageView
                                android:id="@+id/ivAvatar"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/feature_user_profile_avatar"
                                android:padding="@dimen/feature_user_profile_avatar_inner_padding"
                                android:scaleType="fitCenter"
                                tools:src="@drawable/feature_user_ic_profile_avatar_default" />
                        </com.google.android.material.card.MaterialCardView>

                        <FrameLayout
                            android:layout_width="@dimen/feature_user_profile_camera_button_size"
                            android:layout_height="@dimen/feature_user_profile_camera_button_size"
                            android:layout_gravity="bottom|end"
                            android:layout_marginEnd="@dimen/feature_user_profile_camera_button_end_margin"
                            android:layout_marginBottom="@dimen/feature_user_profile_camera_button_bottom_margin"
                            android:background="@drawable/feature_user_profile_camera_button_background"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless"
                            android:onClick="@{()->viewModel.onAvatarClick()}">

                            <ImageView
                                android:layout_width="@dimen/feature_user_profile_camera_icon_size"
                                android:layout_height="@dimen/feature_user_profile_camera_icon_size"
                                android:layout_gravity="center"
                                android:contentDescription="@string/feature_user_profile_change_avatar"
                                android:src="@drawable/feature_user_ic_profile_camera" />
                        </FrameLayout>
                    </FrameLayout>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/feature_user_profile_avatar_top_margin"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/feature_user_profile_card_background"
                        android:orientation="vertical"
                        android:paddingTop="@dimen/feature_user_profile_card_vertical_padding"
                        android:paddingBottom="@dimen/feature_user_profile_card_vertical_padding">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/feature_user_profile_row_height"
                            android:gravity="center_vertical"
                            android:onClick="@{()->viewModel.changeNickname()}"
                            android:paddingStart="@dimen/feature_user_profile_row_horizontal_padding"
                            android:paddingEnd="@dimen/feature_user_profile_row_horizontal_padding">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/feature_user_profile_label_nickname"
                                android:textColor="@color/feature_user_profile_label"
                                android:textSize="@dimen/feature_user_profile_label_size" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@{viewModel.displayNickname(user)}"
                                android:textColor="@color/feature_user_profile_value"
                                android:textSize="@dimen/feature_user_profile_value_size"
                                tools:text="张三" />

                            <ImageView
                                android:layout_width="@dimen/feature_user_profile_chevron_size"
                                android:layout_height="@dimen/feature_user_profile_chevron_size"
                                android:layout_marginStart="@dimen/feature_user_profile_trailing_icon_spacing"
                                android:contentDescription="@null"
                                android:src="@drawable/feature_user_ic_profile_chevron_right" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/feature_user_profile_row_height"
                            android:gravity="center_vertical"
                            android:paddingStart="@dimen/feature_user_profile_row_horizontal_padding"
                            android:paddingEnd="@dimen/feature_user_profile_row_horizontal_padding">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/feature_user_profile_label_member_status"
                                android:textColor="@color/feature_user_profile_label"
                                android:textSize="@dimen/feature_user_profile_label_size" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/feature_user_profile_vip_tag_background"
                                android:drawablePadding="@dimen/feature_user_profile_vip_drawable_padding"
                                android:gravity="center_vertical"
                                android:paddingStart="@dimen/feature_user_profile_vip_horizontal_padding"
                                android:paddingTop="@dimen/feature_user_profile_vip_vertical_padding"
                                android:paddingEnd="@dimen/feature_user_profile_vip_horizontal_padding"
                                android:paddingBottom="@dimen/feature_user_profile_vip_vertical_padding"
                                android:text="@string/feature_user_profile_member_gold"
                                android:textColor="@color/feature_user_profile_vip_text"
                                android:textSize="@dimen/feature_user_profile_vip_text_size"
                                android:textStyle="bold"
                                app:drawableStartCompat="@drawable/feature_user_ic_profile_vip_badge" />

                            <ImageView
                                android:layout_width="@dimen/feature_user_profile_chevron_size"
                                android:layout_height="@dimen/feature_user_profile_chevron_size"
                                android:layout_marginStart="@dimen/feature_user_profile_trailing_icon_spacing"
                                android:contentDescription="@null"
                                android:src="@drawable/feature_user_ic_profile_chevron_right" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/accountIdRow"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/feature_user_profile_row_height"
                            android:gravity="center_vertical"
                            android:paddingStart="@dimen/feature_user_profile_row_horizontal_padding"
                            android:paddingEnd="@dimen/feature_user_profile_row_horizontal_padding">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/feature_user_profile_label_account_id"
                                android:textColor="@color/feature_user_profile_label"
                                android:textSize="@dimen/feature_user_profile_label_size" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@{viewModel.displayAccountId(user)}"
                                android:textColor="@color/feature_user_profile_value"
                                android:textSize="@dimen/feature_user_profile_account_id_size"
                                tools:text="10293847" />

                            <ImageView
                                android:id="@+id/ivCopyAccountId"
                                android:layout_width="@dimen/feature_user_profile_copy_icon_size"
                                android:layout_height="@dimen/feature_user_profile_copy_icon_size"
                                android:layout_marginStart="@dimen/feature_user_profile_copy_icon_spacing"
                                android:contentDescription="@string/feature_user_profile_copy_account_id"
                                android:src="@drawable/feature_user_ic_profile_copy" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/feature_user_profile_row_height"
                            android:gravity="center_vertical"
                            android:onClick="@{()->viewModel.changeGender()}"
                            android:paddingStart="@dimen/feature_user_profile_row_horizontal_padding"
                            android:paddingEnd="@dimen/feature_user_profile_row_horizontal_padding">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/feature_user_profile_label_gender"
                                android:textColor="@color/feature_user_profile_label"
                                android:textSize="@dimen/feature_user_profile_label_size" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@{viewModel.displayGender(user)}"
                                android:textColor="@color/feature_user_profile_value"
                                android:textSize="@dimen/feature_user_profile_value_size"
                                tools:text="男" />

                            <ImageView
                                android:layout_width="@dimen/feature_user_profile_chevron_size"
                                android:layout_height="@dimen/feature_user_profile_chevron_size"
                                android:layout_marginStart="@dimen/feature_user_profile_trailing_icon_spacing"
                                android:contentDescription="@null"
                                android:src="@drawable/feature_user_ic_profile_chevron_right" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/feature_user_profile_card_spacing"
                        android:background="@drawable/feature_user_profile_card_background"
                        android:orientation="vertical"
                        android:paddingTop="@dimen/feature_user_profile_card_vertical_padding"
                        android:paddingBottom="@dimen/feature_user_profile_card_vertical_padding">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/feature_user_profile_row_height"
                            android:gravity="center_vertical"
                            android:onClick="@{()->viewModel.changePhoneNumber()}"
                            android:paddingStart="@dimen/feature_user_profile_row_horizontal_padding"
                            android:paddingEnd="@dimen/feature_user_profile_row_horizontal_padding">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/feature_user_profile_label_phone"
                                android:textColor="@color/feature_user_profile_label"
                                android:textSize="@dimen/feature_user_profile_label_size" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@{viewModel.displayPhone(user)}"
                                android:textColor="@color/feature_user_profile_value"
                                android:textSize="@dimen/feature_user_profile_value_size"
                                tools:text="138****8888" />

                            <ImageView
                                android:layout_width="@dimen/feature_user_profile_chevron_size"
                                android:layout_height="@dimen/feature_user_profile_chevron_size"
                                android:layout_marginStart="@dimen/feature_user_profile_trailing_icon_spacing"
                                android:contentDescription="@null"
                                android:src="@drawable/feature_user_ic_profile_chevron_right" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/feature_user_profile_row_height"
                            android:gravity="center_vertical"
                            android:onClick="@{()->viewModel.changeWechat()}"
                            android:paddingStart="@dimen/feature_user_profile_row_horizontal_padding"
                            android:paddingEnd="@dimen/feature_user_profile_row_horizontal_padding">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/feature_user_profile_label_wechat"
                                android:textColor="@color/feature_user_profile_label"
                                android:textSize="@dimen/feature_user_profile_label_size" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@{viewModel.displayWechat(user)}"
                                android:textColor="@color/feature_user_profile_value"
                                android:textSize="@dimen/feature_user_profile_value_size"
                                tools:text="wx_zhangsan" />

                            <ImageView
                                android:layout_width="@dimen/feature_user_profile_chevron_size"
                                android:layout_height="@dimen/feature_user_profile_chevron_size"
                                android:layout_marginStart="@dimen/feature_user_profile_trailing_icon_spacing"
                                android:contentDescription="@null"
                                android:src="@drawable/feature_user_ic_profile_chevron_right" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/feature_user_profile_row_height"
                            android:gravity="center_vertical"
                            android:onClick="@{()->viewModel.changeQQ()}"
                            android:paddingStart="@dimen/feature_user_profile_row_horizontal_padding"
                            android:paddingEnd="@dimen/feature_user_profile_row_horizontal_padding">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/feature_user_profile_label_qq"
                                android:textColor="@color/feature_user_profile_label"
                                android:textSize="@dimen/feature_user_profile_label_size" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@{viewModel.displayQq(user)}"
                                android:textColor="@color/feature_user_profile_value"
                                android:textSize="@dimen/feature_user_profile_value_size"
                                tools:text="12345678" />

                            <ImageView
                                android:layout_width="@dimen/feature_user_profile_chevron_size"
                                android:layout_height="@dimen/feature_user_profile_chevron_size"
                                android:layout_marginStart="@dimen/feature_user_profile_trailing_icon_spacing"
                                android:contentDescription="@null"
                                android:src="@drawable/feature_user_ic_profile_chevron_right" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/feature_user_profile_card_spacing"
                        android:background="@drawable/feature_user_profile_card_background"
                        android:orientation="vertical"
                        android:paddingTop="@dimen/feature_user_profile_card_vertical_padding"
                        android:paddingBottom="@dimen/feature_user_profile_card_vertical_padding">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/feature_user_profile_row_height"
                            android:gravity="center_vertical"
                            android:onClick="@{()->viewModel.toChangePassword()}"
                            android:paddingStart="@dimen/feature_user_profile_row_horizontal_padding"
                            android:paddingEnd="@dimen/feature_user_profile_row_horizontal_padding">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/feature_user_profile_change_password"
                                android:textColor="@color/feature_user_profile_label"
                                android:textSize="@dimen/feature_user_profile_label_size" />

                            <ImageView
                                android:layout_width="@dimen/feature_user_profile_chevron_size"
                                android:layout_height="@dimen/feature_user_profile_chevron_size"
                                android:contentDescription="@null"
                                android:src="@drawable/feature_user_ic_profile_chevron_right" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/feature_user_profile_row_height"
                            android:gravity="center_vertical"
                            android:onClick="@{()->viewModel.toDeleteAccountConfirm()}"
                            android:paddingStart="@dimen/feature_user_profile_row_horizontal_padding"
                            android:paddingEnd="@dimen/feature_user_profile_row_horizontal_padding">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/feature_user_profile_delete_account"
                                android:textColor="@color/feature_user_profile_delete"
                                android:textSize="@dimen/feature_user_profile_label_size" />

                            <ImageView
                                android:layout_width="@dimen/feature_user_profile_chevron_size"
                                android:layout_height="@dimen/feature_user_profile_chevron_size"
                                android:contentDescription="@null"
                                android:src="@drawable/feature_user_ic_profile_chevron_right" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>
</layout>

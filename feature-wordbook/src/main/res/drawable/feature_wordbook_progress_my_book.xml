<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <solid android:color="@color/feature_wordbook_my_book_progress_background" />
            <corners android:radius="@dimen/feature_wordbook_my_book_progress_corner_radius" />
        </shape>
    </item>

    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <solid android:color="@color/feature_wordbook_my_book_progress_fill" />
                <corners android:radius="@dimen/feature_wordbook_my_book_progress_corner_radius" />
            </shape>
        </clip>
    </item>
</layer-list>

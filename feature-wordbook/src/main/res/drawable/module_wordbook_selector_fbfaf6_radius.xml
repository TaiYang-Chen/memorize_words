<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 按下状态 -->
    <item android:state_pressed="true">
        <shape>
            <corners android:radius="8dp" />
            <solid android:color="@color/feature_wordbook_study_plan_secondary_action_background" />
            <stroke
                android:width="1dp"
                android:color="@color/feature_wordbook_study_plan_secondary_action_stroke" />
        </shape>
    </item>

    <!-- 默认状态（未按下） -->
    <item>
        <shape>
            <corners android:radius="8dp" />
            <solid android:color="@color/feature_wordbook_study_plan_secondary_action_background" />
            <stroke
                android:width="1dp"
                android:color="@color/feature_wordbook_study_plan_secondary_action_stroke" />
        </shape>
    </item>
</selector>

<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape>
            <solid android:color="#EAF4FF" />
            <stroke android:width="1dp" android:color="@color/feature_wordbook_word_list_primary" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/feature_wordbook_word_list_surface" />
            <stroke android:width="1dp" android:color="@color/feature_wordbook_word_list_divider" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>

<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="vm"
            type="com.chen.memorizewords.feature.wordbook.plan.ModifyPlanDialogViewModel" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/module_wordbook_bottom_dialog_bg"
        android:orientation="vertical">

        <View
            android:layout_width="@dimen/core_ui_dp_40"
            android:layout_height="@dimen/core_ui_dp_6"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/core_ui_dp_8"
            android:background="@drawable/module_wordbook_bg_drag_handle" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="@dimen/core_ui_dp_24"
            android:paddingTop="@dimen/core_ui_dp_16"
            android:paddingEnd="@dimen/core_ui_dp_24"
            android:text="修改计划"
            android:textColor="#000"
            android:textSize="@dimen/core_ui_text_18"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="@dimen/core_ui_dp_24"
            android:paddingTop="@dimen/core_ui_dp_32"
            android:paddingEnd="@dimen/core_ui_dp_24">

            <TextView
                android:id="@+id/tvNewWord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="每日新词数"
                android:textColor="#000"
                android:textSize="@dimen/core_ui_text_14"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="推荐 15~30"
                android:textSize="@dimen/core_ui_text_11" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="@dimen/core_ui_dp_24"
            android:paddingTop="@dimen/core_ui_dp_16"
            android:paddingEnd="@dimen/core_ui_dp_24">

            <ImageView
                android:id="@+id/btnMinus"
                android:layout_width="@dimen/core_ui_dp_40"
                android:layout_height="@dimen/core_ui_dp_40"
                android:background="@drawable/module_wordbook_bg_multi_normal"
                android:onClick="@{() -> vm.decrementDailyNewCount()}"
                android:padding="@dimen/core_ui_dp_13"
                android:src="@drawable/module_wordbook_ic_minus" />

            <EditText
                android:id="@+id/tvCount"
                android:layout_width="0dp"
                android:layout_height="@dimen/core_ui_dp_40"
                android:layout_marginHorizontal="@dimen/core_ui_dp_12"
                android:layout_weight="1"
                android:background="@drawable/module_wordbook_bg_count_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="3"
                android:text="@={vm.dailyNewCount}"
                android:textSize="@dimen/core_ui_text_18"
                android:textStyle="bold"
                tools:text="15" />

            <ImageView
                android:id="@+id/btnPlus"
                android:layout_width="@dimen/core_ui_dp_40"
                android:layout_height="@dimen/core_ui_dp_40"
                android:background="@drawable/module_wordbook_bg_multi_normal"
                android:onClick="@{() -> vm.incrementDailyNewCount()}"
                android:padding="@dimen/core_ui_dp_13"
                android:src="@drawable/module_wordbook_ic_add" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="@dimen/core_ui_dp_24"
            android:paddingTop="@dimen/core_ui_dp_32"
            android:paddingEnd="@dimen/core_ui_dp_24">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="每日复习数"
                android:textColor="#000"
                android:textSize="@dimen/core_ui_text_14"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="推荐 30~60"
                android:textSize="@dimen/core_ui_text_11" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="@dimen/core_ui_dp_24"
            android:paddingTop="@dimen/core_ui_dp_16"
            android:paddingEnd="@dimen/core_ui_dp_24">

            <ImageView
                android:layout_width="@dimen/core_ui_dp_40"
                android:layout_height="@dimen/core_ui_dp_40"
                android:background="@drawable/module_wordbook_bg_multi_normal"
                android:onClick="@{() -> vm.decrementDailyReviewCount()}"
                android:padding="@dimen/core_ui_dp_13"
                android:src="@drawable/module_wordbook_ic_minus" />

            <EditText
                android:layout_width="0dp"
                android:layout_height="@dimen/core_ui_dp_40"
                android:layout_marginHorizontal="@dimen/core_ui_dp_12"
                android:layout_weight="1"
                android:background="@drawable/module_wordbook_bg_count_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="3"
                android:text="@={vm.dailyReviewCount}"
                android:textSize="@dimen/core_ui_text_18"
                android:textStyle="bold"
                tools:text="15" />

            <ImageView
                android:layout_width="@dimen/core_ui_dp_40"
                android:layout_height="@dimen/core_ui_dp_40"
                android:background="@drawable/module_wordbook_bg_multi_normal"
                android:onClick="@{() -> vm.incrementDailyReviewCount()}"
                android:padding="@dimen/core_ui_dp_13"
                android:src="@drawable/module_wordbook_ic_add" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnConfirm"
            android:layout_width="match_parent"
            android:layout_height="@dimen/core_ui_dp_48"
            android:layout_marginStart="@dimen/core_ui_dp_24"
            android:layout_marginTop="@dimen/core_ui_dp_32"
            android:layout_marginEnd="@dimen/core_ui_dp_24"
            android:layout_marginBottom="@dimen/core_ui_dp_32"
            android:background="@drawable/module_wordbook_bg_confirm"
            android:gravity="center"
            android:onClick="@{() -> vm.confirmModify()}"
            android:text="确认"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/core_ui_text_16"
            android:textStyle="bold" />

    </LinearLayout>
</layout>

<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="com.chen.memorizewords.feature.wordbook.my.MyWordBooksViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:padding="@dimen/feature_wordbook_my_books_page_padding">

        <FrameLayout
            android:id="@+id/header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/title_margin"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="@dimen/title_icon_size"
                android:layout_height="@dimen/title_icon_size"
                android:layout_gravity="center_vertical"
                android:onClick="@{()->viewModel.back()}"
                android:src="@drawable/ic_arrow_back" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="@dimen/feature_wordbook_create_header_action_size"
                android:layout_marginEnd="@dimen/feature_wordbook_create_header_action_size"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/module_wordbook_nav_my_books_title"
                android:textColor="#000000"
                android:textSize="@dimen/title_text_size"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="@dimen/feature_wordbook_create_header_action_size"
                android:layout_height="@dimen/feature_wordbook_create_header_action_size"
                android:layout_gravity="center_vertical|end"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/feature_wordbook_create_title"
                android:onClick="@{()->viewModel.onCreateWordBookClick()}">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/module_wordbook_ic_add" />
            </FrameLayout>
        </FrameLayout>

        <RadioGroup
            android:id="@+id/radioGroupFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/feature_wordbook_my_books_filter_margin_top"
            android:background="@drawable/feature_wordbook_bg_my_books_filter_group"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header">

            <RadioButton
                android:id="@+id/btnAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/feature_wordbook_bg_my_books_filter_item_selector"
                android:button="@null"
                android:checked="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:minWidth="0dp"
                android:minHeight="4dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:paddingStart="@dimen/feature_wordbook_my_books_filter_padding_horizontal"
                android:paddingEnd="@dimen/feature_wordbook_my_books_filter_padding_horizontal"
                android:text="&#20840;&#37096;"
                android:textColor="@drawable/feature_wordbook_my_books_filter_text_selector"
                android:textSize="@dimen/feature_wordbook_my_books_filter_text_size"
                android:textStyle="bold" />

            <RadioButton
                android:id="@+id/btnStudying"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/feature_wordbook_my_books_filter_spacing"
                android:background="@drawable/feature_wordbook_bg_my_books_filter_item_selector"
                android:button="@null"
                android:gravity="center"
                android:includeFontPadding="false"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:paddingStart="@dimen/feature_wordbook_my_books_filter_padding_horizontal"
                android:paddingEnd="@dimen/feature_wordbook_my_books_filter_padding_horizontal"
                android:text="&#27491;&#22312;&#23398;&#20064;"
                android:textColor="@drawable/feature_wordbook_my_books_filter_text_selector"
                android:textSize="@dimen/feature_wordbook_my_books_filter_text_size"
                android:textStyle="bold" />

            <RadioButton
                android:id="@+id/btnCompleted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/feature_wordbook_my_books_filter_spacing"
                android:background="@drawable/feature_wordbook_bg_my_books_filter_item_selector"
                android:button="@null"
                android:gravity="center"
                android:includeFontPadding="false"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:paddingStart="@dimen/feature_wordbook_my_books_filter_padding_horizontal"
                android:paddingEnd="@dimen/feature_wordbook_my_books_filter_padding_horizontal"
                android:text="&#24050;&#23436;&#25104;"
                android:textColor="@drawable/feature_wordbook_my_books_filter_text_selector"
                android:textSize="@dimen/feature_wordbook_my_books_filter_text_size"
                android:textStyle="bold" />
        </RadioGroup>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            app:layout_constraintBottom_toTopOf="@id/btnAddWordBook"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/radioGroupFilter"
            tools:listitem="@layout/module_wordbook_item_wordbook" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddWordBook"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/feature_wordbook_my_books_content_to_button_spacing"
            android:layout_marginBottom="@dimen/feature_wordbook_my_books_primary_action_margin_bottom"
            android:background="@drawable/feature_wordbook_bg_my_books_add_button"
            android:backgroundTint="@null"
            android:drawablePadding="12dp"
            android:gravity="center"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:onClick="@{()->viewModel.onPickShopFragment()}"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="&#28155;&#21152;&#26032;&#35789;&#27719;&#20070;"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/feature_wordbook_my_books_primary_action_text_size"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>

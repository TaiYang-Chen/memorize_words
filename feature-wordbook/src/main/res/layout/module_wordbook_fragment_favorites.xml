<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.chen.memorizewords.feature.wordbook.favorites.FavoritesViewModel" />

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/feature_wordbook_favorites_page_background"
        android:orientation="vertical"
        android:padding="@dimen/page_margin">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/title_height"
            android:layout_marginTop="@dimen/title_margin"
            android:layout_marginBottom="@dimen/core_ui_dp_12">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="@dimen/title_icon_touch_size"
                android:layout_height="@dimen/title_icon_touch_size"
                android:layout_gravity="center_vertical|start"
                android:padding="@dimen/core_ui_dp_7"
                android:onClick="@{()->viewModel.back()}"
                android:src="@drawable/ic_arrow_back" />

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:gravity="center"
                android:text="@string/feature_wordbook_favorites_title"
                android:textColor="#000000"
                android:textSize="@dimen/title_text_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnSelectionCancel"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/core_ui_dp_36"
                android:layout_gravity="center_vertical|start"
                android:gravity="center"
                android:minWidth="@dimen/core_ui_dp_48"
                android:text="@string/feature_wordbook_favorites_cancel"
                android:textColor="@color/feature_wordbook_favorites_text_secondary"
                android:textSize="@dimen/core_ui_text_15"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tvSelectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:gravity="center"
                android:textColor="#000000"
                android:textSize="@dimen/title_text_size"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="已选择 2 项"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/btnSelectionDelete"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/core_ui_dp_36"
                android:layout_gravity="center_vertical|end"
                android:gravity="center"
                android:minWidth="@dimen/core_ui_dp_48"
                android:text="@string/feature_wordbook_favorites_delete"
                android:textColor="@color/feature_wordbook_favorites_delete_background"
                android:textSize="@dimen/core_ui_text_15"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="@dimen/core_ui_dp_24"
                tools:listitem="@layout/module_wordbook_fragment_favorites_item" />

            <TextView
                android:id="@+id/emptyView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="@string/feature_wordbook_favorites_empty"
                android:textColor="@color/feature_wordbook_favorites_date_text"
                android:textSize="@dimen/core_ui_text_15"
                android:visibility="gone"
                tools:visibility="visible" />
        </FrameLayout>
    </LinearLayout>
</layout>

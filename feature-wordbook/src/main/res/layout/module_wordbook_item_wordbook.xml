<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="info"
            type="com.chen.memorizewords.domain.wordbook.model.WordBookInfo" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/rootCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="@dimen/feature_wordbook_my_book_card_corner_radius"
        app:cardUseCompatPadding="false"
        app:strokeWidth="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/feature_wordbook_my_book_card_padding_horizontal">

            <FrameLayout
                android:id="@+id/coverContainer"
                android:layout_width="@dimen/feature_wordbook_my_book_cover_width"
                android:layout_height="@dimen/feature_wordbook_my_book_cover_height"
                android:background="@drawable/feature_wordbook_bg_my_book_cover"
                android:clipToOutline="true"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/ivCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    tools:src="@drawable/module_wordbook_ic_book"
                    tools:visibility="visible" />

                <ImageView
                    android:id="@+id/ivCoverFallback"
                    android:layout_width="@dimen/feature_wordbook_my_book_cover_fallback_size"
                    android:layout_height="@dimen/feature_wordbook_my_book_cover_fallback_size"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/module_wordbook_ic_book" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/feature_wordbook_bg_my_book_status"
                android:gravity="center"
                android:includeFontPadding="false"
                android:paddingTop="@dimen/core_ui_dp_4"
                android:paddingBottom="@dimen/core_ui_dp_4"
                android:paddingStart="@dimen/feature_wordbook_my_book_status_padding_horizontal"
                android:paddingEnd="@dimen/feature_wordbook_my_book_status_padding_horizontal"
                android:text="正在学习"
                android:textColor="@color/feature_wordbook_my_book_status_text"
                android:textSize="@dimen/feature_wordbook_my_book_status_text_size"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintEnd_toStartOf="@id/btnDelete"
                app:layout_constraintTop_toTopOf="parent"
                tools:visibility="visible" />


            <TextView
                android:id="@+id/btnDelete"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:includeFontPadding="false"
                android:paddingTop="@dimen/core_ui_dp_4"
                android:paddingBottom="@dimen/core_ui_dp_4"
                android:paddingStart="@dimen/feature_wordbook_my_book_status_padding_horizontal"
                android:paddingEnd="@dimen/feature_wordbook_my_book_status_padding_horizontal"
                android:text="删除"
                android:textColor="#FF0000"
                android:textSize="@dimen/feature_wordbook_my_book_status_text_size"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/feature_wordbook_my_book_content_spacing"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="@color/feature_wordbook_my_book_title"
                android:textSize="@dimen/feature_wordbook_my_book_title_text_size"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/tvStatus"
                app:layout_constraintStart_toEndOf="@id/coverContainer"
                app:layout_constraintTop_toTopOf="@id/coverContainer"
                app:layout_goneMarginEnd="@dimen/core_ui_dp_8"
                tools:text="IELTS Core Words" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/feature_wordbook_my_book_content_spacing"
                android:layout_marginTop="@dimen/feature_wordbook_my_book_subtitle_margin_top"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="2"
                android:textColor="@color/feature_wordbook_my_book_subtitle"
                android:textSize="@dimen/feature_wordbook_my_book_subtitle_text_size"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/coverContainer"
                app:layout_constraintTop_toBottomOf="@id/tvTitle"
                tools:text="Cambridge selected word bank" />

            <LinearLayout
                android:id="@+id/statsRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/feature_wordbook_my_book_content_spacing"
                android:layout_marginTop="@dimen/feature_wordbook_my_book_stats_margin_top"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintBottom_toTopOf="@id/progressStudy"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/coverContainer">

                <TextView
                    android:id="@+id/tvProgressLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:includeFontPadding="false"
                    android:textColor="@color/feature_wordbook_my_book_stats"
                    android:textSize="@dimen/feature_wordbook_my_book_stats_text_size"
                    tools:text="Learned: 1200 / 3000" />

                <TextView
                    android:id="@+id/tvMasteredLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:textColor="@color/feature_wordbook_my_book_stats"
                    android:textSize="@dimen/feature_wordbook_my_book_stats_text_size"
                    tools:text="Mastered: 800" />
            </LinearLayout>

            <com.chen.memorizewords.feature.wordbook.custom.MultiProgressView
                android:id="@+id/progressStudy"
                android:layout_width="0dp"
                android:layout_height="@dimen/feature_wordbook_my_book_progress_height"
                android:layout_marginStart="@dimen/feature_wordbook_my_book_content_spacing"
                android:layout_marginTop="@dimen/feature_wordbook_my_book_progress_margin_top"
                app:bgColor="@color/feature_wordbook_my_book_progress_background"
                app:layout_constraintBottom_toBottomOf="@id/coverContainer"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/coverContainer"
                app:progress1Color="@color/feature_wordbook_my_book_progress_learning_fill"
                app:progress2Color="@color/feature_wordbook_my_book_progress_fill" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>

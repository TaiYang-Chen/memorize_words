<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="vm"
            type="com.chen.memorizewords.feature.wordbook.wordlist.WordListViewModel" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/feature_wordbook_word_list_page_background"
        android:orientation="vertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/feature_wordbook_word_list_surface"
            android:paddingStart="20dp"
            android:paddingTop="@dimen/title_margin"
            android:paddingEnd="20dp"
            android:paddingBottom="10dp">

            <FrameLayout
                android:id="@+id/layoutToolbar"
                android:layout_width="0dp"
                android:layout_height="@dimen/title_height"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="@dimen/title_icon_touch_size"
                    android:layout_height="@dimen/title_icon_touch_size"
                    android:layout_gravity="center_vertical|start"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="返回"
                    android:onClick="@{()->vm.back()}"
                    android:padding="7dp"
                    android:src="@drawable/ic_arrow_back" />

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:paddingStart="48dp"
                    android:paddingEnd="48dp"
                    android:textColor="@color/feature_wordbook_word_text_primary"
                    android:textSize="@dimen/title_text_size"
                    android:textStyle="bold"
                    tools:text="CET4 四级词汇" />

                <ImageButton
                    android:id="@+id/btnSort"
                    android:layout_width="@dimen/title_icon_touch_size"
                    android:layout_height="@dimen/title_icon_touch_size"
                    android:layout_gravity="center_vertical|end"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="排序"
                    android:padding="7dp"
                    android:src="@drawable/feature_wordbook_ic_sort" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvSummary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="@color/feature_wordbook_word_text_tertiary"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layoutToolbar"
                tools:text="共 4532 词 · 已学 120 · 待复习 18" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/feature_wordbook_word_list_surface"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:id="@+id/layoutSearch"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/feature_wordbook_bg_word_search"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/feature_wordbook_ic_shop_search" />

                <EditText
                    android:id="@+id/editSearch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="搜索单词或释义"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textColor="@color/feature_wordbook_word_text_primary"
                    android:textColorHint="@color/feature_wordbook_word_text_tertiary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/btnClearSearch"
                    android:layout_width="40dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="清除"
                    android:textColor="@color/feature_wordbook_word_text_tertiary"
                    android:textSize="12sp"
                    android:visibility="gone"
                    tools:visibility="visible" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layoutFilters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chipAll"
                        style="@style/FeatureWordBookWordListChip"
                        android:text="全部" />

                    <TextView
                        android:id="@+id/chipToLearn"
                        style="@style/FeatureWordBookWordListChip"
                        android:text="未学" />

                    <TextView
                        android:id="@+id/chipLearned"
                        style="@style/FeatureWordBookWordListChip"
                        android:text="已学" />

                    <TextView
                        android:id="@+id/chipMastered"
                        style="@style/FeatureWordBookWordListChip"
                        android:text="掌握" />

                    <TextView
                        android:id="@+id/chipReview"
                        style="@style/FeatureWordBookWordListChip"
                        android:text="待复习" />

                    <TextView
                        android:id="@+id/chipFavorite"
                        style="@style/FeatureWordBookWordListChip"
                        android:text="重点词" />
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tvSortLabel"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/feature_wordbook_bg_word_status_neutral"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textColor="@color/feature_wordbook_word_text_tertiary"
                android:textSize="11sp"
                tools:text="默认词书顺序" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:id="@+id/layoutEmpty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/tvEmptyTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="暂无单词"
                    android:textColor="@color/feature_wordbook_word_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvEmptySubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="换个筛选条件试试"
                    android:textColor="@color/feature_wordbook_word_text_tertiary"
                    android:textSize="13sp" />
            </LinearLayout>

            <com.chen.memorizewords.feature.wordbook.custom.FastIndexView
                android:id="@+id/fastIndexView"
                android:layout_width="24dp"
                android:layout_height="match_parent"
                android:layout_gravity="end" />
        </FrameLayout>
    </LinearLayout>
</layout>

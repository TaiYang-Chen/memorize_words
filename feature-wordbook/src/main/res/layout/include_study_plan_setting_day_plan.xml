<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="androidx.core.text.HtmlCompat" />
        <variable
            name="viewmodel"
            type="com.chen.memorizewords.feature.wordbook.plan.StudyPlanSettingViewModel" />
    </data>

    <!-- 主卡片容器 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/dailyPlanCard"
        android:layout_width="match_parent"
        app:cardBackgroundColor="#FDFDFD"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <!-- 标题：每日计划 -->
                    <TextView
                        android:id="@+id/titleTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="每日计划"
                        android:textColor="#000000"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- 预计完成时间 -->
                    <TextView
                        android:id="@+id/daysTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif"
                        android:text='@{HtmlCompat.fromHtml("预计 &lt;font color=\"#FF9800\"&gt;&lt;b&gt;&lt;big&gt;"+(viewmodel.wordBookCardState.remainWords / (viewmodel.planCountCardState.dailyNewCount == 0 ? 1: viewmodel.planCountCardState.dailyNewCount ))+"&lt;/big&gt;&lt;/b&gt;&lt;/font&gt; 天后完成计划", HtmlCompat.FROM_HTML_MODE_LEGACY)}'
                        android:textColor="#666666"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="@id/titleTextView"
                        app:layout_constraintTop_toBottomOf="@id/titleTextView"
                        tools:text="预计214天后完成计划" />

                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:onClick="@{()->viewmodel.onPickChangeStudyCount()}"
                    app:cardBackgroundColor="@color/module_wordbook_light_gray"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/editIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:padding="10dp"
                        android:src="@drawable/module_wordbook_ic_edit"
                        app:layout_constraintBottom_toBottomOf="@+id/daysTextView"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/titleTextView" />
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/module_wordbook_light_gray"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/newWordsLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <!-- 绿色图标容器 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <!-- 这里可以放置实际的图标，暂时用文本代替 -->
                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_marginEnd="4dp"
                                android:src="@drawable/module_wordbook_ic_potted_plant" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif"
                                android:text="新学单词"
                                android:textColor="#666666"
                                android:textSize="11sp" />
                        </LinearLayout>


                        <!-- 数值文本 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="horizontal">

                            <!-- 巨大的数字"15" -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-black"
                                android:includeFontPadding="false"
                                android:letterSpacing="-0.05"
                                android:text="@{String.valueOf(viewmodel.planCountCardState.dailyNewCount)}"
                                android:textColor="#000000"
                                android:textSize="32sp"
                                android:textStyle="bold"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                tools:text="15" />

                            <!-- 右下方的小字"词/天" -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.8"
                                android:fontFamily="sans-serif"
                                android:text=" 词/天"
                                android:textColor="#888888"
                                android:textSize="11sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:id="@+id/verticalDivider"
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#F0F0F0"
                        app:layout_constraintBottom_toBottomOf="@id/newWordsLayout"
                        app:layout_constraintEnd_toStartOf="@id/reviewLayout"
                        app:layout_constraintStart_toEndOf="@id/newWordsLayout"
                        app:layout_constraintTop_toTopOf="@id/newWordsLayout" />

                    <LinearLayout
                        android:id="@+id/reviewLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/verticalDivider"
                        app:layout_constraintTop_toTopOf="@id/newWordsLayout">
                        <!-- 绿色图标容器 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <!-- 这里可以放置实际的图标，暂时用文本代替 -->
                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_marginEnd="4dp"
                                android:src="@drawable/module_wordbook_ic_clockwise_direction" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif"
                                android:text="复习上线"
                                android:textColor="#666666"
                                android:textSize="11sp" />
                        </LinearLayout>


                        <!-- 数值文本 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="horizontal">

                            <!-- 巨大的数字"15" -->
                            <TextView
                                android:id="@+id/numberText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-black"
                                android:includeFontPadding="false"
                                android:letterSpacing="-0.05"
                                android:text="@{String.valueOf(viewmodel.planCountCardState.dailyReviewCount)}"
                                android:textColor="#000000"
                                android:textSize="32sp"
                                android:textStyle="bold"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                tools:text="15" />

                            <!-- 右下方的小字"词/天" -->
                            <TextView
                                android:id="@+id/unitText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.8"
                                android:fontFamily="sans-serif"
                                android:text=" 词/天"
                                android:textColor="#888888"
                                android:textSize="11sp" />

                        </LinearLayout>
                    </LinearLayout>


                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</layout>
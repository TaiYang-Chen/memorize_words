<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data />

    <LinearLayout
        android:id="@+id/rootContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/feature_wordbook_favorites_card_spacing"
        android:background="@drawable/feature_wordbook_bg_favorites_card"
        android:clickable="true"
        android:elevation="@dimen/core_ui_dp_2"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:minHeight="@dimen/feature_wordbook_favorites_card_min_height"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/feature_wordbook_favorites_card_padding_horizontal"
        android:paddingVertical="@dimen/feature_wordbook_favorites_card_padding_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvWord"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="@color/feature_wordbook_favorites_text_primary"
                android:textSize="@dimen/feature_wordbook_favorites_word_text_size"
                android:textStyle="bold"
                tools:text="manufacture" />

            <TextView
                android:id="@+id/tvMeaning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/core_ui_dp_9"
                android:ellipsize="end"
                android:lineSpacingExtra="@dimen/core_ui_dp_2"
                android:maxLines="2"
                android:textColor="@color/feature_wordbook_favorites_text_secondary"
                android:textSize="@dimen/feature_wordbook_favorites_meaning_text_size"
                tools:text="v. 生产 n. 制成品" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivSelection"
            android:layout_width="@dimen/feature_wordbook_favorites_selection_size"
            android:layout_height="@dimen/feature_wordbook_favorites_selection_size"
            android:layout_marginStart="@dimen/core_ui_dp_12"
            android:background="@drawable/module_wordbook_white_radio_16dp_not_border"
            android:contentDescription="@null"
            android:visibility="gone"
            tools:src="@drawable/module_wordbook_ic_check_circle"
            tools:visibility="visible" />
    </LinearLayout>
</layout>

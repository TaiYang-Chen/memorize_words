<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewmodel"
            type="com.chen.memorizewords.feature.wordbook.plan.StudyPlanSettingViewModel" />

        <variable
            name="wordBookCardState"
            type="com.chen.memorizewords.feature.wordbook.plan.StudyPlanWordBookCardState" />

    </data>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/feature_wordbook_study_plan_page_background"
        android:padding="@dimen/page_margin"
        tools:context=".ui.home.HomeFragment">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/title_margin"
                android:layout_marginBottom="@dimen/core_ui_dp_16"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/title_icon_size"
                    android:layout_height="@dimen/title_icon_size"
                    android:layout_gravity="center_vertical"
                    android:onClick="@{()->viewmodel.back()}"
                    android:src="@drawable/ic_arrow_back" />

                <TextView
                    android:id="@+id/textView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:gravity="center"
                    android:text="@string/module_wordbook_nav_study_plan_title"
                    android:textColor="@color/feature_wordbook_study_plan_text_primary"
                    android:textSize="@dimen/title_text_size"
                    android:textStyle="bold" />
            </FrameLayout>

            <include
                android:id="@+id/includeStudyPlanBook"
                layout="@layout/include_study_plan_setting_book"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/core_ui_dp_2"
                app:viewmodel="@{viewmodel}"
                app:wordBookCardState="@{wordBookCardState}" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/core_ui_dp_24"
                android:text="每日计划"
                android:textColor="@color/feature_wordbook_study_plan_text_primary"
                android:textStyle="bold" />

            <include
                layout="@layout/include_study_plan_setting_day_plan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/core_ui_dp_12"
                app:viewmodel="@{viewmodel}" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/core_ui_dp_24"
                android:text="@string/module_wordbook_mode_and_order_title"
                android:textColor="@color/feature_wordbook_study_plan_text_primary"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/core_ui_dp_12"
                app:cardBackgroundColor="@color/feature_wordbook_study_plan_option_unselected_background"
                app:cardCornerRadius="@dimen/core_ui_dp_16"
                app:cardElevation="0dp"
                app:strokeColor="@color/feature_wordbook_study_plan_secondary_action_stroke"
                app:strokeWidth="@dimen/core_ui_dp_1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/layoutStudyModeAction"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:minHeight="@dimen/core_ui_dp_56"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/core_ui_dp_16"
                        android:paddingTop="@dimen/core_ui_dp_14"
                        android:paddingEnd="@dimen/core_ui_dp_12"
                        android:paddingBottom="@dimen/core_ui_dp_14">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/module_wordbook_study_mode"
                            android:textColor="@color/feature_wordbook_study_plan_text_primary"
                            android:textSize="@dimen/core_ui_text_15" />

                        <TextView
                            android:id="@+id/tvStudyModeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/core_ui_dp_16"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/feature_wordbook_study_plan_text_secondary"
                            android:textSize="@dimen/core_ui_text_14"
                            tools:text="英汉双解" />

                        <ImageView
                            android:layout_width="@dimen/core_ui_dp_18"
                            android:layout_height="@dimen/core_ui_dp_18"
                            android:layout_marginStart="@dimen/core_ui_dp_8"
                            android:contentDescription="@null"
                            android:src="@drawable/module_wordbook_ic_chevron_right" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/core_ui_dp_1"
                        android:layout_marginStart="@dimen/core_ui_dp_16"
                        android:layout_marginEnd="@dimen/core_ui_dp_16"
                        android:background="@color/feature_wordbook_study_plan_divider" />

                    <LinearLayout
                        android:id="@+id/layoutWordOrderAction"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:minHeight="@dimen/core_ui_dp_56"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/core_ui_dp_16"
                        android:paddingTop="@dimen/core_ui_dp_14"
                        android:paddingEnd="@dimen/core_ui_dp_12"
                        android:paddingBottom="@dimen/core_ui_dp_14">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/module_wordbook_word_order"
                            android:textColor="@color/feature_wordbook_study_plan_text_primary"
                            android:textSize="@dimen/core_ui_text_15" />

                        <TextView
                            android:id="@+id/tvWordOrderValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/core_ui_dp_16"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/feature_wordbook_study_plan_text_secondary"
                            android:textSize="@dimen/core_ui_text_14"
                            tools:text="随机乱序" />

                        <ImageView
                            android:layout_width="@dimen/core_ui_dp_18"
                            android:layout_height="@dimen/core_ui_dp_18"
                            android:layout_marginStart="@dimen/core_ui_dp_8"
                            android:contentDescription="@null"
                            android:src="@drawable/module_wordbook_ic_chevron_right" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</layout>

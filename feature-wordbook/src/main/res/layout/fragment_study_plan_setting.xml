<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewmodel"
            type="com.chen.memorizewords.feature.wordbook.plan.StudyPlanSettingViewModel" />

    </data>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/feature_wordbook_study_plan_page_background"
        android:padding="@dimen/page_margin"
        tools:context=".ui.home.HomeFragment">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/title_height"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:onClick="@{()->viewmodel.back()}"
                    android:src="@drawable/ic_arrow_back" />

                <TextView
                    android:id="@+id/textView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:gravity="center"
                    android:text="@string/module_wordbook_nav_study_plan_title"
                    android:textColor="@color/feature_wordbook_study_plan_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <include
                layout="@layout/include_study_plan_setting_book"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                app:viewmodel="@{viewmodel}" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="每日计划"
                android:textColor="@color/feature_wordbook_study_plan_text_primary"
                android:textStyle="bold" />

            <include
                layout="@layout/include_study_plan_setting_day_plan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:viewmodel="@{viewmodel}" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/module_wordbook_mode_and_order_title"
                android:textColor="@color/feature_wordbook_study_plan_text_primary"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/feature_wordbook_study_plan_option_unselected_background"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/feature_wordbook_study_plan_secondary_action_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/layoutStudyModeAction"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:minHeight="56dp"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingTop="14dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/module_wordbook_study_mode"
                            android:textColor="@color/feature_wordbook_study_plan_text_primary"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tvStudyModeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/feature_wordbook_study_plan_text_secondary"
                            android:textSize="14sp"
                            tools:text="英汉双解" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginStart="8dp"
                            android:contentDescription="@null"
                            android:src="@drawable/module_wordbook_ic_chevron_right" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:background="@color/feature_wordbook_study_plan_divider" />

                    <LinearLayout
                        android:id="@+id/layoutWordOrderAction"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:minHeight="56dp"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingTop="14dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/module_wordbook_word_order"
                            android:textColor="@color/feature_wordbook_study_plan_text_primary"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tvWordOrderValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/feature_wordbook_study_plan_text_secondary"
                            android:textSize="14sp"
                            tools:text="随机乱序" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginStart="8dp"
                            android:contentDescription="@null"
                            android:src="@drawable/module_wordbook_ic_chevron_right" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</layout>

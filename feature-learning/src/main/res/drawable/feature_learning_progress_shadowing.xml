<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <solid android:color="@color/feature_learning_shadowing_progress_track" />
            <corners android:radius="@dimen/core_ui_dp_2" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <solid android:color="@color/feature_learning_shadowing_progress_fill" />
                <corners android:radius="@dimen/core_ui_dp_2" />
            </shape>
        </clip>
    </item>
</layer-list>

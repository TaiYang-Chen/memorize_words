<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="click"
            type="com.chen.memorizewords.feature.learning.adapter.OnWordClickListener" />

        <variable
            name="data"
            type="com.chen.memorizewords.domain.model.words.word.WordExample" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/text_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- 英文文本 -->
            <TextView
                android:id="@+id/english_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:textColor="#3c4654"
                android:textSize="16sp"
                app:clickableWords="@{data.englishSentence}"
                app:onWordClickListener="@{click}"
                tools:text="This type of farming is simply not sustainable." />

            <!-- 中文文本 -->
            <TextView
                android:id="@+id/chinese_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:lineSpacingExtra="2dp"
                android:text="@{data.chineseTranslation}"
                android:textColor="#77879a"
                android:textStyle="bold"
                tools:text="他表现出对压力的极强适应能力。" />
        </LinearLayout>

        <!-- 扬声器图标 -->
        <ImageView
            android:id="@+id/speaker_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="12dp"
            android:padding="3dp"
            android:src="@drawable/module_learning_ic_volume_up_gray" />
    </LinearLayout>
</layout>
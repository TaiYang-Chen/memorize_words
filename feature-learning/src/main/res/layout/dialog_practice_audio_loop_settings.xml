<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/feature_learning_bg_audio_loop_settings_sheet"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <View
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/feature_learning_bg_audio_loop_chip" />

        <TextView
            android:id="@+id/tv_settings_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:text="@string/feature_learning_audio_loop_settings_title"
            android:textColor="@color/feature_learning_audio_loop_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_settings_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="@string/feature_learning_audio_loop_settings_subtitle"
            android:textColor="@color/feature_learning_audio_loop_text_secondary"
            android:textSize="13sp" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/settings_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/card_mode"
                    style="@style/FeatureLearningAudioLoopSettingsCard">

                    <LinearLayout style="@style/FeatureLearningAudioLoopSettingsSectionHeader">

                        <View style="@style/FeatureLearningAudioLoopSettingsAccent" />

                        <LinearLayout style="@style/FeatureLearningAudioLoopSettingsSectionTextGroup">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsSectionTitle"
                                android:text="@string/feature_learning_audio_loop_settings_mode_title" />

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsSectionDesc"
                                android:text="@string/feature_learning_audio_loop_settings_mode_subtitle" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/list_mode"
                        style="@style/FeatureLearningAudioLoopSettingsList">

                        <LinearLayout
                            android:id="@+id/layout_mode_word_only"
                            style="@style/FeatureLearningAudioLoopSettingsModeRow">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowIcon"
                                android:text="W" />

                            <LinearLayout style="@style/FeatureLearningAudioLoopSettingsModeTextGroup">

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsModeTitle"
                                    android:text="@string/feature_learning_audio_loop_mode_word_only" />

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsModeDesc"
                                    android:text="@string/feature_learning_audio_loop_mode_word_only_desc" />
                            </LinearLayout>

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/radio_word_only"
                                style="@style/FeatureLearningAudioLoopSettingsRadio" />
                        </LinearLayout>

                        <View style="@style/FeatureLearningAudioLoopSettingsDivider" />

                        <LinearLayout
                            android:id="@+id/layout_mode_word_with_meaning"
                            style="@style/FeatureLearningAudioLoopSettingsModeRow">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowIcon"
                                android:text="CN" />

                            <LinearLayout style="@style/FeatureLearningAudioLoopSettingsModeTextGroup">

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsModeTitle"
                                    android:text="@string/feature_learning_audio_loop_mode_word_with_meaning" />

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsModeDesc"
                                    android:text="@string/feature_learning_audio_loop_mode_word_with_meaning_desc" />
                            </LinearLayout>

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/radio_word_with_meaning"
                                style="@style/FeatureLearningAudioLoopSettingsRadio" />
                        </LinearLayout>

                        <View style="@style/FeatureLearningAudioLoopSettingsDivider" />

                        <LinearLayout
                            android:id="@+id/layout_mode_word_with_example"
                            style="@style/FeatureLearningAudioLoopSettingsModeRow">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowIcon"
                                android:text="Ex" />

                            <LinearLayout style="@style/FeatureLearningAudioLoopSettingsModeTextGroup">

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsModeTitle"
                                    android:text="@string/feature_learning_audio_loop_mode_word_with_example" />

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsModeDesc"
                                    android:text="@string/feature_learning_audio_loop_mode_word_with_example_desc" />
                            </LinearLayout>

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/radio_word_with_example"
                                style="@style/FeatureLearningAudioLoopSettingsRadio" />
                        </LinearLayout>

                        <View style="@style/FeatureLearningAudioLoopSettingsDivider" />

                        <LinearLayout
                            android:id="@+id/layout_mode_dictation"
                            style="@style/FeatureLearningAudioLoopSettingsModeRow">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowIcon"
                                android:text="Di" />

                            <LinearLayout style="@style/FeatureLearningAudioLoopSettingsModeTextGroup">

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsModeTitle"
                                    android:text="@string/feature_learning_audio_loop_mode_dictation" />

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsModeDesc"
                                    android:text="@string/feature_learning_audio_loop_mode_dictation_desc" />
                            </LinearLayout>

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/radio_dictation"
                                style="@style/FeatureLearningAudioLoopSettingsRadio" />
                        </LinearLayout>

                        <View style="@style/FeatureLearningAudioLoopSettingsDivider" />

                        <LinearLayout
                            android:id="@+id/layout_mode_full_detail"
                            style="@style/FeatureLearningAudioLoopSettingsModeRow">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowIcon"
                                android:text="All" />

                            <LinearLayout style="@style/FeatureLearningAudioLoopSettingsModeTextGroup">

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsModeTitle"
                                    android:text="@string/feature_learning_audio_loop_mode_full_detail" />

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsModeDesc"
                                    android:text="@string/feature_learning_audio_loop_mode_full_detail_desc" />
                            </LinearLayout>

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/radio_full_detail"
                                style="@style/FeatureLearningAudioLoopSettingsRadio" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/card_params"
                    style="@style/FeatureLearningAudioLoopSettingsCard"
                    android:layout_marginTop="14dp">

                    <LinearLayout style="@style/FeatureLearningAudioLoopSettingsSectionHeader">

                        <View style="@style/FeatureLearningAudioLoopSettingsAccent" />

                        <LinearLayout style="@style/FeatureLearningAudioLoopSettingsSectionTextGroup">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsSectionTitle"
                                android:text="@string/feature_learning_audio_loop_settings_params_title" />

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsSectionDesc"
                                android:text="@string/feature_learning_audio_loop_settings_params_subtitle" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/list_params"
                        style="@style/FeatureLearningAudioLoopSettingsList">

                        <LinearLayout
                            android:id="@+id/layout_param_play_times"
                            style="@style/FeatureLearningAudioLoopSettingsRow">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowIcon"
                                android:text="N" />

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowTitle"
                                android:text="@string/feature_learning_audio_loop_settings_play_times" />

                            <TextView
                                android:id="@+id/tv_play_times_value"
                                style="@style/FeatureLearningAudioLoopSettingsRowValue" />

                            <ImageView style="@style/FeatureLearningAudioLoopSettingsRowArrow" />
                        </LinearLayout>

                        <View style="@style/FeatureLearningAudioLoopSettingsDivider" />

                        <LinearLayout
                            android:id="@+id/layout_param_word_repeat"
                            style="@style/FeatureLearningAudioLoopSettingsRow">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowIcon"
                                android:text="W" />

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowTitle"
                                android:text="@string/feature_learning_audio_loop_settings_word_repeat" />

                            <TextView
                                android:id="@+id/tv_word_repeat_value"
                                style="@style/FeatureLearningAudioLoopSettingsRowValue" />

                            <ImageView style="@style/FeatureLearningAudioLoopSettingsRowArrow" />
                        </LinearLayout>

                        <View style="@style/FeatureLearningAudioLoopSettingsDivider" />

                        <LinearLayout
                            android:id="@+id/layout_param_example_repeat"
                            style="@style/FeatureLearningAudioLoopSettingsRow">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowIcon"
                                android:text="Ex" />

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowTitle"
                                android:text="@string/feature_learning_audio_loop_settings_example_repeat" />

                            <TextView
                                android:id="@+id/tv_example_repeat_value"
                                style="@style/FeatureLearningAudioLoopSettingsRowValue" />

                            <ImageView style="@style/FeatureLearningAudioLoopSettingsRowArrow" />
                        </LinearLayout>

                        <View style="@style/FeatureLearningAudioLoopSettingsDivider" />

                        <LinearLayout
                            android:id="@+id/layout_param_interval"
                            style="@style/FeatureLearningAudioLoopSettingsRow">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowIcon"
                                android:text="P" />

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowTitle"
                                android:text="@string/feature_learning_audio_loop_settings_interval" />

                            <TextView
                                android:id="@+id/tv_interval_value"
                                style="@style/FeatureLearningAudioLoopSettingsRowValue" />

                            <ImageView style="@style/FeatureLearningAudioLoopSettingsRowArrow" />
                        </LinearLayout>

                        <View style="@style/FeatureLearningAudioLoopSettingsDivider" />

                        <LinearLayout
                            android:id="@+id/layout_param_dictation_pause"
                            style="@style/FeatureLearningAudioLoopSettingsRow">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowIcon"
                                android:text="Di" />

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowTitle"
                                android:text="@string/feature_learning_audio_loop_settings_dictation_pause" />

                            <TextView
                                android:id="@+id/tv_dictation_pause_value"
                                style="@style/FeatureLearningAudioLoopSettingsRowValue" />

                            <ImageView style="@style/FeatureLearningAudioLoopSettingsRowArrow" />
                        </LinearLayout>

                        <View style="@style/FeatureLearningAudioLoopSettingsDivider" />

                        <LinearLayout
                            android:id="@+id/layout_param_reveal_delay"
                            style="@style/FeatureLearningAudioLoopSettingsRow">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowIcon"
                                android:text="A" />

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowTitle"
                                android:text="@string/feature_learning_audio_loop_settings_reveal_delay" />

                            <TextView
                                android:id="@+id/tv_reveal_delay_value"
                                style="@style/FeatureLearningAudioLoopSettingsRowValue" />

                            <ImageView style="@style/FeatureLearningAudioLoopSettingsRowArrow" />
                        </LinearLayout>

                        <View style="@style/FeatureLearningAudioLoopSettingsDivider" />

                        <LinearLayout
                            android:id="@+id/layout_param_timed_stop"
                            style="@style/FeatureLearningAudioLoopSettingsRow">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowIcon"
                                android:text="T" />

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowTitle"
                                android:text="@string/feature_learning_audio_loop_settings_timed_stop" />

                            <TextView
                                android:id="@+id/tv_timed_stop_value"
                                style="@style/FeatureLearningAudioLoopSettingsRowValue" />

                            <ImageView style="@style/FeatureLearningAudioLoopSettingsRowArrow" />
                        </LinearLayout>

                        <View style="@style/FeatureLearningAudioLoopSettingsDivider" />

                        <LinearLayout
                            android:id="@+id/layout_param_speed"
                            style="@style/FeatureLearningAudioLoopSettingsRow">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowIcon"
                                android:text="X" />

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowTitle"
                                android:text="@string/feature_learning_audio_loop_settings_speed" />

                            <TextView
                                android:id="@+id/tv_speed_value"
                                style="@style/FeatureLearningAudioLoopSettingsRowValue" />

                            <ImageView style="@style/FeatureLearningAudioLoopSettingsRowArrow" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/card_other"
                    style="@style/FeatureLearningAudioLoopSettingsCard"
                    android:layout_marginTop="14dp">

                    <LinearLayout style="@style/FeatureLearningAudioLoopSettingsSectionHeader">

                        <View style="@style/FeatureLearningAudioLoopSettingsAccent" />

                        <LinearLayout style="@style/FeatureLearningAudioLoopSettingsSectionTextGroup">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsSectionTitle"
                                android:text="@string/feature_learning_audio_loop_settings_other_title" />

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsSectionDesc"
                                android:text="@string/feature_learning_audio_loop_settings_other_subtitle" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/list_other"
                        style="@style/FeatureLearningAudioLoopSettingsList">

                        <LinearLayout
                            android:id="@+id/layout_switch_loop"
                            style="@style/FeatureLearningAudioLoopSettingsSwitchRow">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowIcon"
                                android:text="Lp" />

                            <LinearLayout style="@style/FeatureLearningAudioLoopSettingsSwitchTextGroup">

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsSwitchTitle"
                                    android:text="@string/feature_learning_audio_loop_settings_loop" />

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsSwitchDesc"
                                    android:text="@string/feature_learning_audio_loop_settings_loop_desc" />
                            </LinearLayout>

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switch_loop"
                                style="@style/FeatureLearningAudioLoopSettingsSwitch" />
                        </LinearLayout>

                        <View style="@style/FeatureLearningAudioLoopSettingsDivider" />

                        <LinearLayout
                            android:id="@+id/layout_switch_random_order"
                            style="@style/FeatureLearningAudioLoopSettingsSwitchRow">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowIcon"
                                android:text="Rd" />

                            <LinearLayout style="@style/FeatureLearningAudioLoopSettingsSwitchTextGroup">

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsSwitchTitle"
                                    android:text="@string/feature_learning_audio_loop_settings_random" />

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsSwitchDesc"
                                    android:text="@string/feature_learning_audio_loop_settings_random_desc" />
                            </LinearLayout>

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switch_random_order"
                                style="@style/FeatureLearningAudioLoopSettingsSwitch" />
                        </LinearLayout>

                        <View style="@style/FeatureLearningAudioLoopSettingsDivider" />

                        <LinearLayout
                            android:id="@+id/layout_switch_keep_screen"
                            style="@style/FeatureLearningAudioLoopSettingsSwitchRow">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowIcon"
                                android:text="On" />

                            <LinearLayout style="@style/FeatureLearningAudioLoopSettingsSwitchTextGroup">

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsSwitchTitle"
                                    android:text="@string/feature_learning_audio_loop_settings_keep_screen" />

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsSwitchDesc"
                                    android:text="@string/feature_learning_audio_loop_settings_keep_screen_desc" />
                            </LinearLayout>

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switch_keep_screen"
                                style="@style/FeatureLearningAudioLoopSettingsSwitch" />
                        </LinearLayout>

                        <View style="@style/FeatureLearningAudioLoopSettingsDivider" />

                        <LinearLayout
                            android:id="@+id/layout_switch_word_spelling"
                            style="@style/FeatureLearningAudioLoopSettingsSwitchRow">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowIcon"
                                android:text="Ph" />

                            <LinearLayout style="@style/FeatureLearningAudioLoopSettingsSwitchTextGroup">

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsSwitchTitle"
                                    android:text="@string/feature_learning_audio_loop_settings_phonetic" />

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsSwitchDesc"
                                    android:text="@string/feature_learning_audio_loop_settings_phonetic_desc" />
                            </LinearLayout>

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switch_word_spelling"
                                style="@style/FeatureLearningAudioLoopSettingsSwitch" />
                        </LinearLayout>

                        <View style="@style/FeatureLearningAudioLoopSettingsDivider" />

                        <LinearLayout
                            android:id="@+id/layout_switch_chinese_meaning"
                            style="@style/FeatureLearningAudioLoopSettingsSwitchRow">

                            <TextView
                                style="@style/FeatureLearningAudioLoopSettingsRowIcon"
                                android:text="CN" />

                            <LinearLayout style="@style/FeatureLearningAudioLoopSettingsSwitchTextGroup">

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsSwitchTitle"
                                    android:text="@string/feature_learning_audio_loop_settings_meaning" />

                                <TextView
                                    style="@style/FeatureLearningAudioLoopSettingsSwitchDesc"
                                    android:text="@string/feature_learning_audio_loop_settings_meaning_desc" />
                            </LinearLayout>

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switch_chinese_meaning"
                                style="@style/FeatureLearningAudioLoopSettingsSwitch" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/feature_learning_audio_loop_settings_save_full"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/purple_primary"
            app:cornerRadius="26dp"
            app:icon="@drawable/feature_learning_ic_audio_loop_save"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="@android:color/white" />
    </LinearLayout>
</layout>

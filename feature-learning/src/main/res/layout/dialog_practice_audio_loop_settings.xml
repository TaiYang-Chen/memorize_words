<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/feature_learning_audio_loop_settings_title"
                android:textColor="@color/feature_learning_audio_loop_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/feature_learning_audio_loop_settings_mode_title"
                android:textColor="@color/feature_learning_audio_loop_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/radio_group_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/radio_word_only"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/feature_learning_audio_loop_mode_word_only"
                    android:textColor="@color/feature_learning_audio_loop_text_primary"
                    android:textSize="15sp" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/radio_word_with_example"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/feature_learning_audio_loop_mode_word_with_example"
                    android:textColor="@color/feature_learning_audio_loop_text_primary"
                    android:textSize="15sp" />
            </RadioGroup>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/feature_learning_audio_loop_settings_play_times"
                    android:textColor="@color/feature_learning_audio_loop_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_play_times_minus"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="-" />

                <TextView
                    android:id="@+id/tv_play_times_value"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/feature_learning_audio_loop_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_play_times_plus"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="+" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/feature_learning_audio_loop_settings_interval"
                    android:textColor="@color/feature_learning_audio_loop_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_interval_minus"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="-" />

                <TextView
                    android:id="@+id/tv_interval_value"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/feature_learning_audio_loop_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_interval_plus"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="+" />
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_loop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="@string/feature_learning_audio_loop_settings_loop"
                android:textColor="@color/feature_learning_audio_loop_text_primary"
                android:textSize="15sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_word_spelling"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/feature_learning_audio_loop_settings_phonetic"
                android:textColor="@color/feature_learning_audio_loop_text_primary"
                android:textSize="15sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_chinese_meaning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/feature_learning_audio_loop_settings_meaning"
                android:textColor="@color/feature_learning_audio_loop_text_primary"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/feature_learning_audio_loop_settings_save"
                android:textStyle="bold"
                app:backgroundTint="@color/feature_learning_audio_loop_text_primary"
                app:cornerRadius="26dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</layout>

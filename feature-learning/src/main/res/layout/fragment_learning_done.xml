<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="com.chen.memorizewords.feature.learning.ui.done.LearningDoneViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/module_learning_bg_summary_root"
        android:paddingStart="@dimen/page_margin"
        android:paddingTop="@dimen/page_margin"
        android:paddingEnd="@dimen/page_margin">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/topBar"
            android:layout_width="0dp"
            android:layout_marginTop="36dp"
            android:layout_height="@dimen/title_height"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivClose"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:onClick="@{() -> viewModel.finish()}"
                android:padding="6dp"
                android:src="@drawable/module_learning_close"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#2F3A35" />

            <TextView
                android:id="@+id/tvHeaderTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:ellipsize="end"
                android:fontFamily="serif"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/learning_done_header_title"
                android:textColor="#006C5B"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/ivClose"
                app:layout_constraintEnd_toStartOf="@id/ivShare"
                app:layout_constraintStart_toEndOf="@id/ivClose"
                app:layout_constraintTop_toTopOf="@id/ivClose"
                tools:text="Session Summary" />

            <ImageView
                android:id="@+id/ivShare"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="5dp"
                android:src="@drawable/module_learning_share_24dp_444f5f"
                app:layout_constraintBottom_toBottomOf="@id/ivClose"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/ivClose"
                app:tint="#2F3A35" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:fillViewport="false"
            android:overScrollMode="never"
            android:paddingBottom="142dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/topBar">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/cardHero"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/module_learning_bg_summary_hero"
                    android:elevation="1dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="22dp">

                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/module_learning_bg_summary_medal_outer">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:background="@drawable/module_learning_bg_summary_medal_inner">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/module_learning_ic_summary_medal" />
                        </FrameLayout>
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvDoneTag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/module_learning_bg_summary_chip"
                        android:includeFontPadding="false"
                        android:paddingStart="13dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="13dp"
                        android:paddingBottom="6dp"
                        android:text="@string/learning_done_tag_new"
                        android:textColor="#723B07"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="New study" />

                    <TextView
                        android:id="@+id/tvDoneTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:text="@string/learning_done_title"
                        android:textColor="#07111F"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        tools:text="Done" />

                    <TextView
                        android:id="@+id/tvDoneSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp"
                        android:text="@string/learning_done_subtitle_new"
                        android:textColor="#2F3A35"
                        android:textSize="14sp"
                        tools:text="This session is complete. Keep the rhythm and start another set." />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardStats"
                    android:layout_width="match_parent"
                    android:layout_height="82dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/module_learning_bg_summary_panel"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvMetricCompletedValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="serif"
                            android:includeFontPadding="false"
                            android:text="0"
                            android:textColor="#006C5B"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            tools:text="15" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:includeFontPadding="false"
                            android:text="@string/learning_done_metric_completed"
                            android:textColor="#26352F"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="50dp"
                        android:background="@drawable/module_learning_bg_summary_divider" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvMetricAccuracyValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="serif"
                            android:includeFontPadding="false"
                            android:text="0%"
                            android:textColor="#006C5B"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            tools:text="92%" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:includeFontPadding="false"
                            android:text="@string/learning_done_metric_accuracy"
                            android:textColor="#26352F"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="50dp"
                        android:background="@drawable/module_learning_bg_summary_divider" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvMetricDurationValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="serif"
                            android:includeFontPadding="false"
                            android:text="0 m"
                            android:textColor="#006C5B"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            tools:text="12 m" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:includeFontPadding="false"
                            android:text="@string/learning_done_metric_duration"
                            android:textColor="#26352F"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardExtraStats"
                    android:layout_width="match_parent"
                    android:layout_height="86dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/module_learning_bg_summary_panel"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/learning_done_metric_quality"
                            android:textColor="#1C2925"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvMetricQualityValue"
                            android:layout_width="46dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="A"
                            android:textColor="#96520E"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="A" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/learning_done_metric_answered"
                            android:textColor="#1C2925"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvMetricAnsweredValue"
                            android:layout_width="50dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="0"
                            android:textColor="#07111F"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="40" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/learning_done_metric_wrong"
                            android:textColor="#1C2925"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvMetricWrongValue"
                            android:layout_width="46dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="#B80D16"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="3" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/learning_done_metric_efficiency"
                            android:textColor="#1C2925"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvMetricEfficiencyValue"
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:gravity="end"
                            android:maxLines="1"
                            android:text="0.0"
                            android:textColor="#07111F"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="3.5 w/m" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvWordListTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:includeFontPadding="false"
                    android:text="@string/learning_done_list_title"
                    android:textColor="#07111F"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvWordList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    tools:itemCount="3"
                    tools:listitem="@layout/rv_item_word_list" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:id="@+id/actionPanel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="8dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/btnContinue"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/module_learning_selector_summary_primary"
                android:gravity="center"
                android:text="@string/learning_done_continue"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnBackHome"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/module_learning_selector_summary_secondary"
                android:gravity="center"
                android:text="@string/learning_done_back_home"
                android:textColor="#9A5412"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>

<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="com.chen.memorizewords.feature.learning.ui.done.LearningDoneViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/module_learning_bg_done_root">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:id="@+id/cardHero"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/module_learning_bg_done_hero"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvDoneTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/learning_done_title"
                        android:textColor="#0F172A"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDoneSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/learning_done_subtitle_new"
                        android:textColor="#475569"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvDoneTag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/module_learning_bg_done_chip"
                        android:paddingStart="12dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="4dp"
                        android:text="@string/learning_done_tag_new"
                        android:textColor="#0F766E"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/module_learning_bg_done_card"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <androidx.gridlayout.widget.GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:columnCount="3"
                        app:rowCount="3">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp"
                            app:layout_column="0"
                            app:layout_columnWeight="1"
                            app:layout_row="0"
                            app:layout_rowWeight="1">

                            <TextView
                                android:id="@+id/tvMetricCompletedValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#0F172A"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="15" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/learning_done_metric_completed"
                                android:textColor="#64748B"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp"
                            app:layout_column="1"
                            app:layout_columnWeight="1"
                            app:layout_row="0"
                            app:layout_rowWeight="1">

                            <TextView
                                android:id="@+id/tvMetricDurationValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0分钟"
                                android:textColor="#0F172A"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="12分钟" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/learning_done_metric_duration"
                                android:textColor="#64748B"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp"
                            app:layout_column="2"
                            app:layout_columnWeight="1"
                            app:layout_row="0"
                            app:layout_rowWeight="1">

                            <TextView
                                android:id="@+id/tvMetricAccuracyValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textColor="#0F172A"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="92%" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/learning_done_metric_accuracy"
                                android:textColor="#64748B"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp"
                            app:layout_column="0"
                            app:layout_columnWeight="1"
                            app:layout_row="1"
                            app:layout_rowWeight="1">

                            <TextView
                                android:id="@+id/tvMetricQualityValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="优"
                                android:textColor="#0F172A"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="优" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/learning_done_metric_quality"
                                android:textColor="#64748B"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp"
                            app:layout_column="1"
                            app:layout_columnWeight="1"
                            app:layout_row="1"
                            app:layout_rowWeight="1">

                            <TextView
                                android:id="@+id/tvMetricAnsweredValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#0F172A"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="40" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/learning_done_metric_answered"
                                android:textColor="#64748B"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp"
                            app:layout_column="2"
                            app:layout_columnWeight="1"
                            app:layout_row="1"
                            app:layout_rowWeight="1">

                            <TextView
                                android:id="@+id/tvMetricWrongValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#0F172A"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="3" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/learning_done_metric_wrong"
                                android:textColor="#64748B"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp"
                            app:layout_column="0"
                            app:layout_columnSpan="3"
                            app:layout_columnWeight="1"
                            app:layout_row="2"
                            app:layout_rowWeight="1">

                            <TextView
                                android:id="@+id/tvMetricEfficiencyValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.0 词/分钟"
                                android:textColor="#0F172A"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="3.5 词/分钟" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/learning_done_metric_efficiency"
                                android:textColor="#64748B"
                                android:textSize="11sp" />
                        </LinearLayout>

                    </androidx.gridlayout.widget.GridLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvWordListTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/learning_done_list_title"
                    android:textColor="#0F172A"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvWordList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    tools:listitem="@layout/rv_item_word_list" />

                <LinearLayout
                    android:id="@+id/actionRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btnContinue"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/module_learning_selector_6b5b95_radius"
                        android:gravity="center"
                        android:text="@string/learning_done_continue"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnBackHome"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:background="@drawable/module_learning_selector_done_secondary"
                        android:gravity="center"
                        android:text="@string/learning_done_back_home"
                        android:textColor="#475569"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>

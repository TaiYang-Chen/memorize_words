<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="data"
            type="com.chen.memorizewords.domain.model.words.word.WordForm" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/module_learning_bg_radius_fff"
        android:orientation="horizontal"
        android:padding="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@{data.formType.name()}"
            android:textColor="#2984f7"
            android:textStyle="bold"
            tools:text="sus-" />

        <TextView
            android:layout_weight="1"
            android:gravity="end"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@{data.formText}"
            android:textColor="#133856"
            android:textStyle="bold"
            tools:text="这个颜色" />
    </LinearLayout>
</layout>
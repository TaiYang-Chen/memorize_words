<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white">

        <LinearLayout
            android:id="@+id/layout_header_root"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical|start"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_arrow_back" />

                <TextView
                    android:id="@+id/tv_screen_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textColor="#111111"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btn_settings"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical|end"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@null"
                    android:src="@drawable/module_learning_ic_settings" />
            </FrameLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EDF1F5" />
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_content"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingBottom="12dp"
            app:layout_constraintBottom_toTopOf="@id/layout_bottom_actions"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_header_root">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingTop="18dp"
                android:paddingEnd="18dp">

                <LinearLayout
                    android:id="@+id/layout_practice_root"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_mode_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/module_learning_bg_listening_mode_badge"
                        android:drawablePadding="5dp"
                        android:gravity="center"
                        android:minHeight="28dp"
                        android:paddingStart="14dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="5dp"
                        android:textColor="#20242D"
                        android:textSize="9sp"
                        tools:text="当前模式：辨音选义" />

                    <FrameLayout
                        android:id="@+id/layout_audio_focus"
                        android:layout_width="148dp"
                        android:layout_height="148dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/module_learning_bg_listening_audio_rings">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/card_audio"
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:layout_gravity="center"
                            app:cardBackgroundColor="@android:color/white"
                            app:cardCornerRadius="36dp"
                            app:cardElevation="4dp"
                            app:strokeColor="#EEF2F7"
                            app:strokeWidth="1dp">

                            <ImageView
                                android:id="@+id/btn_play_audio"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@null"
                                android:padding="18dp"
                                android:src="@drawable/module_learning_ic_volume_up" />
                        </com.google.android.material.card.MaterialCardView>
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tv_phonetic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="center"
                        android:textColor="#7A849A"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_prompt"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#1F2937"
                            android:textSize="15sp"
                            tools:text="请听发音，选出正确的释义" />

                        <TextView
                            android:id="@+id/tv_prompt_hint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:textColor="#8B95A7"
                            android:textSize="13sp"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/layout_meaning_options"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_option_1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:elevation="1dp"
                                android:gravity="start|center_vertical"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minHeight="54dp"
                                android:paddingStart="18dp"
                                android:paddingTop="14dp"
                                android:paddingEnd="18dp"
                                android:paddingBottom="14dp"
                                android:stateListAnimator="@null"
                                android:textAlignment="viewStart"
                                android:textAllCaps="false"
                                android:textColor="#111827"
                                android:textSize="13sp"
                                app:backgroundTint="@android:color/white"
                                app:cornerRadius="18dp"
                                app:rippleColor="#12000000"
                                app:strokeColor="#E8EDF4"
                                app:strokeWidth="1dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_option_2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:elevation="1dp"
                                android:gravity="start|center_vertical"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minHeight="54dp"
                                android:paddingStart="18dp"
                                android:paddingTop="14dp"
                                android:paddingEnd="18dp"
                                android:paddingBottom="14dp"
                                android:stateListAnimator="@null"
                                android:textAlignment="viewStart"
                                android:textAllCaps="false"
                                android:textColor="#111827"
                                android:textSize="13sp"
                                app:backgroundTint="@android:color/white"
                                app:cornerRadius="18dp"
                                app:rippleColor="#12000000"
                                app:strokeColor="#E8EDF4"
                                app:strokeWidth="1dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_option_3"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:elevation="1dp"
                                android:gravity="start|center_vertical"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minHeight="54dp"
                                android:paddingStart="18dp"
                                android:paddingTop="14dp"
                                android:paddingEnd="18dp"
                                android:paddingBottom="14dp"
                                android:stateListAnimator="@null"
                                android:textAlignment="viewStart"
                                android:textAllCaps="false"
                                android:textColor="#111827"
                                android:textSize="13sp"
                                app:backgroundTint="@android:color/white"
                                app:cornerRadius="18dp"
                                app:rippleColor="#12000000"
                                app:strokeColor="#E8EDF4"
                                app:strokeWidth="1dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_option_4"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:elevation="1dp"
                                android:gravity="start|center_vertical"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minHeight="54dp"
                                android:paddingStart="18dp"
                                android:paddingTop="14dp"
                                android:paddingEnd="18dp"
                                android:paddingBottom="14dp"
                                android:stateListAnimator="@null"
                                android:textAlignment="viewStart"
                                android:textAllCaps="false"
                                android:textColor="#111827"
                                android:textSize="13sp"
                                app:backgroundTint="@android:color/white"
                                app:cornerRadius="18dp"
                                app:rippleColor="#12000000"
                                app:strokeColor="#E8EDF4"
                                app:strokeWidth="1dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layout_spelling_question"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:orientation="vertical"
                            android:paddingBottom="8dp"
                            android:visibility="gone">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_horizontal"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:id="@+id/layout_spelling_slots"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:orientation="horizontal"
                                    android:showDividers="none"
                                    tools:ignore="UselessParent" />

                                <TextView
                                    android:id="@+id/tv_spelling_answer_feedback"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:background="@drawable/module_learning_bg_listening_chip"
                                    android:paddingStart="12dp"
                                    android:paddingTop="6dp"
                                    android:paddingEnd="12dp"
                                    android:paddingBottom="6dp"
                                    android:textColor="#D1435B"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:visibility="gone"
                                    tools:text="正确答案：listening" />

                                <androidx.gridlayout.widget.GridLayout
                                    android:id="@+id/grid_spelling_letters"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="18dp"
                                    app:columnCount="5"
                                    app:alignmentMode="alignMargins"
                                    app:useDefaultMargins="false" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_submit_spelling"
                                    android:layout_width="156dp"
                                    android:layout_height="42dp"
                                    android:layout_marginTop="18dp"
                                    android:insetTop="0dp"
                                    android:insetBottom="0dp"
                                    android:text="@string/practice_listening_submit"
                                    android:textAllCaps="false"
                                    android:textColor="@android:color/white"
                                    android:textSize="14sp"
                                    app:backgroundTint="#2F80ED"
                                    app:cornerRadius="12dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_feedback"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:paddingStart="12dp"
                        android:paddingTop="7dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="7dp"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_study_root"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="20dp"
                    android:paddingBottom="24dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_study_word"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="#000000"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        tools:text="absorption" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layout_study_phonetic_bar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp">

                        <RadioGroup
                            android:id="@+id/study_language_radio_group"
                            android:layout_width="50dp"
                            android:layout_height="25dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/module_learning_toggle_background"
                            android:orientation="horizontal"
                            android:padding="2dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/tv_study_phonetic"
                            app:layout_constraintTop_toTopOf="parent">

                            <RadioButton
                                android:id="@+id/btn_study_us"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@drawable/module_learning_toggle_item_selector"
                                android:button="@null"
                                android:checked="true"
                                android:gravity="center"
                                android:padding="2dp"
                                android:text="美"
                                android:textColor="@drawable/module_learning_toggle_text_selector"
                                android:textSize="10sp" />

                            <RadioButton
                                android:id="@+id/btn_study_uk"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@drawable/module_learning_toggle_item_selector"
                                android:button="@null"
                                android:gravity="center"
                                android:padding="2dp"
                                android:text="英"
                                android:textColor="@drawable/module_learning_toggle_text_selector"
                                android:textSize="10sp" />
                        </RadioGroup>

                        <TextView
                            android:id="@+id/tv_study_phonetic_label"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:visibility="gone" />

                        <View
                            android:id="@+id/view_study_phonetic_divider"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tv_study_phonetic"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif"
                            android:textColor="#666666"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:text="/əbˈzɔːrpʃən/" />

                        <ImageView
                            android:id="@+id/btn_play_study_audio"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="8dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@null"
                            android:padding="2dp"
                            android:src="@drawable/module_learning_ic_volume_up"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/tv_study_phonetic"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <TextView
                        android:id="@+id/tv_study_definition"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:lineSpacingExtra="1dp"
                        android:textColor="#334155"
                        android:textSize="16sp"
                        android:visibility="gone"
                        tools:text="n. 吸收；全神贯注；专注" />

                    <LinearLayout
                        android:id="@+id/card_study_examples"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/module_learning_bg_radius_f1f5f9"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingTop="18dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="18dp"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/layout_study_examples"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_study_definitions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp" />

                    <LinearLayout
                        android:id="@+id/layout_study_memory_tip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/module_learning_bg_radius_eefdf7"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/module_learning_lightbulb_10b981"
                            android:text="记忆技巧"
                            android:textColor="#167e5e"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_study_memory_tip"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="#6b7885"
                            tools:text="root memory tip" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/section_study_examples_header"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="18dp"
                            android:layout_marginEnd="4dp"
                            android:background="#10b981" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="例句"
                            android:textColor="#aab8c8"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_study_examples"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp" />

                    <LinearLayout
                        android:id="@+id/section_study_inflection_header"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="18dp"
                            android:layout_marginEnd="4dp"
                            android:background="#fb9034" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="词形变化"
                            android:textColor="#aab8c8"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_study_inflection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp" />

                    <LinearLayout
                        android:id="@+id/section_study_roots_header"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="18dp"
                            android:layout_marginEnd="4dp"
                            android:background="#60a5fa" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="词根词缀"
                            android:textColor="#aab8c8"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_study_root"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp" />

                    <LinearLayout
                        android:id="@+id/section_study_synonyms_header"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="18dp"
                            android:layout_marginEnd="4dp"
                            android:background="#be7dfc" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="同反义词"
                            android:textColor="#aab8c8"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_study_synonyms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_report_root"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="2dp"
                    android:paddingBottom="22dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_report_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#0F172A"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_report_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="1dp"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_report_accuracy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        app:cardBackgroundColor="@android:color/white"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#E9EEF5"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:paddingStart="20dp"
                            android:paddingTop="20dp"
                            android:paddingEnd="20dp"
                            android:paddingBottom="18dp">

                            <FrameLayout
                                android:layout_width="144dp"
                                android:layout_height="144dp">

                                <com.google.android.material.progressindicator.CircularProgressIndicator
                                    android:id="@+id/progress_report_accuracy"
                                    android:layout_width="144dp"
                                    android:layout_height="144dp"
                                    android:layout_gravity="center"
                                    android:indeterminate="false"
                                    android:max="100"
                                    app:indicatorColor="#12233F"
                                    app:indicatorSize="144dp"
                                    app:trackColor="#E8EDF4"
                                    app:trackThickness="10dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tv_report_accuracy"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="#12233F"
                                        android:textSize="28sp"
                                        android:textStyle="bold"
                                        tools:text="92%" />

                                    <TextView
                                        android:id="@+id/tv_report_accuracy_label"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="@string/practice_listening_report_accuracy_label"
                                        android:textColor="#7C8799"
                                        android:textSize="12sp" />
                                </LinearLayout>
                            </FrameLayout>

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/card_report_summary"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="18dp"
                                app:cardBackgroundColor="#F5F7FA"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="0dp"
                                app:strokeColor="#00000000"
                                app:strokeWidth="0dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_horizontal"
                                    android:orientation="vertical"
                                    android:paddingStart="16dp"
                                    android:paddingTop="14dp"
                                    android:paddingEnd="16dp"
                                    android:paddingBottom="14dp">

                                    <TextView
                                        android:id="@+id/tv_report_summary_primary"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:gravity="center"
                                        android:textColor="#12233F"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        tools:text="完成 20 个单词" />

                                    <TextView
                                        android:id="@+id/tv_report_summary_secondary"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:gravity="center"
                                        android:textColor="#667085"
                                        android:textSize="12sp"
                                        tools:text="累计作答 28 次，答对 21 次" />
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="16dp"
                            android:background="#12233F" />

                        <TextView
                            android:id="@+id/tv_report_reviewed_section_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/practice_listening_report_reviewed_words"
                            android:textColor="#12233F"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layout_report_reviewed_words"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="16dp"
                            android:background="#D8DEE8" />

                        <TextView
                            android:id="@+id/tv_report_all_words_section_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/practice_listening_report_all_words"
                            android:textColor="#6B7280"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layout_report_unfinished_words"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:id="@+id/layout_bottom_actions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/module_learning_bg_listening_footer"
            android:orientation="vertical"
            android:paddingTop="14dp"
            android:paddingBottom="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:id="@+id/layout_practice_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/btn_reveal_answer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="start"
                    android:minHeight="28dp"
                    android:text="@string/practice_listening_action_reveal"
                    android:textColor="#8A91A5"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/btn_skip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:minHeight="28dp"
                    android:text="@string/practice_listening_action_skip"
                    android:textColor="#8A91A5"
                    android:textSize="14sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_primary_action"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="16dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:visibility="gone"
                app:backgroundTint="#000000"
                app:cornerRadius="18dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>

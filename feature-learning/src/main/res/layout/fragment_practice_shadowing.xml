<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/feature_learning_shadowing_bg">

        <LinearLayout
            android:id="@+id/layout_header"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/title_height"
            android:layout_marginStart="@dimen/page_margin"
            android:layout_marginTop="@dimen/title_margin"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="@dimen/title_icon_touch_size"
                android:layout_height="@dimen/title_icon_touch_size"
                android:background="@android:color/transparent"
                android:contentDescription="@string/practice_shadowing_title_compare"
                android:padding="@dimen/core_ui_dp_7"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/feature_learning_shadowing_text_primary" />

            <TextView
                android:id="@+id/tv_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/core_ui_dp_6"
                android:text="0/0"
                android:textColor="@color/feature_learning_shadowing_text_primary"
                android:textSize="@dimen/core_ui_text_15"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/title_margin"
            android:gravity="center"
            android:minHeight="@dimen/title_height"
            android:text="@string/practice_shadowing_title_compare"
            android:textColor="@color/feature_learning_shadowing_text_primary"
            android:textSize="@dimen/title_text_size"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_quota"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginEnd="@dimen/page_margin"
            android:background="@drawable/feature_learning_bg_shadowing_chip"
            android:gravity="center"
            android:minWidth="@dimen/core_ui_dp_96"
            android:paddingStart="@dimen/core_ui_dp_10"
            android:paddingEnd="@dimen/core_ui_dp_10"
            android:text="@string/practice_shadowing_quota_unknown"
            android:textColor="@color/feature_learning_shadowing_text_secondary"
            android:textSize="@dimen/core_ui_text_11"
            app:layout_constraintBottom_toBottomOf="@id/tv_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_title" />

        <LinearLayout
            android:id="@+id/layout_bottom_panel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/feature_learning_shadowing_page_margin"
            android:layout_marginEnd="@dimen/feature_learning_shadowing_page_margin"
            android:layout_marginBottom="@dimen/core_ui_dp_12"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:id="@+id/layout_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/core_ui_dp_10"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/action_reference"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_play_reference"
                        android:layout_width="@dimen/feature_learning_shadowing_play_button"
                        android:layout_height="@dimen/feature_learning_shadowing_play_button"
                        app:cardBackgroundColor="@android:color/white"
                        app:cardCornerRadius="@dimen/core_ui_dp_23"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/feature_learning_shadowing_action_stroke"
                        app:strokeWidth="@dimen/core_ui_dp_1">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/practice_shadowing_reference_audio"
                            android:padding="@dimen/feature_learning_shadowing_play_icon_padding"
                            android:src="@drawable/module_learning_ic_volume_up"
                            app:tint="@color/feature_learning_shadowing_text_primary" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tv_reference_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/core_ui_dp_6"
                        android:text="@string/practice_shadowing_reference_audio"
                        android:textColor="@color/feature_learning_shadowing_text_secondary"
                        android:textSize="@dimen/feature_learning_shadowing_action_label_size" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/action_record"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_record"
                        android:layout_width="@dimen/feature_learning_shadowing_record_button"
                        android:layout_height="@dimen/feature_learning_shadowing_record_button"
                        app:cardBackgroundColor="@color/feature_learning_shadowing_record_bg"
                        app:cardCornerRadius="@dimen/core_ui_dp_35"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/feature_learning_shadowing_record_stroke"
                        app:strokeWidth="@dimen/core_ui_dp_1">

                        <ImageView
                            android:id="@+id/iv_record_action"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/practice_shadowing_record"
                            android:padding="@dimen/feature_learning_shadowing_record_icon_padding"
                            android:src="@drawable/feature_learning_ic_microphone"
                            app:tint="@color/feature_learning_shadowing_text_primary" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tv_record_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/core_ui_dp_6"
                        android:text="@string/practice_shadowing_record"
                        android:textColor="@color/feature_learning_shadowing_text_secondary"
                        android:textSize="@dimen/feature_learning_shadowing_record_label_size" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/action_mine"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_play_mine"
                        android:layout_width="@dimen/feature_learning_shadowing_play_button"
                        android:layout_height="@dimen/feature_learning_shadowing_play_button"
                        app:cardBackgroundColor="@android:color/white"
                        app:cardCornerRadius="@dimen/core_ui_dp_23"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/feature_learning_shadowing_action_stroke"
                        app:strokeWidth="@dimen/core_ui_dp_1">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/practice_shadowing_my_audio"
                            android:padding="@dimen/feature_learning_shadowing_play_icon_padding"
                            android:src="@drawable/feature_learning_ic_equalizer"
                            app:tint="@color/feature_learning_shadowing_text_primary" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tv_mine_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/core_ui_dp_6"
                        android:text="@string/practice_shadowing_my_audio"
                        android:textColor="@color/feature_learning_shadowing_text_secondary"
                        android:textSize="@dimen/feature_learning_shadowing_action_label_size" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_next_word"
                android:layout_width="match_parent"
                android:layout_height="@dimen/feature_learning_shadowing_bottom_button_height"
                android:layout_marginTop="@dimen/core_ui_dp_14"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/practice_next_word"
                android:textColor="@android:color/white"
                android:textSize="@dimen/core_ui_text_16"
                android:textStyle="bold"
                app:backgroundTint="@android:color/black"
                app:cornerRadius="@dimen/core_ui_dp_26" />
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_content"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:fillViewport="false"
            android:paddingBottom="@dimen/core_ui_dp_16"
            app:layout_constraintBottom_toTopOf="@id/layout_bottom_panel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="@dimen/feature_learning_shadowing_page_margin"
                android:paddingTop="@dimen/feature_learning_shadowing_content_top"
                android:paddingEnd="@dimen/feature_learning_shadowing_page_margin">

                <TextView
                    android:id="@+id/tv_word"
                    android:layout_width="@dimen/feature_learning_shadowing_word_max_width"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:autoSizeMinTextSize="@dimen/core_ui_text_24"
                    android:autoSizeMaxTextSize="@dimen/feature_learning_shadowing_word_size"
                    android:autoSizeStepGranularity="@dimen/core_ui_text_auto_size_step"
                    android:autoSizeTextType="uniform"
                    android:text="-"
                    android:textColor="@color/feature_learning_shadowing_text_primary"
                    android:textSize="@dimen/feature_learning_shadowing_word_size"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/layout_chips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_10"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_phonetic_chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/feature_learning_bg_shadowing_chip"
                        android:paddingStart="@dimen/feature_learning_shadowing_chip_padding_horizontal"
                        android:paddingTop="@dimen/feature_learning_shadowing_chip_padding_vertical"
                        android:paddingEnd="@dimen/feature_learning_shadowing_chip_padding_horizontal"
                        android:paddingBottom="@dimen/feature_learning_shadowing_chip_padding_vertical"
                        android:textColor="@color/feature_learning_shadowing_chip_text"
                        android:textSize="@dimen/feature_learning_shadowing_chip_text_size" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_meaning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/feature_learning_shadowing_meaning_top"
                    android:textColor="@color/feature_learning_shadowing_text_primary"
                    android:textSize="@dimen/feature_learning_shadowing_meaning_text_size" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_wave"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/feature_learning_shadowing_card_top"
                    app:cardBackgroundColor="@color/feature_learning_shadowing_card_bg"
                    app:cardCornerRadius="@dimen/core_ui_dp_20"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/feature_learning_shadowing_card_stroke"
                    app:strokeWidth="@dimen/core_ui_dp_1">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/feature_learning_shadowing_card_padding"
                        android:paddingTop="@dimen/feature_learning_shadowing_card_padding"
                        android:paddingEnd="@dimen/feature_learning_shadowing_card_padding"
                        android:paddingBottom="@dimen/feature_learning_shadowing_card_padding">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_wave_title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/feature_learning_shadowing_text_primary"
                                    android:textSize="@dimen/core_ui_text_14"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tv_wave_subtitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/core_ui_dp_3"
                                    android:textColor="@color/feature_learning_shadowing_text_secondary"
                                    android:textSize="@dimen/core_ui_text_12" />
                            </LinearLayout>
                        </LinearLayout>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/feature_learning_shadowing_wave_height"
                            android:layout_marginTop="@dimen/core_ui_dp_10">

                            <com.chen.memorizewords.feature.learning.ui.practice.ShadowingWaveformView
                                android:id="@+id/waveform_view"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/practice_shadowing_waveform_content"
                                android:paddingStart="@dimen/core_ui_dp_10"
                                android:paddingEnd="@dimen/core_ui_dp_10" />

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/card_wave_play_overlay"
                                android:layout_width="@dimen/core_ui_dp_60"
                                android:layout_height="@dimen/core_ui_dp_60"
                                android:layout_gravity="center"
                                app:cardBackgroundColor="#70000000"
                                app:cardCornerRadius="@dimen/core_ui_dp_30"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/iv_wave_play"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="@dimen/core_ui_dp_18"
                                    android:src="@drawable/feature_learning_ic_play" />
                            </com.google.android.material.card.MaterialCardView>

                        </FrameLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_evaluate_pronunciation"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/core_ui_dp_34"
                            android:layout_gravity="end"
                            android:layout_marginTop="@dimen/core_ui_dp_6"
                            android:layout_marginEnd="@dimen/core_ui_dp_10"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/core_ui_dp_16"
                            android:paddingEnd="@dimen/core_ui_dp_16"
                            android:text="@string/practice_shadowing_evaluate_action"
                            android:textColor="@android:color/white"
                            android:textSize="@dimen/core_ui_text_13"
                            android:textStyle="bold"
                            android:visibility="gone"
                            app:backgroundTint="@color/feature_learning_shadowing_text_primary"
                            app:cornerRadius="@dimen/core_ui_dp_17" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_feedback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_10"
                    android:layout_marginBottom="@dimen/core_ui_dp_10"
                    app:cardBackgroundColor="@color/feature_learning_shadowing_feedback_bg"
                    app:cardCornerRadius="@dimen/core_ui_dp_16"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/feature_learning_shadowing_card_padding"
                        android:paddingTop="@dimen/feature_learning_shadowing_card_padding"
                        android:paddingEnd="@dimen/feature_learning_shadowing_card_padding"
                        android:paddingBottom="@dimen/feature_learning_shadowing_card_padding">

                        <TextView
                            android:id="@+id/tv_feedback_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/feature_learning_shadowing_feedback_score"
                            android:textSize="@dimen/feature_learning_shadowing_feedback_title_size"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_score_detail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/core_ui_dp_6"
                            android:textColor="@color/feature_learning_shadowing_text_secondary"
                            android:textSize="@dimen/feature_learning_shadowing_feedback_body_size" />

                        <TextView
                            android:id="@+id/tv_score_breakdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/core_ui_dp_6"
                            android:textColor="@color/feature_learning_shadowing_text_secondary"
                            android:textSize="@dimen/feature_learning_shadowing_feedback_meta_size"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tv_weak_points"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/core_ui_dp_4"
                            android:textColor="@color/feature_learning_shadowing_feedback_retry"
                            android:textStyle="bold"
                            android:textSize="@dimen/feature_learning_shadowing_feedback_meta_size"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tv_audio_issue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/core_ui_dp_4"
                            android:textColor="@color/feature_learning_shadowing_feedback_retry"
                            android:textSize="@dimen/feature_learning_shadowing_feedback_meta_size"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tv_feedback_message"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/core_ui_dp_6"
                            android:textColor="@color/feature_learning_shadowing_text_primary"
                            android:textSize="@dimen/feature_learning_shadowing_feedback_body_size" />

                        <TextView
                            android:id="@+id/tv_recognized"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/core_ui_dp_6"
                            android:textColor="@color/feature_learning_shadowing_text_secondary"
                            android:textSize="@dimen/feature_learning_shadowing_feedback_meta_size" />

                        <TextView
                            android:id="@+id/tv_detail_note"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/core_ui_dp_4"
                            android:textColor="@color/feature_learning_shadowing_text_secondary"
                            android:textSize="@dimen/core_ui_text_11"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <HorizontalScrollView
                    android:id="@+id/history_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/layout_history_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>

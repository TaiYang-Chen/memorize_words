<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/feature_learning_bg_audio_loop_settings_sheet"
    android:orientation="vertical"
    android:paddingStart="@dimen/core_ui_dp_16"
    android:paddingTop="@dimen/core_ui_dp_14"
    android:paddingEnd="@dimen/core_ui_dp_16"
    android:paddingBottom="@dimen/core_ui_dp_12">

    <View
        android:layout_width="@dimen/core_ui_dp_48"
        android:layout_height="@dimen/core_ui_dp_4"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/feature_learning_bg_audio_loop_chip" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/core_ui_dp_14"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_playlist_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/feature_learning_audio_loop_playlist_title"
                android:textColor="@color/feature_learning_audio_loop_text_primary"
                android:textSize="@dimen/core_ui_text_22"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_playlist_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/core_ui_dp_2"
                android:textColor="@color/feature_learning_audio_loop_text_secondary"
                android:textSize="@dimen/core_ui_text_13" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="@dimen/core_ui_dp_44"
            android:layout_height="@dimen/core_ui_dp_44"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="@string/feature_learning_audio_loop_action_close"
            android:padding="@dimen/core_ui_dp_12"
            android:src="@drawable/module_learning_close"
            app:tint="@color/feature_learning_audio_loop_text_secondary" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_playlist"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/core_ui_dp_14"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="@dimen/core_ui_dp_8" />
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/feature_learning_audio_loop_bg">

        <LinearLayout
            android:id="@+id/layout_header_start"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/title_height"
            android:layout_marginStart="@dimen/page_margin"
            android:layout_marginTop="@dimen/title_margin"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="@dimen/title_icon_touch_size"
                android:layout_height="@dimen/title_icon_touch_size"
                android:background="@android:color/transparent"
                android:contentDescription="@string/feature_learning_audio_loop_title"
                android:padding="@dimen/core_ui_dp_7"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/feature_learning_audio_loop_text_primary" />

            <TextView
                android:id="@+id/tv_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/core_ui_dp_6"
                android:text="0/0"
                android:textColor="@color/feature_learning_audio_loop_text_primary"
                android:textSize="@dimen/core_ui_text_15"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/title_margin"
            android:text="@string/feature_learning_audio_loop_title"
            android:textColor="@color/feature_learning_audio_loop_text_primary"
            android:textSize="@dimen/title_text_size"
            android:textStyle="bold"
            android:minHeight="@dimen/title_height"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/layout_bottom_panel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/core_ui_dp_18"
            android:layout_marginEnd="@dimen/core_ui_dp_18"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/feature_learning_audio_loop_text_primary"
                android:textSize="@dimen/core_ui_text_14"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_status_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/core_ui_dp_6"
                android:textColor="@color/feature_learning_audio_loop_text_secondary"
                android:textSize="@dimen/core_ui_text_13" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/core_ui_dp_14"
                android:layout_marginBottom="@dimen/core_ui_dp_16"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btn_playlist"
                    android:layout_width="@dimen/core_ui_dp_44"
                    android:layout_height="@dimen/core_ui_dp_44"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/feature_learning_audio_loop_action_playlist"
                    android:padding="@dimen/core_ui_dp_8"
                    android:src="@drawable/feature_learning_ic_audio_loop_playlist"
                    app:tint="@color/feature_learning_audio_loop_text_primary" />

                <ImageButton
                    android:id="@+id/btn_previous"
                    android:layout_width="@dimen/core_ui_dp_48"
                    android:layout_height="@dimen/core_ui_dp_48"
                    android:layout_marginStart="@dimen/core_ui_dp_10"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/feature_learning_audio_loop_action_previous"
                    android:padding="@dimen/core_ui_dp_10"
                    android:src="@drawable/feature_learning_ic_audio_loop_previous"
                    app:tint="@color/feature_learning_audio_loop_text_primary" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_play_pause"
                    android:layout_width="@dimen/core_ui_dp_76"
                    android:layout_height="@dimen/core_ui_dp_76"
                    android:layout_marginStart="@dimen/core_ui_dp_12"
                    android:layout_marginEnd="@dimen/core_ui_dp_12"
                    app:cardBackgroundColor="@color/feature_learning_audio_loop_play_button"
                    app:cardCornerRadius="@dimen/core_ui_dp_38"
                    app:cardElevation="@dimen/core_ui_dp_6">

                    <ImageView
                        android:id="@+id/iv_play_pause"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/feature_learning_audio_loop_action_toggle"
                        android:padding="@dimen/core_ui_dp_20"
                        android:src="@drawable/feature_learning_ic_play"
                        app:tint="@android:color/white" />
                </com.google.android.material.card.MaterialCardView>

                <ImageButton
                    android:id="@+id/btn_next"
                    android:layout_width="@dimen/core_ui_dp_48"
                    android:layout_height="@dimen/core_ui_dp_48"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/feature_learning_audio_loop_action_next"
                    android:padding="@dimen/core_ui_dp_10"
                    android:src="@drawable/feature_learning_ic_audio_loop_next"
                    app:tint="@color/feature_learning_audio_loop_text_primary" />

                <ImageButton
                    android:id="@+id/btn_settings"
                    android:layout_width="@dimen/core_ui_dp_44"
                    android:layout_height="@dimen/core_ui_dp_44"
                    android:layout_marginStart="@dimen/core_ui_dp_10"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/feature_learning_audio_loop_action_settings"
                    android:padding="@dimen/core_ui_dp_8"
                    android:src="@drawable/module_learning_ic_settings"
                    app:tint="@color/feature_learning_audio_loop_text_primary" />
            </LinearLayout>
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/content_scroll"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingStart="@dimen/core_ui_dp_24"
            android:paddingTop="@dimen/core_ui_dp_12"
            android:paddingEnd="@dimen/core_ui_dp_24"
            android:paddingBottom="@dimen/core_ui_dp_12"
            app:layout_constraintBottom_toTopOf="@id/layout_bottom_panel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="@dimen/core_ui_dp_36">

                <TextView
                    android:id="@+id/tv_word"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/feature_learning_audio_loop_text_primary"
                    android:textSize="@dimen/core_ui_text_40"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="@dimen/core_ui_text_26"
                    android:autoSizeMaxTextSize="@dimen/core_ui_text_40"
                    android:autoSizeStepGranularity="@dimen/core_ui_text_auto_size_step" />

                <LinearLayout
                    android:id="@+id/layout_audio_loop_phonetic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_16"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <RadioGroup
                        android:id="@+id/audio_loop_language_radio_group"
                        android:layout_width="@dimen/core_ui_dp_50"
                        android:layout_height="@dimen/core_ui_dp_25"
                        android:layout_marginEnd="@dimen/core_ui_dp_8"
                        android:background="@drawable/module_learning_toggle_background"
                        android:orientation="horizontal"
                        android:padding="@dimen/core_ui_dp_2">

                        <RadioButton
                            android:id="@+id/btn_audio_loop_us"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/module_learning_toggle_item_selector"
                            android:button="@null"
                            android:checked="true"
                            android:gravity="center"
                            android:padding="@dimen/core_ui_dp_2"
                            android:text="@string/feature_learning_audio_loop_pronunciation_us"
                            android:textColor="@drawable/module_learning_toggle_text_selector"
                            android:textSize="@dimen/core_ui_sp_10" />

                        <RadioButton
                            android:id="@+id/btn_audio_loop_uk"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/module_learning_toggle_item_selector"
                            android:button="@null"
                            android:gravity="center"
                            android:padding="@dimen/core_ui_dp_2"
                            android:text="@string/feature_learning_audio_loop_pronunciation_uk"
                            android:textColor="@drawable/module_learning_toggle_text_selector"
                            android:textSize="@dimen/core_ui_sp_10" />
                    </RadioGroup>

                    <TextView
                        android:id="@+id/tv_phonetic_chip"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/core_ui_dp_25"
                        android:background="@drawable/feature_learning_bg_audio_loop_chip"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:paddingStart="@dimen/core_ui_dp_16"
                        android:paddingEnd="@dimen/core_ui_dp_16"
                        android:textColor="@color/feature_learning_audio_loop_chip_text"
                        android:textSize="@dimen/core_ui_text_15" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_entry_status_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_10"
                    android:background="@drawable/feature_learning_bg_audio_loop_status_chip"
                    android:paddingStart="@dimen/core_ui_dp_14"
                    android:paddingTop="@dimen/core_ui_dp_6"
                    android:paddingEnd="@dimen/core_ui_dp_14"
                    android:paddingBottom="@dimen/core_ui_dp_6"
                    android:textColor="@color/feature_learning_audio_loop_status_text"
                    android:textSize="@dimen/core_ui_text_13"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_supporting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_72"
                    android:gravity="center"
                    android:textColor="@color/feature_learning_audio_loop_text_secondary"
                    android:textSize="@dimen/core_ui_text_16"
                    android:maxLines="4" />

                <TextView
                    android:id="@+id/tv_supporting_translation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_12"
                    android:gravity="center"
                    android:textColor="@color/feature_learning_audio_loop_text_secondary"
                    android:textSize="@dimen/core_ui_text_15" />

                <TextView
                    android:id="@+id/tv_meaning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_22"
                    android:gravity="center"
                    android:textColor="@color/feature_learning_audio_loop_text_primary"
                    android:textSize="@dimen/core_ui_text_18"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_empty_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_48"
                    android:gravity="center"
                    android:text="@string/feature_learning_audio_loop_empty_title"
                    android:textColor="@color/feature_learning_audio_loop_text_primary"
                    android:textSize="@dimen/core_ui_text_22"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_empty_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_14"
                    android:gravity="center"
                    android:text="@string/feature_learning_audio_loop_empty_hint"
                    android:textColor="@color/feature_learning_audio_loop_text_secondary"
                    android:textSize="@dimen/core_ui_text_15"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>

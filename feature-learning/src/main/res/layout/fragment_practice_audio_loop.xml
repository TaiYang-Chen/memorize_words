<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/feature_learning_audio_loop_bg">

        <LinearLayout
            android:id="@+id/layout_header_start"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/title_height"
            android:layout_marginStart="@dimen/page_margin"
            android:layout_marginTop="@dimen/title_margin"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="@dimen/title_icon_touch_size"
                android:layout_height="@dimen/title_icon_touch_size"
                android:background="@android:color/transparent"
                android:contentDescription="@string/feature_learning_audio_loop_title"
                android:padding="7dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/feature_learning_audio_loop_text_primary" />

            <TextView
                android:id="@+id/tv_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="0/0"
                android:textColor="@color/feature_learning_audio_loop_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/title_margin"
            android:text="@string/feature_learning_audio_loop_title"
            android:textColor="@color/feature_learning_audio_loop_text_primary"
            android:textSize="@dimen/title_text_size"
            android:textStyle="bold"
            android:minHeight="@dimen/title_height"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/layout_bottom_panel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/feature_learning_audio_loop_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_status_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/feature_learning_audio_loop_text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btn_playlist"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/feature_learning_audio_loop_action_playlist"
                    android:padding="8dp"
                    android:src="@drawable/feature_learning_ic_audio_loop_playlist"
                    app:tint="@color/feature_learning_audio_loop_text_primary" />

                <ImageButton
                    android:id="@+id/btn_previous"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="10dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/feature_learning_audio_loop_action_previous"
                    android:padding="10dp"
                    android:src="@drawable/feature_learning_ic_audio_loop_previous"
                    app:tint="@color/feature_learning_audio_loop_text_primary" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_play_pause"
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    app:cardBackgroundColor="@color/feature_learning_audio_loop_play_button"
                    app:cardCornerRadius="38dp"
                    app:cardElevation="6dp">

                    <ImageView
                        android:id="@+id/iv_play_pause"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/feature_learning_audio_loop_action_toggle"
                        android:padding="20dp"
                        android:src="@drawable/feature_learning_ic_play"
                        app:tint="@color/feature_learning_audio_loop_text_primary" />
                </com.google.android.material.card.MaterialCardView>

                <ImageButton
                    android:id="@+id/btn_next"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/feature_learning_audio_loop_action_next"
                    android:padding="10dp"
                    android:src="@drawable/feature_learning_ic_audio_loop_next"
                    app:tint="@color/feature_learning_audio_loop_text_primary" />

                <ImageButton
                    android:id="@+id/btn_settings"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="10dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/feature_learning_audio_loop_action_settings"
                    android:padding="8dp"
                    android:src="@drawable/module_learning_ic_settings"
                    app:tint="@color/feature_learning_audio_loop_text_primary" />
            </LinearLayout>
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/content_scroll"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingStart="24dp"
            android:paddingTop="12dp"
            android:paddingEnd="24dp"
            android:paddingBottom="12dp"
            app:layout_constraintBottom_toTopOf="@id/layout_bottom_panel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="36dp">

                <TextView
                    android:id="@+id/tv_word"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/feature_learning_audio_loop_text_primary"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="26sp"
                    android:autoSizeMaxTextSize="40sp"
                    android:autoSizeStepGranularity="1sp" />

                <LinearLayout
                    android:id="@+id/layout_audio_loop_phonetic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <RadioGroup
                        android:id="@+id/audio_loop_language_radio_group"
                        android:layout_width="50dp"
                        android:layout_height="25dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/module_learning_toggle_background"
                        android:orientation="horizontal"
                        android:padding="2dp">

                        <RadioButton
                            android:id="@+id/btn_audio_loop_us"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/module_learning_toggle_item_selector"
                            android:button="@null"
                            android:checked="true"
                            android:gravity="center"
                            android:padding="2dp"
                            android:text="@string/feature_learning_audio_loop_pronunciation_us"
                            android:textColor="@drawable/module_learning_toggle_text_selector"
                            android:textSize="10sp" />

                        <RadioButton
                            android:id="@+id/btn_audio_loop_uk"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/module_learning_toggle_item_selector"
                            android:button="@null"
                            android:gravity="center"
                            android:padding="2dp"
                            android:text="@string/feature_learning_audio_loop_pronunciation_uk"
                            android:textColor="@drawable/module_learning_toggle_text_selector"
                            android:textSize="10sp" />
                    </RadioGroup>

                    <TextView
                        android:id="@+id/tv_phonetic_chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/feature_learning_bg_audio_loop_chip"
                        android:paddingStart="16dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="8dp"
                        android:textColor="@color/feature_learning_audio_loop_chip_text"
                        android:textSize="15sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_entry_status_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/feature_learning_bg_audio_loop_status_chip"
                    android:paddingStart="14dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="6dp"
                    android:textColor="@color/feature_learning_audio_loop_status_text"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_supporting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="72dp"
                    android:gravity="center"
                    android:textColor="@color/feature_learning_audio_loop_text_secondary"
                    android:textSize="16sp"
                    android:maxLines="4" />

                <TextView
                    android:id="@+id/tv_supporting_translation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:textColor="@color/feature_learning_audio_loop_text_secondary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tv_meaning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:gravity="center"
                    android:textColor="@color/feature_learning_audio_loop_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_empty_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="48dp"
                    android:gravity="center"
                    android:text="@string/feature_learning_audio_loop_empty_title"
                    android:textColor="@color/feature_learning_audio_loop_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_empty_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:text="@string/feature_learning_audio_loop_empty_hint"
                    android:textColor="@color/feature_learning_audio_loop_text_secondary"
                    android:textSize="15sp"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>

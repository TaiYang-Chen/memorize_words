<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/module_learning_bg_summary_root"
        android:paddingStart="@dimen/page_margin"
        android:paddingTop="@dimen/page_margin"
        android:paddingEnd="@dimen/page_margin">

        <FrameLayout
            android:id="@+id/top_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/title_margin"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btn_close"
                android:layout_width="@dimen/title_icon_size"
                android:layout_height="@dimen/title_icon_size"
                android:layout_gravity="center_vertical|start"
                android:background="@android:color/transparent"
                android:contentDescription="@string/practice_spelling_done_exit"
                android:padding="@dimen/core_ui_dp_7"
                android:src="@drawable/module_learning_close"
                app:tint="#0F172A" />

            <TextView
                android:id="@+id/tv_header_title"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="@string/practice_spelling_done_header"
                android:textColor="#0F172A"
                android:textSize="@dimen/title_text_size"
                android:textStyle="bold" />
        </FrameLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_content"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="@dimen/core_ui_dp_140"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/top_bar">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="@dimen/core_ui_dp_12">

                <LinearLayout
                    android:id="@+id/card_hero"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/module_learning_bg_summary_hero"
                    android:elevation="@dimen/core_ui_dp_1"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/core_ui_dp_20"
                    android:paddingTop="@dimen/core_ui_dp_22"
                    android:paddingEnd="@dimen/core_ui_dp_20"
                    android:paddingBottom="@dimen/core_ui_dp_24">

                    <TextView
                        android:id="@+id/tv_done_tag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/module_learning_bg_summary_chip"
                        android:includeFontPadding="false"
                        android:paddingStart="@dimen/core_ui_dp_14"
                        android:paddingTop="@dimen/core_ui_dp_6"
                        android:paddingEnd="@dimen/core_ui_dp_14"
                        android:paddingBottom="@dimen/core_ui_dp_6"
                        android:text="@string/practice_spelling_done_tag"
                        android:textColor="#723B07"
                        android:textSize="@dimen/core_ui_text_14"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_accuracy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/core_ui_dp_12"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:textColor="#006C5B"
                        android:textSize="@dimen/core_ui_text_48"
                        android:textStyle="bold"
                        tools:text="86%" />

                    <TextView
                        android:id="@+id/tv_done_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/core_ui_dp_8"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:text="@string/practice_spelling_done_title"
                        android:textColor="#07111F"
                        android:textSize="@dimen/core_ui_text_25"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_done_subtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/core_ui_dp_10"
                        android:gravity="center"
                        android:lineSpacingExtra="@dimen/core_ui_dp_4"
                        android:textColor="#2F3A35"
                        android:textSize="@dimen/core_ui_text_14"
                        tools:text="完成 7 个单词，错词 1 个。" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/card_stats"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/core_ui_dp_92"
                    android:layout_marginTop="@dimen/core_ui_dp_14"
                    android:background="@drawable/module_learning_bg_summary_panel"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/core_ui_dp_12"
                    android:paddingEnd="@dimen/core_ui_dp_12">

                    <include
                        android:id="@+id/stat_completed"
                        layout="@layout/include_practice_spelling_done_stat" />

                    <View
                        android:layout_width="@dimen/core_ui_dp_1"
                        android:layout_height="@dimen/core_ui_dp_52"
                        android:background="@drawable/module_learning_bg_summary_divider" />

                    <include
                        android:id="@+id/stat_correct"
                        layout="@layout/include_practice_spelling_done_stat" />

                    <View
                        android:layout_width="@dimen/core_ui_dp_1"
                        android:layout_height="@dimen/core_ui_dp_52"
                        android:background="@drawable/module_learning_bg_summary_divider" />

                    <include
                        android:id="@+id/stat_wrong"
                        layout="@layout/include_practice_spelling_done_stat" />

                    <View
                        android:layout_width="@dimen/core_ui_dp_1"
                        android:layout_height="@dimen/core_ui_dp_52"
                        android:background="@drawable/module_learning_bg_summary_divider" />

                    <include
                        android:id="@+id/stat_hint"
                        layout="@layout/include_practice_spelling_done_stat" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_review_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_18"
                    android:includeFontPadding="false"
                    android:text="@string/practice_spelling_done_review_title"
                    android:textColor="#07111F"
                    android:textSize="@dimen/core_ui_text_19"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_review_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_12"
                    android:background="@drawable/module_learning_bg_summary_panel"
                    android:lineSpacingExtra="@dimen/core_ui_dp_4"
                    android:paddingStart="@dimen/core_ui_dp_18"
                    android:paddingTop="@dimen/core_ui_dp_16"
                    android:paddingEnd="@dimen/core_ui_dp_18"
                    android:paddingBottom="@dimen/core_ui_dp_16"
                    android:text="@string/practice_spelling_done_review_empty"
                    android:textColor="#26352F"
                    android:textSize="@dimen/core_ui_text_14" />

                <LinearLayout
                    android:id="@+id/layout_wrong_words"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_12"
                    android:orientation="vertical" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:id="@+id/action_panel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/core_ui_dp_20"
            android:elevation="@dimen/core_ui_dp_8"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_primary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/core_ui_dp_52"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="@dimen/core_ui_text_16"
                android:textStyle="bold"
                app:backgroundTint="@android:color/black"
                app:cornerRadius="@dimen/core_ui_dp_26" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_exit"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/core_ui_dp_50"
                android:layout_marginTop="@dimen/core_ui_dp_10"
                android:backgroundTint="@android:color/white"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/practice_spelling_done_exit"
                android:textAllCaps="false"
                android:textColor="#334155"
                android:textSize="@dimen/core_ui_text_16"
                android:textStyle="bold"
                app:cornerRadius="@dimen/core_ui_dp_25"
                app:strokeColor="#D8DEE8"
                app:strokeWidth="@dimen/core_ui_dp_1" />
        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_detail"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@android:color/white"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:id="@+id/detail_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/page_margin"
                android:layout_marginTop="@dimen/title_margin"
                android:layout_marginEnd="@dimen/page_margin"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageButton
                    android:id="@+id/btn_detail_back"
                    android:layout_width="@dimen/title_icon_size"
                    android:layout_height="@dimen/title_icon_size"
                    android:layout_gravity="center_vertical|start"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/practice_spelling_done_detail_back"
                    android:padding="@dimen/core_ui_dp_7"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#0F172A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="@string/learning_nav_word_detail_title"
                    android:textColor="#0F172A"
                    android:textSize="@dimen/title_text_size"
                    android:textStyle="bold" />
            </FrameLayout>

            <androidx.core.widget.NestedScrollView
                android:id="@+id/detail_scroll"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingBottom="@dimen/core_ui_dp_24"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/detail_header">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/core_ui_dp_18"
                    android:paddingTop="@dimen/core_ui_dp_18"
                    android:paddingEnd="@dimen/core_ui_dp_18">

                    <TextView
                        android:id="@+id/tv_detail_word"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="#0F172A"
                        android:textSize="@dimen/core_ui_text_32"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_detail_phonetic"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/core_ui_dp_10"
                        android:gravity="center"
                        android:textColor="#64748B"
                        android:textSize="@dimen/core_ui_text_14" />

                    <TextView
                        android:id="@+id/tv_detail_loading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/core_ui_dp_28"
                        android:gravity="center"
                        android:text="@string/practice_spelling_detail_loading"
                        android:textColor="#94A3B8"
                        android:textSize="@dimen/core_ui_text_14" />

                    <LinearLayout
                        android:id="@+id/layout_detail_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/core_ui_dp_24"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/learning_share_definitions_title"
                            android:textColor="#0F172A"
                            android:textSize="@dimen/core_ui_text_15"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/layout_detail_definitions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/core_ui_dp_10"
                            android:orientation="vertical" />

                        <TextView
                            android:id="@+id/tv_detail_examples_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/core_ui_dp_24"
                            android:text="@string/learning_share_examples_title"
                            android:textColor="#0F172A"
                            android:textSize="@dimen/core_ui_text_15"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/layout_detail_examples"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/core_ui_dp_10"
                            android:orientation="vertical" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/core_ui_dp_10"
    android:background="@drawable/module_learning_selector_summary_word_item"
    android:gravity="center_vertical"
    android:minHeight="@dimen/core_ui_dp_72"
    android:orientation="horizontal"
    android:paddingStart="@dimen/core_ui_dp_18"
    android:paddingTop="@dimen/core_ui_dp_10"
    android:paddingEnd="@dimen/core_ui_dp_14"
    android:paddingBottom="@dimen/core_ui_dp_10">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvWord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/core_ui_dp_8"
                android:ellipsize="end"
                android:fontFamily="serif"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="#07111F"
                android:textSize="@dimen/core_ui_text_18"
                android:textStyle="bold"
                tools:text="serene" />

            <TextView
                android:id="@+id/tvPhonetic"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="#4B5563"
                android:textSize="@dimen/core_ui_text_13"
                tools:text="/se'ri:n/" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDefinition"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_9"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="#111827"
            android:textSize="@dimen/core_ui_text_14"
            tools:text="adj. calm, peaceful" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvAction"
        android:layout_width="@dimen/core_ui_dp_28"
        android:layout_height="match_parent"
        android:layout_marginStart="@dimen/core_ui_dp_10"
        android:gravity="center"
        android:text="&#8250;"
        android:textColor="#9AA0A6"
        android:textSize="@dimen/core_ui_text_28"
        tools:text=">" />
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.text.Html" />

        <variable
            name="viewModel"
            type="com.chen.memorizewords.feature.learning.ui.fragment.WordLearningDetailViewModel" />
    </data>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp"
        android:paddingTop="24dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_definitions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/module_learning_bg_radius_eefdf7"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="@{viewModel.currentWord.memoryTip != null ? 0 : 8}">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/module_learning_lightbulb_10b981"
                android:text="记忆技巧"
                android:textColor="#167e5e"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@{viewModel.currentWord.memoryTip}"
                android:textColor="#6b7885"
                tools:text="词根记忆:sus(在....下面)+ tain(握住，支撑)able(能...的)>能在下面支撑住的>可持续的" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- 绿色竖条 -->
            <View
                android:layout_width="4dp"
                android:layout_height="18dp"
                android:layout_marginEnd="4dp"
                android:background="#10b981" />

            <!-- "例句"文字 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="例句"
                android:textColor="#aab8c8"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_examples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:layout_width="4dp"
                android:layout_height="18dp"
                android:layout_marginEnd="4dp"
                android:background="#fb9034" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="词性变化"
                android:textColor="#aab8c8"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_inflection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:layout_width="4dp"
                android:layout_height="18dp"
                android:layout_marginEnd="4dp"
                android:background="#60a5fa" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="词根词缀"
                android:textColor="#aab8c8"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_root"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:layout_width="4dp"
                android:layout_height="18dp"
                android:layout_marginEnd="4dp"
                android:background="#be7dfc" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="同反义词"
                android:textColor="#aab8c8"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_synonyms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />
    </LinearLayout>
</layout>
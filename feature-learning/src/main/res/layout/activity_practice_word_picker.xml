<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:paddingHorizontal="@dimen/core_ui_dp_4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_exit"
            android:layout_width="@dimen/core_ui_dp_48"
            android:layout_height="@dimen/core_ui_dp_48"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/practice_word_picker_exit"
            android:padding="@dimen/core_ui_dp_11"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_title"
            style="@style/FeatureLearning.ToolbarTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:autoSizeMaxTextSize="@dimen/core_ui_text_16"
            android:autoSizeMinTextSize="@dimen/core_ui_text_14"
            android:autoSizeStepGranularity="@dimen/core_ui_text_auto_size_step"
            android:autoSizeTextType="uniform"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="@string/practice_word_picker_title"
            android:textColor="#1F2937"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_confirm"
            app:layout_constraintStart_toEndOf="@id/btn_exit"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn_confirm"
            android:layout_width="@dimen/core_ui_dp_48"
            android:layout_height="@dimen/core_ui_dp_48"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/practice_word_picker_confirm"
            android:padding="@dimen/core_ui_dp_10"
            android:src="@drawable/feature_learning_ic_picker_confirm"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <EditText
        android:id="@+id/et_search"
        android:layout_width="0dp"
        android:layout_height="@dimen/core_ui_dp_44"
        android:layout_marginHorizontal="@dimen/core_ui_dp_16"
        android:layout_marginTop="@dimen/core_ui_dp_4"
        android:background="@drawable/feature_learning_bg_word_picker_search"
        android:drawableStart="@drawable/feature_learning_ic_picker_search"
        android:drawablePadding="@dimen/core_ui_dp_8"
        android:hint="@string/practice_word_picker_search_hint"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:paddingHorizontal="@dimen/core_ui_dp_16"
        android:singleLine="true"
        android:textColor="#111827"
        android:textColorHint="#D1D5DB"
        android:textSize="@dimen/core_ui_text_14"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar_actions"
        android:layout_width="0dp"
        android:layout_height="@dimen/core_ui_dp_44"
        android:layout_marginHorizontal="@dimen/core_ui_dp_16"
        android:layout_marginTop="@dimen/core_ui_dp_12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_search">

        <TextView
            android:id="@+id/btn_select_all"
            android:layout_width="@dimen/core_ui_dp_96"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical|start"
            android:text="@string/practice_word_picker_select_all_visible"
            android:textColor="#6B7280"
            android:textSize="@dimen/core_ui_text_14"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_selected_count"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="@string/practice_word_picker_selected_count_default"
            android:textColor="#D1D5DB"
            android:textSize="@dimen/core_ui_text_14"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_clear"
            app:layout_constraintStart_toEndOf="@id/btn_select_all"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="0 已选" />

        <TextView
            android:id="@+id/btn_clear"
            android:layout_width="@dimen/core_ui_dp_96"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical|end"
            android:text="@string/practice_word_picker_clear_selection"
            android:textColor="#6B7280"
            android:textSize="@dimen/core_ui_text_14"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/action_divider"
        android:layout_width="0dp"
        android:layout_height="@dimen/core_ui_dp_1"
        android:background="#F3F4F6"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar_actions" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_words"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/core_ui_dp_16"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/action_divider"
        tools:listitem="@layout/item_practice_word_select" />

    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:text="@string/practice_word_picker_empty"
        android:textColor="#94A3B8"
        android:textSize="@dimen/core_ui_text_14"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/action_divider" />

</androidx.constraintlayout.widget.ConstraintLayout>

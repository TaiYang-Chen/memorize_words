<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/popup_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="@dimen/core_ui_dp_4"
    android:paddingBottom="@dimen/core_ui_dp_4">

    <View
        android:id="@+id/arrow_top"
        android:layout_width="@dimen/core_ui_dp_12"
        android:layout_height="@dimen/core_ui_dp_12"
        android:layout_gravity="top|start"
        android:background="@drawable/module_learning_bg_popup_card"
        android:elevation="@dimen/core_ui_dp_6"
        android:rotation="45" />

    <LinearLayout
        android:id="@+id/card_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/core_ui_dp_6"
        android:layout_marginBottom="@dimen/core_ui_dp_6"
        android:background="@drawable/module_learning_bg_popup_card"
        android:elevation="@dimen/core_ui_dp_8"
        android:orientation="vertical"
        android:padding="@dimen/core_ui_dp_14">

        <TextView
            android:id="@+id/tv_word"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#111827"
            android:textSize="@dimen/core_ui_text_20"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_10"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_phonetic_us"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#475569"
                android:textSize="@dimen/core_ui_text_13" />

            <TextView
                android:id="@+id/btn_speak_us"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/module_learning_bg_popup_chip"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="@dimen/core_ui_dp_10"
                android:paddingTop="@dimen/core_ui_dp_6"
                android:paddingEnd="@dimen/core_ui_dp_10"
                android:paddingBottom="@dimen/core_ui_dp_6"
                android:text="美"
                android:textColor="#334155"
                android:textSize="@dimen/core_ui_text_12"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_6"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_phonetic_uk"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#475569"
                android:textSize="@dimen/core_ui_text_13" />

            <TextView
                android:id="@+id/btn_speak_uk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/module_learning_bg_popup_chip"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="@dimen/core_ui_dp_10"
                android:paddingTop="@dimen/core_ui_dp_6"
                android:paddingEnd="@dimen/core_ui_dp_10"
                android:paddingBottom="@dimen/core_ui_dp_6"
                android:text="英"
                android:textColor="#334155"
                android:textSize="@dimen/core_ui_text_12"
                android:textStyle="bold" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_loading"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/core_ui_dp_12"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_10"
            android:textColor="#6B7280"
            android:textSize="@dimen/core_ui_text_13"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_meaning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_10"
            android:lineSpacingExtra="@dimen/core_ui_dp_1"
            android:maxLines="4"
            android:textColor="#1F2937"
            android:textSize="@dimen/core_ui_text_14" />

        <TextView
            android:id="@+id/btn_view_full"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/core_ui_dp_14"
            android:background="@drawable/module_learning_select_radius_black"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingTop="@dimen/core_ui_dp_9"
            android:paddingBottom="@dimen/core_ui_dp_9"
            android:text="查看完整释义"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/core_ui_text_14"
            android:textStyle="bold" />

    </LinearLayout>

    <View
        android:id="@+id/arrow_bottom"
        android:layout_width="@dimen/core_ui_dp_12"
        android:layout_height="@dimen/core_ui_dp_12"
        android:layout_gravity="bottom|start"
        android:background="@drawable/module_learning_bg_popup_card"
        android:elevation="@dimen/core_ui_dp_6"
        android:rotation="45"
        android:visibility="gone" />

</FrameLayout>
<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/popup_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <View
        android:id="@+id/arrow_top"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_gravity="top|start"
        android:background="@drawable/module_learning_bg_popup_card"
        android:elevation="6dp"
        android:rotation="45" />

    <LinearLayout
        android:id="@+id/card_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:background="@drawable/module_learning_bg_popup_card"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tv_word"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#111827"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_phonetic_us"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#475569"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btn_speak_us"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/module_learning_bg_popup_chip"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:text="美"
                android:textColor="#334155"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_phonetic_uk"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#475569"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btn_speak_uk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/module_learning_bg_popup_chip"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:text="英"
                android:textColor="#334155"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_loading"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#6B7280"
            android:textSize="13sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_meaning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:lineSpacingExtra="1dp"
            android:maxLines="4"
            android:textColor="#1F2937"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btn_view_full"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/module_learning_select_radius_black"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:text="查看完整释义"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <View
        android:id="@+id/arrow_bottom"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_gravity="bottom|start"
        android:background="@drawable/module_learning_bg_popup_card"
        android:elevation="6dp"
        android:rotation="45"
        android:visibility="gone" />

</FrameLayout>

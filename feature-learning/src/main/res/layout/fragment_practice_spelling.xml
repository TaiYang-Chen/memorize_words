<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8FAFC">

        <FrameLayout
            android:id="@+id/layout_header"
            android:layout_width="0dp"
            android:layout_height="@dimen/title_height"
            android:layout_marginStart="@dimen/page_margin"
            android:layout_marginTop="@dimen/title_margin"
            android:layout_marginEnd="@dimen/page_margin"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="@dimen/title_icon_touch_size"
                android:layout_height="@dimen/title_icon_touch_size"
                android:layout_gravity="center_vertical|start"
                android:background="@android:color/transparent"
                android:contentDescription="@string/practice_spelling_back"
                android:padding="@dimen/core_ui_dp_7"
                android:src="@drawable/ic_arrow_back"
                app:tint="#0F172A" />

            <TextView
                android:id="@+id/tv_screen_title"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="@string/practice_mode_title_spelling"
                android:textColor="#0F172A"
                android:textSize="@dimen/title_text_size"
                android:textStyle="bold" />
        </FrameLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_practice"
            android:layout_width="0dp"
            android:layout_height="@dimen/core_ui_dp_2"
            android:layout_marginStart="@dimen/core_ui_dp_16"
            android:layout_marginTop="@dimen/core_ui_dp_2"
            android:layout_marginEnd="@dimen/core_ui_dp_16"
            android:max="100"
            android:progress="0"
            app:indicatorColor="#2F80ED"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_header"
            app:trackColor="#EDF1F5"
            app:trackCornerRadius="@dimen/core_ui_dp_2"
            app:trackThickness="@dimen/core_ui_dp_3" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_content"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:paddingBottom="@dimen/core_ui_dp_12"
            app:layout_constraintBottom_toTopOf="@id/layout_letter_panel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progress_practice">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="@dimen/core_ui_dp_18"
                android:paddingTop="@dimen/core_ui_dp_10"
                android:paddingEnd="@dimen/core_ui_dp_18">

                <TextView
                    android:id="@+id/tv_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/module_learning_bg_spelling_status_chip"
                    android:paddingStart="@dimen/core_ui_dp_12"
                    android:paddingTop="@dimen/core_ui_dp_5"
                    android:paddingEnd="@dimen/core_ui_dp_12"
                    android:paddingBottom="@dimen/core_ui_dp_5"
                    android:text="@string/practice_spelling_progress_default"
                    android:textColor="#5B677A"
                    android:textSize="@dimen/core_ui_text_12"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/layout_slots"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_18"
                    android:gravity="center"
                    android:orientation="horizontal" />

                <TextView
                    android:id="@+id/tv_word_length"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="0dp"
                    android:text="@string/practice_spelling_word_length_default"
                    android:textColor="#94A3B8"
                    android:textSize="@dimen/core_ui_text_13"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_play_audio"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/core_ui_dp_38"
                    android:layout_marginTop="@dimen/core_ui_dp_14"
                    android:backgroundTint="#EAF3FF"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="0dp"
                    android:paddingHorizontal="@dimen/core_ui_dp_18"
                    android:text="@string/practice_spelling_play_audio"
                    android:textAllCaps="false"
                    android:textColor="#2563EB"
                    android:textSize="@dimen/core_ui_text_13"
                    android:textStyle="bold"
                    app:cornerRadius="@dimen/core_ui_dp_19"
                    app:icon="@drawable/module_learning_ic_volume_up"
                    app:iconPadding="@dimen/core_ui_dp_6"
                    app:iconTint="#2563EB"
                    app:strokeWidth="0dp" />

                <TextView
                    android:id="@+id/tv_meaning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_18"
                    android:lineSpacingExtra="@dimen/core_ui_dp_2"
                    android:text="@string/practice_spelling_meaning_placeholder"
                    android:textColor="#1F2937"
                    android:textSize="@dimen/core_ui_text_16"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_10"
                    android:background="@drawable/module_learning_bg_practice_feedback"
                    android:paddingStart="@dimen/core_ui_dp_12"
                    android:paddingTop="@dimen/core_ui_dp_8"
                    android:paddingEnd="@dimen/core_ui_dp_12"
                    android:paddingBottom="@dimen/core_ui_dp_8"
                    android:textColor="#1D4ED8"
                    android:textSize="@dimen/core_ui_text_13"
                    android:visibility="gone" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_answer_layout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_14"
                    android:hint="@string/practice_spelling_input_hint"
                    app:boxBackgroundColor="@android:color/white"
                    app:boxBackgroundMode="filled"
                    app:boxCornerRadiusBottomEnd="@dimen/core_ui_dp_12"
                    app:boxCornerRadiusBottomStart="@dimen/core_ui_dp_12"
                    app:boxCornerRadiusTopEnd="@dimen/core_ui_dp_12"
                    app:boxCornerRadiusTopStart="@dimen/core_ui_dp_12"
                    app:boxStrokeColor="#E2E8F0"
                    app:boxStrokeWidth="@dimen/core_ui_dp_1"
                    app:boxStrokeWidthFocused="@dimen/core_ui_dp_1"
                    app:endIconMode="clear_text"
                    app:hintTextColor="#94A3B8">

                    <com.chen.memorizewords.feature.learning.ui.practice.AppendOnlyEditText
                        android:id="@+id/et_answer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionDone"
                        android:inputType="textNoSuggestions|textVisiblePassword"
                        android:maxLines="1"
                        android:textAllCaps="false"
                        android:textColor="#0F172A"
                        android:textSize="@dimen/core_ui_text_16" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/core_ui_dp_12"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_hint"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/core_ui_dp_38"
                        android:backgroundTint="@android:color/white"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="@dimen/core_ui_dp_16"
                        android:paddingEnd="@dimen/core_ui_dp_18"
                        android:text="@string/practice_spelling_hint"
                        android:textAllCaps="false"
                        android:textColor="#4F46E5"
                        android:textSize="@dimen/core_ui_text_13"
                        android:textStyle="bold"
                        app:cornerRadius="@dimen/core_ui_dp_19"
                        app:icon="@drawable/module_learning_lightbulb_10b981"
                        app:iconPadding="@dimen/core_ui_dp_7"
                        app:strokeColor="#D8DEE8"
                        app:strokeWidth="@dimen/core_ui_dp_1" />

                    <TextView
                        android:id="@+id/tv_attempt_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/core_ui_dp_12"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="@string/practice_spelling_attempt_status_default"
                        android:textColor="#7A849A"
                        android:textSize="@dimen/core_ui_text_12" />
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:id="@+id/layout_letter_panel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/module_learning_bg_spelling_keyboard_panel"
            android:elevation="0dp"
            android:orientation="vertical"
            android:paddingStart="@dimen/core_ui_dp_18"
            android:paddingTop="@dimen/core_ui_dp_10"
            android:paddingEnd="@dimen/core_ui_dp_18"
            android:paddingBottom="@dimen/core_ui_dp_10"
            app:layout_constraintBottom_toTopOf="@id/handwriting_drawer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:id="@+id/grid_letters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/handwriting_drawer"
            android:layout_width="0dp"
            android:layout_height="@dimen/core_ui_dp_40"
            android:background="@drawable/module_learning_bg_spelling_drawer"
            android:elevation="@dimen/core_ui_dp_1"
            android:orientation="vertical"
            android:paddingStart="@dimen/core_ui_dp_16"
            android:paddingEnd="@dimen/core_ui_dp_16"
            app:layout_constraintBottom_toTopOf="@id/bottom_actions"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:id="@+id/layout_handwriting_handle"
                android:layout_width="match_parent"
                android:layout_height="@dimen/core_ui_dp_40"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="@dimen/core_ui_dp_28"
                    android:layout_height="@dimen/core_ui_dp_3"
                    android:background="@drawable/module_learning_bg_spelling_drawer_grabber" />

                <TextView
                    android:id="@+id/tv_handwriting_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/core_ui_dp_12"
                    android:layout_weight="1"
                    android:text="@string/practice_spelling_handwriting_title"
                    android:textColor="#334155"
                    android:textSize="@dimen/core_ui_text_13"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_handwriting_toggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/practice_spelling_handwriting_expand"
                    android:textColor="#2563EB"
                    android:textSize="@dimen/core_ui_text_12"
                    android:textStyle="bold" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/handwriting_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/module_learning_bg_practice_handwriting"
                android:padding="@dimen/core_ui_dp_8">

                <com.chen.memorizewords.feature.learning.ui.practice.HandwritingCanvasView
                    android:id="@+id/handwriting_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <TextView
                    android:id="@+id/tv_handwriting_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/practice_spelling_handwriting_hint"
                    android:textColor="#CBD5E1"
                    android:textSize="@dimen/core_ui_text_12" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end|top"
                    android:layout_margin="@dimen/core_ui_dp_6"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_reset_handwriting"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/core_ui_dp_32"
                        android:background="@drawable/module_learning_bg_practice_chip"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingStart="@dimen/core_ui_dp_10"
                        android:paddingEnd="@dimen/core_ui_dp_10"
                        android:text="@string/practice_spelling_handwriting_reset"
                        android:textColor="#64748B"
                        android:textSize="@dimen/core_ui_text_11" />

                    <TextView
                        android:id="@+id/btn_clear_handwriting"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/core_ui_dp_32"
                        android:layout_marginStart="@dimen/core_ui_dp_8"
                        android:background="@drawable/module_learning_bg_practice_chip"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingStart="@dimen/core_ui_dp_10"
                        android:paddingEnd="@dimen/core_ui_dp_10"
                        android:text="@string/practice_clear"
                        android:textColor="#64748B"
                        android:textSize="@dimen/core_ui_text_11" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bottom_actions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:elevation="@dimen/core_ui_dp_2"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/core_ui_dp_16"
            android:paddingTop="@dimen/core_ui_dp_10"
            android:paddingEnd="@dimen/core_ui_dp_16"
            android:paddingBottom="@dimen/core_ui_dp_10"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_next_word"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/core_ui_dp_46"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/practice_next_word"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:cornerRadius="@dimen/core_ui_dp_23"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="@dimen/core_ui_dp_1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit"
                android:layout_width="0dp"
                android:layout_height="@dimen/core_ui_dp_46"
                android:layout_marginStart="@dimen/core_ui_dp_12"
                android:layout_weight="1.4"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/practice_spelling_submit_answer"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:cornerRadius="@dimen/core_ui_dp_23"
                app:icon="@drawable/module_learning_check"
                app:iconPadding="@dimen/core_ui_dp_8"
                app:iconTint="@android:color/white" />
        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_practice_detail"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@android:color/white"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:id="@+id/layout_detail_header"
                android:layout_width="0dp"
                android:layout_height="@dimen/title_height"
                android:layout_marginStart="@dimen/page_margin"
                android:layout_marginTop="@dimen/title_margin"
                android:layout_marginEnd="@dimen/page_margin"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageButton
                    android:id="@+id/btn_detail_back"
                    android:layout_width="@dimen/title_icon_touch_size"
                    android:layout_height="@dimen/title_icon_touch_size"
                    android:layout_gravity="center_vertical|start"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/practice_spelling_detail_back"
                    android:padding="@dimen/core_ui_dp_7"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#0F172A" />

                <TextView
                    android:id="@+id/tv_detail_title"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="@string/learning_nav_word_detail_title"
                    android:textColor="#0F172A"
                    android:textSize="@dimen/title_text_size"
                    android:textStyle="bold" />
            </FrameLayout>

            <androidx.core.widget.NestedScrollView
                android:id="@+id/scroll_practice_detail"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:overScrollMode="never"
                android:paddingBottom="@dimen/core_ui_dp_18"
                app:layout_constraintBottom_toTopOf="@id/layout_detail_bottom_actions"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layout_detail_header">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/core_ui_dp_18"
                    android:paddingTop="@dimen/core_ui_dp_18"
                    android:paddingEnd="@dimen/core_ui_dp_18">

                    <TextView
                        android:id="@+id/tv_detail_word"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="#0F172A"
                        android:textSize="@dimen/core_ui_text_32"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/core_ui_dp_12"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_detail_phonetic"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#64748B"
                            android:textSize="@dimen/core_ui_text_14" />

                        <ImageButton
                            android:id="@+id/btn_detail_speaker"
                            android:layout_width="@dimen/core_ui_dp_36"
                            android:layout_height="@dimen/core_ui_dp_36"
                            android:layout_marginStart="@dimen/core_ui_dp_6"
                            android:background="@android:color/transparent"
                            android:contentDescription="@string/practice_spelling_play_audio"
                            android:padding="@dimen/core_ui_dp_7"
                            android:src="@drawable/module_learning_ic_volume_up"
                            app:tint="#2563EB" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_detail_loading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/core_ui_dp_28"
                        android:gravity="center"
                        android:text="@string/practice_spelling_detail_loading"
                        android:textColor="#94A3B8"
                        android:textSize="@dimen/core_ui_text_14" />

                    <LinearLayout
                        android:id="@+id/layout_detail_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/core_ui_dp_24"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tv_detail_definitions_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/learning_share_definitions_title"
                            android:textColor="#0F172A"
                            android:textSize="@dimen/core_ui_text_15"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/layout_detail_definitions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/core_ui_dp_10"
                            android:orientation="vertical" />

                        <TextView
                            android:id="@+id/tv_detail_examples_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/core_ui_dp_24"
                            android:text="@string/learning_share_examples_title"
                            android:textColor="#0F172A"
                            android:textSize="@dimen/core_ui_text_15"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/layout_detail_examples"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/core_ui_dp_10"
                            android:orientation="vertical" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <LinearLayout
                android:id="@+id/layout_detail_bottom_actions"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:elevation="@dimen/core_ui_dp_2"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/core_ui_dp_16"
                android:paddingTop="@dimen/core_ui_dp_10"
                android:paddingEnd="@dimen/core_ui_dp_16"
                android:paddingBottom="@dimen/core_ui_dp_10"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_detail_next_word"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/core_ui_dp_46"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/practice_next_word"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    app:cornerRadius="@dimen/core_ui_dp_23" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>

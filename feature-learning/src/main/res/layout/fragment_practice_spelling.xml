<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8FAFC">

        <FrameLayout
            android:id="@+id/layout_header"
            android:layout_width="0dp"
            android:layout_height="@dimen/title_height"
            android:layout_marginStart="@dimen/page_margin"
            android:layout_marginTop="@dimen/title_margin"
            android:layout_marginEnd="@dimen/page_margin"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="@dimen/title_icon_touch_size"
                android:layout_height="@dimen/title_icon_touch_size"
                android:layout_gravity="center_vertical|start"
                android:background="@android:color/transparent"
                android:contentDescription="@string/practice_spelling_back"
                android:padding="7dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="#0F172A" />

            <TextView
                android:id="@+id/tv_screen_title"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="@string/practice_mode_title_spelling"
                android:textColor="#0F172A"
                android:textSize="@dimen/title_text_size"
                android:textStyle="bold" />
        </FrameLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_practice"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="16dp"
            android:max="100"
            android:progress="0"
            app:indicatorColor="#2F80ED"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_header"
            app:trackColor="#EDF1F5"
            app:trackCornerRadius="2dp"
            app:trackThickness="3dp" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_content"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:paddingBottom="12dp"
            app:layout_constraintBottom_toTopOf="@id/layout_letter_panel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progress_practice">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingTop="10dp"
                android:paddingEnd="18dp">

                <TextView
                    android:id="@+id/tv_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/module_learning_bg_spelling_status_chip"
                    android:paddingStart="12dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="5dp"
                    android:text="@string/practice_spelling_progress_default"
                    android:textColor="#5B677A"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/layout_slots"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:orientation="horizontal" />

                <TextView
                    android:id="@+id/tv_word_length"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="0dp"
                    android:text="@string/practice_spelling_word_length_default"
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_play_audio"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginTop="14dp"
                    android:backgroundTint="#EAF3FF"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="0dp"
                    android:paddingHorizontal="18dp"
                    android:text="@string/practice_spelling_play_audio"
                    android:textAllCaps="false"
                    android:textColor="#2563EB"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="19dp"
                    app:icon="@drawable/module_learning_ic_volume_up"
                    app:iconPadding="6dp"
                    app:iconTint="#2563EB"
                    app:strokeWidth="0dp" />

                <TextView
                    android:id="@+id/tv_meaning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/practice_spelling_meaning_placeholder"
                    android:textColor="#1F2937"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/module_learning_bg_practice_feedback"
                    android:paddingStart="12dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="8dp"
                    android:textColor="#1D4ED8"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_answer_layout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="@string/practice_spelling_input_hint"
                    app:boxBackgroundColor="@android:color/white"
                    app:boxBackgroundMode="filled"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxStrokeColor="#E2E8F0"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="1dp"
                    app:endIconMode="clear_text"
                    app:hintTextColor="#94A3B8">

                    <com.chen.memorizewords.feature.learning.ui.practice.AppendOnlyEditText
                        android:id="@+id/et_answer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionDone"
                        android:inputType="textNoSuggestions|textVisiblePassword"
                        android:maxLines="1"
                        android:textAllCaps="false"
                        android:textColor="#0F172A"
                        android:textSize="16sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_hint"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:backgroundTint="@android:color/white"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="18dp"
                        android:text="@string/practice_spelling_hint"
                        android:textAllCaps="false"
                        android:textColor="#4F46E5"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:cornerRadius="19dp"
                        app:icon="@drawable/module_learning_lightbulb_10b981"
                        app:iconPadding="7dp"
                        app:strokeColor="#D8DEE8"
                        app:strokeWidth="1dp" />

                    <TextView
                        android:id="@+id/tv_attempt_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="@string/practice_spelling_attempt_status_default"
                        android:textColor="#7A849A"
                        android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:id="@+id/layout_letter_panel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/module_learning_bg_spelling_keyboard_panel"
            android:elevation="0dp"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="10dp"
            android:paddingEnd="18dp"
            android:paddingBottom="10dp"
            app:layout_constraintBottom_toTopOf="@id/handwriting_drawer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:id="@+id/grid_letters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/handwriting_drawer"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:background="@drawable/module_learning_bg_spelling_drawer"
            android:elevation="1dp"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:layout_constraintBottom_toTopOf="@id/bottom_actions"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:id="@+id/layout_handwriting_handle"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="28dp"
                    android:layout_height="3dp"
                    android:background="@drawable/module_learning_bg_spelling_drawer_grabber" />

                <TextView
                    android:id="@+id/tv_handwriting_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/practice_spelling_handwriting_title"
                    android:textColor="#334155"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_handwriting_toggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/practice_spelling_handwriting_expand"
                    android:textColor="#2563EB"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/handwriting_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/module_learning_bg_practice_handwriting"
                android:padding="8dp">

                <com.chen.memorizewords.feature.learning.ui.practice.HandwritingCanvasView
                    android:id="@+id/handwriting_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <TextView
                    android:id="@+id/tv_handwriting_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/practice_spelling_handwriting_hint"
                    android:textColor="#CBD5E1"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end|top"
                    android:layout_margin="6dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_reset_handwriting"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:background="@drawable/module_learning_bg_practice_chip"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:text="@string/practice_spelling_handwriting_reset"
                        android:textColor="#64748B"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/btn_clear_handwriting"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/module_learning_bg_practice_chip"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:text="@string/practice_clear"
                        android:textColor="#64748B"
                        android:textSize="11sp" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bottom_actions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_next_word"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/practice_next_word"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:cornerRadius="23dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1.4"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/practice_spelling_submit_answer"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:cornerRadius="23dp"
                app:icon="@drawable/module_learning_check"
                app:iconPadding="8dp"
                app:iconTint="@android:color/white" />
        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_practice_detail"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@android:color/white"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:id="@+id/layout_detail_header"
                android:layout_width="0dp"
                android:layout_height="@dimen/title_height"
                android:layout_marginStart="@dimen/page_margin"
                android:layout_marginTop="@dimen/title_margin"
                android:layout_marginEnd="@dimen/page_margin"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageButton
                    android:id="@+id/btn_detail_back"
                    android:layout_width="@dimen/title_icon_touch_size"
                    android:layout_height="@dimen/title_icon_touch_size"
                    android:layout_gravity="center_vertical|start"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/practice_spelling_detail_back"
                    android:padding="7dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#0F172A" />

                <TextView
                    android:id="@+id/tv_detail_title"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="@string/learning_nav_word_detail_title"
                    android:textColor="#0F172A"
                    android:textSize="@dimen/title_text_size"
                    android:textStyle="bold" />
            </FrameLayout>

            <androidx.core.widget.NestedScrollView
                android:id="@+id/scroll_practice_detail"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:overScrollMode="never"
                android:paddingBottom="18dp"
                app:layout_constraintBottom_toTopOf="@id/layout_detail_bottom_actions"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layout_detail_header">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="18dp">

                    <TextView
                        android:id="@+id/tv_detail_word"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="#0F172A"
                        android:textSize="32sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_detail_phonetic"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#64748B"
                            android:textSize="14sp" />

                        <ImageButton
                            android:id="@+id/btn_detail_speaker"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginStart="6dp"
                            android:background="@android:color/transparent"
                            android:contentDescription="@string/practice_spelling_play_audio"
                            android:padding="7dp"
                            android:src="@drawable/module_learning_ic_volume_up"
                            app:tint="#2563EB" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_detail_loading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:gravity="center"
                        android:text="@string/practice_spelling_detail_loading"
                        android:textColor="#94A3B8"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/layout_detail_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tv_detail_definitions_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/learning_share_definitions_title"
                            android:textColor="#0F172A"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/layout_detail_definitions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical" />

                        <TextView
                            android:id="@+id/tv_detail_examples_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:text="@string/learning_share_examples_title"
                            android:textColor="#0F172A"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/layout_detail_examples"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <LinearLayout
                android:id="@+id/layout_detail_bottom_actions"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:elevation="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="10dp"
                android:paddingEnd="16dp"
                android:paddingBottom="10dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_detail_next_word"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/practice_next_word"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    app:cornerRadius="23dp" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
